@model HotelApp.Web.ViewModels.B2BBookingDashboardViewModel
@{
    ViewData["Title"] = "B2B Booking Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/room-dashboard.css" asp-append-version="true" />
<style>
.bk-hero{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.7rem;
         background:linear-gradient(135deg,#b45309 0%,#1a2a6c 45%,#4338ca 100%);
         border-radius:16px;padding:1rem 1.4rem;margin-bottom:.9rem;
         box-shadow:0 6px 24px rgba(26,42,108,.22);position:relative;overflow:hidden;}
.bk-hero::before{content:'';position:absolute;right:-60px;top:-60px;width:200px;height:200px;background:rgba(255,255,255,.07);border-radius:50%;}
.bk-hero::after {content:'';position:absolute;left:10%;bottom:-70px;width:240px;height:240px;background:rgba(255,255,255,.04);border-radius:50%;}
.bk-hero-left{display:flex;align-items:center;gap:1rem;z-index:1;}
.bk-hero-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;
              background:rgba(255,255,255,.18);border:1.5px solid rgba(255,255,255,.3);color:#fff;font-size:1.4rem;flex-shrink:0;}
.bk-hero-title{font-size:1.3rem;font-weight:800;color:#fff;letter-spacing:-.2px;}
.bk-hero-sub{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-top:.25rem;}
.bk-badge{display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .6rem;border-radius:20px;font-size:.72rem;font-weight:700;}
.bk-badge-branch{background:rgba(255,255,255,.18);color:#fff;}
.bk-badge-b2b{background:rgba(255,220,80,.22);color:#ffe082;}
.bk-today{font-size:.75rem;color:rgba(255,255,255,.7);}
.bk-hero-right{display:flex;gap:.55rem;z-index:1;flex-wrap:wrap;}
.bk-hero-btn{display:inline-flex;align-items:center;gap:.4rem;padding:.45rem 1rem;border-radius:9px;font-size:.81rem;font-weight:700;text-decoration:none;transition:all .18s;}
.bk-hero-btn-pri{background:#fff;color:#1a2a6c;}
.bk-hero-btn-pri:hover{background:#e8f0fe;color:#1a2a6c;text-decoration:none;transform:translateY(-1px);}
.bk-hero-btn-sec{background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.3);}
.bk-hero-btn-sec:hover{background:rgba(255,255,255,.25);color:#fff;text-decoration:none;}
/* B2B-specific: amber card for outstanding */
.status-card.b2b-outstanding { background:linear-gradient(140deg,#e65100,#ffa726); }
</style>
}

@{
    var b2bBranch = ViewBag.CurrentBranchName as string ?? "Head Office";
    var b2bRole   = ViewBag.SelectedRoleName as string ?? User.Claims.FirstOrDefault(c => c.Type == "SelectedRoleName")?.Value ?? "";
}
<div class="bk-hero">
    <div class="bk-hero-left">
        <div class="bk-hero-icon"><i class="fas fa-briefcase"></i></div>
        <div>
            <div class="bk-hero-title">B2B Booking Dashboard</div>
            <div class="bk-hero-sub">
                <span class="bk-badge bk-badge-branch"><i class="fas fa-code-branch"></i> @b2bBranch</span>
                <span class="bk-badge bk-badge-b2b"><i class="fas fa-building"></i> B2B</span>
                @if (!string.IsNullOrWhiteSpace(b2bRole)) { <span class="bk-badge bk-badge-b2b"><i class="fas fa-id-badge"></i> @b2bRole</span> }
                <span class="bk-today"><i class="fas fa-calendar"></i> @DateTime.Today.ToString("dddd, dd MMM yyyy")</span>
            </div>
        </div>
    </div>
    <div class="bk-hero-right">
        <a asp-action="Create" class="bk-hero-btn bk-hero-btn-pri"><i class="fas fa-plus"></i> New B2B Booking</a>
        <a asp-action="List" asp-controller="Booking" class="bk-hero-btn bk-hero-btn-sec"><i class="fas fa-list"></i> All Bookings</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
}

<div class="status-cards">
    <div class="status-card available">
        <i class="fas fa-calendar-plus sc-icon"></i>
        <h3>Today's B2B Bookings</h3>
        <div class="value">@Model.TodayBookingCount</div>
        <div class="sc-sub">Corporate bookings today</div>
    </div>
    <div class="status-card occupied">
        <i class="fas fa-rupee-sign sc-icon"></i>
        <h3>Today's Advance</h3>
        <div class="value">₹@Model.TodayAdvanceAmount.ToString("N0")</div>
        <div class="sc-sub">Advance received today</div>
    </div>
    <div class="status-card maintenance">
        <i class="fas fa-building sc-icon"></i>
        <h3>Active Clients</h3>
        <div class="value">@Model.ActiveClientCount</div>
        <div class="sc-sub">B2B clients with bookings</div>
    </div>
    <div class="status-card b2b-outstanding">
        <i class="fas fa-exclamation-circle sc-icon"></i>
        <h3>Total Outstanding</h3>
        <div class="value">₹@Model.TotalOutstandingAmount.ToString("N0")</div>
        <div class="sc-sub">Pending dues from clients</div>
    </div>
</div>

<div class="filters-container">
    <form method="get" asp-action="Index" class="date-filter-form">
        <div class="filter-group">
            <label for="fromDate">From Check-In Date:</label>
            <input type="date" id="fromDate" name="fromDate" class="form-control" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="filter-group">
            <label for="toDate">To Check-In Date:</label>
            <input type="date" id="toDate" name="toDate" class="form-control" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="filter-group">
            <label for="statusFilter">Status Filter:</label>
            <select id="statusFilter" name="statusFilter" class="form-control">
                <option value="">All B2B Bookings</option>
                <option value="upcoming" selected="@(Model.StatusFilter == "upcoming")">Upcoming Booking</option>
                <option value="assigned" selected="@(Model.StatusFilter == "assigned")">Assigned Room</option>
                <option value="notassigned" selected="@(Model.StatusFilter == "notassigned")">Not Assigned Room</option>
                <option value="checkedin" selected="@(Model.StatusFilter == "checkedin")">Checked In</option>
                <option value="checkedout" selected="@(Model.StatusFilter == "checkedout")">Checked Out</option>
                <option value="cancelled" selected="@(Model.StatusFilter == "cancelled")">Cancelled</option>
                <option value="due" selected="@(Model.StatusFilter == "due")">Due Payment</option>
                <option value="fullypaid" selected="@(Model.StatusFilter == "fullypaid")">Fully Paid</option>
            </select>
        </div>
        <div class="filter-actions">
            <button type="submit" class="btn-filter-apply"><i class="fas fa-filter"></i> Apply Filter</button>
            <a asp-action="Index" class="btn-filter-clear"><i class="fas fa-times"></i> Clear</a>
        </div>
    </form>
</div>

@if (Model.Bookings.Any())
{
    <div class="table-container" style="overflow: visible;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Booking #</th>
                    <th>Company</th>
                    <th>Agreement</th>
                    <th>Primary Guest</th>
                    <th>Stay</th>
                    <th>Room</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model.Bookings)
                {
                    <tr>
                        <td>
                            <strong>@booking.BookingNumber</strong>
                            <div class="subtext">@booking.Source / @booking.Channel</div>
                        </td>
                        <td>
                            <strong>@booking.B2BClientName</strong>
                            <div class="subtext">@booking.B2BClientCode</div>
                        </td>
                        <td>
                            <strong>@booking.AgreementName</strong>
                            <div class="subtext">@booking.AgreementCode</div>
                        </td>
                        <td>
                            <strong>@booking.PrimaryGuestFirstName @booking.PrimaryGuestLastName</strong>
                            <div class="subtext">@booking.PrimaryGuestPhone</div>
                        </td>
                        <td>
                            <div>@booking.CheckInDate.ToString("dd MMM yyyy") - @booking.CheckOutDate.ToString("dd MMM yyyy")</div>
                            <div class="subtext">@booking.Nights night(s)</div>
                        </td>
                        <td>
                            <div>@booking.RoomType?.TypeName</div>
                            <div class="subtext">Rooms: @booking.RequiredRooms</div>
                        </td>
                        <td>
                            <strong>₹@booking.TotalAmount.ToString("N0")</strong>
                            <div class="subtext">Balance: ₹@booking.BalanceAmount.ToString("N0")</div>
                        </td>
                        <td>
                            <span class="badge @(booking.Status == "Cancelled" ? "badge-maintenance" : "badge-available")">@booking.Status</span>
                            <div class="subtext">@booking.PaymentStatus</div>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a asp-action="Details" asp-route-bookingNumber="@booking.BookingNumber" class="btn-action btn-view"><i class="fas fa-eye"></i><span>View</span></a>
                                <a asp-controller="Booking" asp-action="Details" asp-route-bookingNumber="@booking.BookingNumber" class="btn-action btn-edit"><i class="fas fa-gears"></i><span>Ops</span></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="empty-state">
        <i class="fas fa-briefcase"></i>
        <h3>No B2B Bookings Found</h3>
        <p>Create a separate corporate or travel-agent booking without touching the standard B2C flow.</p>
        <a asp-action="Create" class="btn-create"><i class="fas fa-plus"></i> New B2B Booking</a>
    </div>
}