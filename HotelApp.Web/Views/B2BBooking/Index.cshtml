@model HotelApp.Web.ViewModels.B2BBookingDashboardViewModel
@{
    ViewData["Title"] = "B2B Booking Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/room-dashboard.css" asp-append-version="true" />
}

<div class="page-header">
    <h2><i class="fas fa-briefcase"></i> B2B Booking Dashboard</h2>
    <a asp-action="Create" class="btn-create"><i class="fas fa-plus"></i> New B2B Booking</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
}

<div class="status-cards booking-status-cards">
    <div class="status-card available">
        <h3>Today's B2B Bookings</h3>
        <div class="value">@Model.TodayBookingCount</div>
    </div>
    <div class="status-card occupied">
        <h3>Today's Advance</h3>
        <div class="value">₹@Model.TodayAdvanceAmount.ToString("N0")</div>
    </div>
    <div class="status-card maintenance">
        <h3>Active Clients</h3>
        <div class="value">@Model.ActiveClientCount</div>
    </div>
    <div class="status-card cleaning">
        <h3>Total Outstanding</h3>
        <div class="value">₹@Model.TotalOutstandingAmount.ToString("N0")</div>
    </div>
</div>

<div class="filters-container">
    <form method="get" asp-action="Index" class="date-filter-form">
        <div class="filter-group">
            <label for="fromDate">From Check-In Date:</label>
            <input type="date" id="fromDate" name="fromDate" class="form-control" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="filter-group">
            <label for="toDate">To Check-In Date:</label>
            <input type="date" id="toDate" name="toDate" class="form-control" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="filter-group">
            <label for="statusFilter">Status Filter:</label>
            <select id="statusFilter" name="statusFilter" class="form-control">
                <option value="">All B2B Bookings</option>
                <option value="upcoming" selected="@(Model.StatusFilter == "upcoming")">Upcoming Booking</option>
                <option value="assigned" selected="@(Model.StatusFilter == "assigned")">Assigned Room</option>
                <option value="notassigned" selected="@(Model.StatusFilter == "notassigned")">Not Assigned Room</option>
                <option value="checkedin" selected="@(Model.StatusFilter == "checkedin")">Checked In</option>
                <option value="checkedout" selected="@(Model.StatusFilter == "checkedout")">Checked Out</option>
                <option value="cancelled" selected="@(Model.StatusFilter == "cancelled")">Cancelled</option>
                <option value="due" selected="@(Model.StatusFilter == "due")">Due Payment</option>
                <option value="fullypaid" selected="@(Model.StatusFilter == "fullypaid")">Fully Paid</option>
            </select>
        </div>
        <div class="filter-actions">
            <button type="submit" class="btn-filter-apply"><i class="fas fa-filter"></i> Apply Filter</button>
            <a asp-action="Index" class="btn-filter-clear"><i class="fas fa-times"></i> Clear</a>
        </div>
    </form>
</div>

@if (Model.Bookings.Any())
{
    <div class="table-container" style="overflow: visible;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Booking #</th>
                    <th>Company</th>
                    <th>Agreement</th>
                    <th>Primary Guest</th>
                    <th>Stay</th>
                    <th>Room</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model.Bookings)
                {
                    <tr>
                        <td>
                            <strong>@booking.BookingNumber</strong>
                            <div class="subtext">@booking.Source / @booking.Channel</div>
                        </td>
                        <td>
                            <strong>@booking.B2BClientName</strong>
                            <div class="subtext">@booking.B2BClientCode</div>
                        </td>
                        <td>
                            <strong>@booking.AgreementName</strong>
                            <div class="subtext">@booking.AgreementCode</div>
                        </td>
                        <td>
                            <strong>@booking.PrimaryGuestFirstName @booking.PrimaryGuestLastName</strong>
                            <div class="subtext">@booking.PrimaryGuestPhone</div>
                        </td>
                        <td>
                            <div>@booking.CheckInDate.ToString("dd MMM yyyy") - @booking.CheckOutDate.ToString("dd MMM yyyy")</div>
                            <div class="subtext">@booking.Nights night(s)</div>
                        </td>
                        <td>
                            <div>@booking.RoomType?.TypeName</div>
                            <div class="subtext">Rooms: @booking.RequiredRooms</div>
                        </td>
                        <td>
                            <strong>₹@booking.TotalAmount.ToString("N0")</strong>
                            <div class="subtext">Balance: ₹@booking.BalanceAmount.ToString("N0")</div>
                        </td>
                        <td>
                            <span class="badge @(booking.Status == "Cancelled" ? "badge-maintenance" : "badge-available")">@booking.Status</span>
                            <div class="subtext">@booking.PaymentStatus</div>
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a asp-action="Details" asp-route-bookingNumber="@booking.BookingNumber" class="btn-action btn-view"><i class="fas fa-eye"></i><span>View</span></a>
                                <a asp-controller="Booking" asp-action="Details" asp-route-bookingNumber="@booking.BookingNumber" class="btn-action btn-edit"><i class="fas fa-gears"></i><span>Ops</span></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="empty-state">
        <i class="fas fa-briefcase"></i>
        <h3>No B2B Bookings Found</h3>
        <p>Create a separate corporate or travel-agent booking without touching the standard B2C flow.</p>
        <a asp-action="Create" class="btn-create"><i class="fas fa-plus"></i> New B2B Booking</a>
    </div>
}