@model HotelApp.Web.ViewModels.B2BBookingCreateViewModel
@using HotelApp.Web.Models
@{
    ViewData["Title"] = "Create B2B Booking";
    var roomTypes = ViewBag.RoomTypes as IEnumerable<RoomType> ?? Enumerable.Empty<RoomType>();
    var clients = ViewBag.Clients as IEnumerable<B2BClient> ?? Enumerable.Empty<B2BClient>();
    var sources = ViewBag.Sources as IEnumerable<string> ?? Enumerable.Empty<string>();
    var channels = ViewBag.Channels as IEnumerable<string> ?? Enumerable.Empty<string>();
    var paymentMethods = ViewBag.PaymentMethods as IReadOnlyDictionary<string, string> ?? new Dictionary<string, string>();
}

<style>
/* ── Page Shell ─────────────────────────────────────────── */
.b2b-page {
    padding: 12px 16px 32px;
    background: #f0f4f8;
    min-height: calc(100vh - 80px);
}

/* ── Page Header ─────────────────────────────────────────── */
.b2b-page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
}
.b2b-page-header h2 {
    margin: 0;
    font-size: 20px;
    font-weight: 700;
    color: #1e293b;
    display: flex;
    align-items: center;
    gap: 8px;
}
.b2b-page-header h2 .icon-badge {
    width: 34px; height: 34px;
    border-radius: 8px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    display: inline-flex; align-items: center; justify-content: center;
    color: white; font-size: 16px; flex-shrink: 0;
}



/* ── Grid Layout ─────────────────────────────────────────── */
.b2b-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 340px;
    gap: 12px;
    align-items: start;
}
.b2b-summary-col {
    grid-column: 3;
    grid-row: 1 / span 3;
}
.b2b-billing-row {
    grid-column: 1 / span 2;
}
.b2b-billing-row .b2b-card-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 20px;
}
.b2b-billing-row .b2b-section {
    padding-bottom: 14px;
    margin-bottom: 0;
    border-bottom: none;
}
.b2b-billing-row .b2b-fg {
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px 14px;
}
.b2b-billing-row .b2b-fg .f2 { grid-column: span 3; }

/* ── Card ────────────────────────────────────────────────── */
.b2b-card {
    background: white;
    border-radius: 14px;
    box-shadow: 0 1px 4px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.04);
    overflow: hidden;
}
.b2b-card-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid #f1f5f9;
    background: #fafbfc;
}
.b2b-card-header .hdr-icon {
    width: 32px; height: 32px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; color: white; flex-shrink: 0;
}
.hdr-icon.purple  { background: linear-gradient(135deg,#6366f1,#8b5cf6); }
.hdr-icon.teal    { background: linear-gradient(135deg,#0891b2,#0e7490); }
.hdr-icon.amber   { background: linear-gradient(135deg,#d97706,#b45309); }
.b2b-card-header h3 { margin: 0; font-size: 14px; font-weight: 700; color: #1e293b; }
.b2b-card-header p  { margin: 1px 0 0; font-size: 11px; color: #94a3b8; }
.b2b-card-body { padding: 14px; }

/* ── Section divider inside card ────────────────────────── */
.b2b-section {
    padding-bottom: 14px;
    margin-bottom: 14px;
    border-bottom: 1px dashed #e2e8f0;
}
.b2b-section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.b2b-section-label {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 12px;
}
.b2b-section-label span { font-size: 12px; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: .04em; }
.b2b-section-label small { font-size: 11px; color: #94a3b8; }

/* ── Form Grid ───────────────────────────────────────────── */
.b2b-fg {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 12px;
}
.b2b-fg .f1 { grid-column: span 1; }
.b2b-fg .f2 { grid-column: span 2; }

/* ── Field ───────────────────────────────────────────────── */
.b2b-field {
    display: flex; flex-direction: column; gap: 5px;
}
.b2b-field label {
    font-size: 11.5px; font-weight: 600; color: #374151;
}
.b2b-field input,
.b2b-field select,
.b2b-field textarea {
    width: 100%; padding: 7px 10px;
    border: 1.5px solid #e2e8f0; border-radius: 7px;
    font-size: 13px; color: #1e293b; background: white;
    transition: border-color .18s, box-shadow .18s;
    line-height: 1.4;
}
.b2b-field input:focus,
.b2b-field select:focus,
.b2b-field textarea:focus {
    outline: none; border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99,102,241,.12);
}
.b2b-field input[readonly],
.b2b-field textarea[readonly] {
    background: #f8fafc; color: #64748b; cursor: default;
}
.b2b-field textarea { min-height: 70px; resize: vertical; }
.b2b-field .text-danger { font-size: 11.5px; margin-top: 2px; }

/* ── Field note ─────────────────────────────────────────── */
.b2b-hint { font-size: 11px; color: #94a3b8; margin-top: 4px; line-height: 1.45; }

/* ── Advance toggle row ─────────────────────────────────── */
.b2b-toggle-row {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; border-radius: 8px;
    background: #f8fafc; border: 1.5px solid #e2e8f0;
    cursor: pointer; grid-column: span 2;
}
.b2b-toggle-row input[type=checkbox] { width: 16px; height: 16px; margin: 0; accent-color: #6366f1; }
.b2b-toggle-row span { font-size: 13px; font-weight: 600; color: #374151; }

/* ── Quote card (right panel) ───────────────────────────── */
.b2b-quote {
    background: linear-gradient(145deg, #6366f1 0%, #8b5cf6 60%, #7c3aed 100%);
    color: white;
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 10px;
}
.b2b-quote h4 {
    margin: 0 0 10px; font-size: 15px; font-weight: 700;
    display: flex; align-items: center; gap: 8px;
}
.b2b-quote-row {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,.18);
    font-size: 12.5px;
}
.b2b-quote-row:last-of-type { border-bottom: none; }
.b2b-quote-row.grand {
    padding-top: 10px; margin-top: 2px;
    border-top: 1px solid rgba(255,255,255,.3);
    font-size: 17px; font-weight: 700;
}
.b2b-quote-row strong { font-size: inherit; }
.b2b-quote-note {
    margin-top: 12px; font-size: 11.5px;
    opacity: .82; line-height: 1.5;
}

/* ── Action buttons ─────────────────────────────────────── */
.b2b-actions { display: flex; flex-direction: column; gap: 8px; }
.btn-b2b-primary {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    padding: 11px 16px;
    background: linear-gradient(135deg, #6366f1, #7c3aed);
    color: white; font-size: 14px; font-weight: 700;
    border: none; border-radius: 8px; cursor: pointer;
    text-decoration: none;
    transition: opacity .2s, transform .15s, box-shadow .2s;
    box-shadow: 0 4px 14px rgba(99,102,241,.35);
}
.btn-b2b-primary:hover:not(:disabled) {
    opacity: .92; transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(99,102,241,.45); color: white;
}
.btn-b2b-primary:disabled {
    opacity: .45; cursor: not-allowed; transform: none; box-shadow: none;
}
.btn-b2b-secondary {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    padding: 9px 14px;
    background: white; color: #475569;
    font-size: 13px; font-weight: 600;
    border: 1.5px solid #e2e8f0; border-radius: 8px; cursor: pointer;
    text-decoration: none;
    transition: border-color .18s, background .18s, color .18s;
}
.btn-b2b-secondary:hover { border-color: #6366f1; color: #6366f1; background: #f5f3ff; }

/* ── Availability badge ─────────────────────────────────── */
#availabilityBadge {
    display: none;
    margin-top: 6px;
}
.avail-ok  { display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border-radius:6px;background:#dcfce7;color:#166534;font-size:12px;font-weight:700; }
.avail-err { display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border-radius:6px;background:#fee2e2;color:#991b1b;font-size:12px;font-weight:700; }

/* ── Room Selection Cards ─────────────────────────────────── */
.b2b-room-sel-wrap { margin-top: 14px; }
.room-card {
    border: 1.5px solid #e2e8f0; border-radius: 10px;
    margin-bottom: 10px; overflow: hidden;
    transition: border-color .2s, box-shadow .2s;
}
.room-card.rc-active { border-color: #6366f1; box-shadow: 0 0 0 2px rgba(99,102,241,.12); }
.room-card-hdr {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px; background: #fafbfc;
    border-bottom: 1px solid #f1f5f9; flex-wrap: wrap;
}
.room-card-hdr .rt-name  { font-weight: 700; color: #1e293b; font-size: 14px; flex: 1; min-width:100px; }
.room-card-hdr .rt-rate  { font-weight: 700; color: #6366f1; font-size: 14px; white-space: nowrap; }
.room-card-hdr .rt-season { font-size: 11px; color: #94a3b8; font-style: italic; padding-left:6px; }
.room-card-hdr .rt-meal  { font-size: 11px; color: #0d9488; background: #f0fdfa; padding: 2px 8px; border-radius: 999px; font-weight: 600; }
.room-qty-wrap { display: flex; align-items: center; gap: 6px; }
.room-qty-wrap label { font-size: 11px; color: #64748b; font-weight: 600; }
.room-qty-input {
    width: 64px; padding: 6px 8px;
    border: 1.5px solid #e2e8f0; border-radius: 8px;
    text-align: center; font-size: 14px; font-weight: 700;
    color: #1e293b; background: white;
}
.room-qty-input:focus { outline: none; border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.12); }
.room-card-detail {
    display: none; padding: 12px 14px;
    background: #faf5ff;
}
.room-card.rc-active .room-card-detail { display: flex; gap: 10px; flex-wrap: wrap; }
.room-card-detail .rc-field { display: flex; flex-direction: column; gap: 3px; flex: 1; min-width: 100px; }
.room-card-detail .rc-field label { font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: .04em; }
.room-card-detail .rc-field input { padding: 7px 9px; border: 1.5px solid #e2e8f0; border-radius: 7px; font-size: 13px; color: #1e293b; background: white; min-width: 0; }
.room-card-detail .rc-field input:focus { outline: none; border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.12); }
.room-card-detail .rc-field input[readonly] { background: #f1f5f9; color: #64748b; cursor: default; }
.quote-line-entry {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 4px 0; font-size: 12px; opacity: .9;
}
.quote-line-entry:not(:last-child) { border-bottom: 1px solid rgba(255,255,255,.12); }

/* ── Validation summary ─────────────────────────────────── */
.b2b-validation {
    padding: 12px 16px; margin-bottom: 14px;
    background: #fff1f2; border: 1px solid #fecdd3;
    border-left: 4px solid #f43f5e; border-radius: 10px;
    color: #9f1239; font-size: 13px;
}
.b2b-validation ul { margin: 6px 0 0 16px; padding: 0; }
.b2b-validation:empty { display: none !important; }

/* ── Responsive: Tablet ─────────────────────────────────── */
@@media (max-width: 1200px) {
    .b2b-grid { grid-template-columns: 1fr 1fr; }
    .b2b-summary-col { grid-column: span 2 !important; grid-row: auto !important; }
    .b2b-billing-row { grid-column: span 2; }
    .b2b-billing-row .b2b-card-body { grid-template-columns: 1fr 1fr; }
    .b2b-billing-row .b2b-fg { grid-template-columns: 1fr 1fr; }
    .b2b-billing-row .b2b-fg .f2 { grid-column: span 2; }
}

@@media (max-width: 900px) {
    .b2b-grid { grid-template-columns: 1fr; }
    .b2b-summary-col { grid-column: span 1 !important; grid-row: auto !important; }
    .b2b-billing-row { grid-column: span 1; }
    .b2b-billing-row .b2b-card-body { grid-template-columns: 1fr; }
    .b2b-billing-row .b2b-fg { grid-template-columns: 1fr 1fr; }
    .b2b-billing-row .b2b-fg .f2 { grid-column: span 2; }
    .b2b-fg { grid-template-columns: 1fr 1fr; }
    .b2b-fg .f1 { grid-column: span 1; }
    .b2b-fg .f2 { grid-column: span 2; }
}

/* ── Responsive: Mobile ─────────────────────────────────── */
@@media (max-width: 600px) {
    .b2b-page { padding: 10px 12px 32px; }
    .b2b-page-header h2 { font-size: 17px; }
    .b2b-page-header h2 .icon-badge { width: 30px; height: 30px; font-size: 13px; }
    .b2b-banner { flex-direction: column; align-items: flex-start; }
    .b2b-fg { grid-template-columns: 1fr; }
    .b2b-fg .f1,
    .b2b-fg .f2 { grid-column: span 1; }
    .b2b-toggle-row { grid-column: span 1; }
    .b2b-card-header { padding: 12px 14px; }
    .b2b-card-body { padding: 14px; }
    .b2b-quote { padding: 16px; }
    .b2b-quote-row.grand { font-size: 16px; }
}
</style>

<div class="b2b-page">

    <div class="b2b-page-header">
        <h2>
            <span class="icon-badge"><i class="fas fa-briefcase"></i></span>
            Create B2B Booking
        </h2>
        <a asp-action="Index" class="btn-b2b-secondary" style="flex:none;">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <div asp-validation-summary="All" class="b2b-validation" style="display:none;"></div>
    <script>document.addEventListener('DOMContentLoaded',function(){var v=document.querySelector('.b2b-validation');if(v&&v.querySelector('li')){v.style.display='';}});</script>

    <form asp-action="Create" method="post" id="b2bBookingForm">
        @Html.AntiForgeryToken()

        <div class="b2b-grid">

            <div class="b2b-card">
                <div class="b2b-card-header">
                    <span class="hdr-icon purple"><i class="fas fa-building-user"></i></span>
                    <div>
                        <h3>Company &amp; Guest</h3>
                        <p>Client, agreement, and primary contact details</p>
                    </div>
                </div>
                <div class="b2b-card-body">

                    <div class="b2b-section">
                        <div class="b2b-section-label">
                            <span>Company Context</span>
                            <small>Agreement auto-resolves</small>
                        </div>
                        <div class="b2b-fg">
                            <div class="b2b-field f2">
                                <label asp-for="ClientId"></label>
                                <select asp-for="ClientId" id="ClientId">
                                    <option value="">— Select B2B Client —</option>
                                    @foreach (var client in clients)
                                    {
                                        <option value="@client.Id">@client.ClientName (@client.ClientCode)</option>
                                    }
                                </select>
                                <span asp-validation-for="ClientId" class="text-danger"></span>
                            </div>
                            <div class="b2b-field f2">
                                <label asp-for="AgreementId">Agreement</label>
                                <input asp-for="AgreementId" id="AgreementId" type="hidden" />
                                <input id="AgreementDisplay" value="@(string.IsNullOrWhiteSpace(Model.AgreementName) ? string.Empty : $"{Model.AgreementName} ({Model.AgreementCode})")" readonly placeholder="Auto-populated after client selection" />
                                <span asp-validation-for="AgreementId" class="text-danger"></span>
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="ClientCode"></label>
                                <input asp-for="ClientCode" id="ClientCode" readonly placeholder="Auto" />
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="AgreementCode"></label>
                                <input asp-for="AgreementCode" id="AgreementCode" readonly placeholder="Auto" />
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="CompanyContactPerson"></label>
                                <input asp-for="CompanyContactPerson" id="CompanyContactPerson" readonly placeholder="Auto" />
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="CompanyContactNo"></label>
                                <input asp-for="CompanyContactNo" id="CompanyContactNo" readonly placeholder="Auto" />
                            </div>
                            <div class="b2b-field f2">
                                <label asp-for="CompanyEmail"></label>
                                <input asp-for="CompanyEmail" id="CompanyEmail" readonly placeholder="Auto" />
                            </div>
                        </div>
                    </div>

                    <div class="b2b-section">
                        <div class="b2b-section-label">
                            <span>Primary Guest</span>
                            <small>Booking contact</small>
                        </div>
                        <div class="b2b-fg">
                            <div class="b2b-field f1">
                                <label asp-for="PrimaryGuestFirstName"></label>
                                <input asp-for="PrimaryGuestFirstName" placeholder="First name" />
                                <span asp-validation-for="PrimaryGuestFirstName" class="text-danger"></span>
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="PrimaryGuestLastName"></label>
                                <input asp-for="PrimaryGuestLastName" placeholder="Last name" />
                                <span asp-validation-for="PrimaryGuestLastName" class="text-danger"></span>
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="PrimaryGuestPhone"></label>
                                <input asp-for="PrimaryGuestPhone" placeholder="+91 XXXXX XXXXX" />
                                <span asp-validation-for="PrimaryGuestPhone" class="text-danger"></span>
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="PrimaryGuestEmail"></label>
                                <input asp-for="PrimaryGuestEmail" placeholder="guest@company.com" />
                                <span asp-validation-for="PrimaryGuestEmail" class="text-danger"></span>
                            </div>
                            <div class="b2b-field f2">
                                <label asp-for="SpecialRequests"></label>
                                <textarea asp-for="SpecialRequests" placeholder="Company remarks, guest preferences, billing notes…"></textarea>
                                <span asp-validation-for="SpecialRequests" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="b2b-card">
                <div class="b2b-card-header">
                    <span class="hdr-icon teal"><i class="fas fa-bed"></i></span>
                    <div>
                        <h3>Stay Details</h3>
                        <p>Dates, room type, occupancy and GST context</p>
                    </div>
                </div>
                <div class="b2b-card-body">

                    <div class="b2b-section">
                        <div class="b2b-section-label">
                            <span>Source &amp; Channel</span>
                        </div>
                        <div class="b2b-fg">
                            <div class="b2b-field f1">
                                <label asp-for="Source"></label>
                                <select asp-for="Source" id="Source">
                                    @foreach (var source in sources)
                                    {
                                        <option value="@source">@source</option>
                                    }
                                </select>
                                <span asp-validation-for="Source" class="text-danger"></span>
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="Channel"></label>
                                <select asp-for="Channel">
                                    @foreach (var channel in channels)
                                    {
                                        <option value="@channel">@channel</option>
                                    }
                                </select>
                                <span asp-validation-for="Channel" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="b2b-section">
                        <div class="b2b-section-label">
                            <span>Default Stay Period</span>
                            <small>Set defaults — each room type can override below</small>
                        </div>
                        <div class="b2b-fg">
                            <div class="b2b-field f1">
                                <label asp-for="CheckInDate">Default Check-In</label>
                                <input asp-for="CheckInDate" type="date" id="CheckInDate" />
                                <span asp-validation-for="CheckInDate" class="text-danger"></span>
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="CheckOutDate">Default Check-Out</label>
                                <input asp-for="CheckOutDate" type="date" id="CheckOutDate" />
                                <span asp-validation-for="CheckOutDate" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Room Type Selection Grid (multi-select from agreement) -->
                        <div class="b2b-room-sel-wrap">
                            <div class="b2b-section-label" style="margin-bottom:8px;">
                                <span>Room Type Selection</span>
                                <small>Select one or multiple — per-type dates, occupancy &amp; meal plan</small>
                            </div>
                            <div id="roomSelPlaceholder" style="text-align:center;padding:18px 12px;color:#94a3b8;font-size:13px;border:1.5px dashed #e2e8f0;border-radius:10px;background:#fafbfc;">
                                <i class="fas fa-building" style="font-size:22px;margin-bottom:6px;display:block;opacity:.45;"></i>
                                Select a B2B client to load room types from the agreement
                            </div>
                            <div id="roomSelGrid" style="display:none;"></div>
                            <div id="roomLinesContainer"></div>
                            <p class="b2b-hint" style="margin-top:8px;">Set rooms &gt; 0 to include a type. Dates/occupancy default from above but can be overridden per type. Click <strong>Refresh Quote</strong> to confirm.</p>
                        </div>
                    </div>

                </div>
            </div>

            <div class="b2b-summary-col" style="display:flex; flex-direction:column; gap:14px;">

                <div class="b2b-quote">
                    <h4><i class="fas fa-receipt"></i> Quote Summary</h4>
                    <div id="quoteLineBreakdown" style="display:none; margin-bottom:8px;">
                        <div id="quoteLineTable" style="font-size:12px;"></div>
                        <div style="height:1px;background:rgba(255,255,255,.2);margin:8px 0;"></div>
                    </div>
                    <div class="b2b-quote-row">
                        <span>Base Amount</span>
                        <strong id="quotedBase">@(Model.QuotedBaseAmount?.ToString("N2") ?? "0.00")</strong>
                    </div>
                    <div class="b2b-quote-row">
                        <span>Tax (GST)</span>
                        <strong id="quotedTax">@(Model.QuotedTaxAmount?.ToString("N2") ?? "0.00")</strong>
                    </div>
                    <div class="b2b-quote-row">
                        <span>GST Slab</span>
                        <strong id="quotedGst" style="font-size:11px;text-align:right;max-width:180px;">@(string.IsNullOrWhiteSpace(Model.GstSlabName) ? "Pending" : Model.GstSlabName)</strong>
                    </div>
                    <div class="b2b-quote-row grand">
                        <span>Grand Total</span>
                        <strong id="quotedGrand">@(Model.QuotedGrandTotal?.ToString("N2") ?? "0.00")</strong>
                    </div>
                    <div id="availabilityBadge" style="display:none; margin-top:10px;"></div>
                    <p class="b2b-quote-note" id="quoteMessage">
                        @(string.IsNullOrWhiteSpace(Model.QuoteMessage)
                            ? "Select a client, dates, source, and room types — then click Refresh Quote."
                            : Model.QuoteMessage)
                    </p>
                </div>

                <div class="b2b-card">
                    <div class="b2b-card-header">
                        <span class="hdr-icon amber"><i class="fas fa-wallet"></i></span>
                        <div>
                            <h3>Advance Payment</h3>
                            <p>Optional — collect after booking creation</p>
                        </div>
                    </div>
                    <div class="b2b-card-body">
                        <div class="b2b-fg">
                            <label class="b2b-toggle-row">
                                <input asp-for="CollectAdvancePayment" type="checkbox" id="CollectAdvancePayment" />
                                <span>Collect advance now</span>
                            </label>
                            <p id="advancePaymentHint" style="margin:6px 0 0 28px; font-size:12px; color:#94a3b8; line-height:1.5;">
                                When checked, the payment modal will open automatically after booking creation — same as the standard booking flow.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="b2b-actions">
                    <button type="button" class="btn-b2b-secondary" id="refreshQuoteButton">
                        <i class="fas fa-rotate"></i> Refresh Quote &amp; Check Availability
                    </button>
                    <button type="submit" class="btn-b2b-primary" id="submitBtn">
                        <i class="fas fa-save"></i> Create B2B Booking
                    </button>
                    <a asp-action="Index" class="btn-b2b-secondary">
                        <i class="fas fa-arrow-left"></i> Back to B2B Dashboard
                    </a>
                </div>

            </div>

            <!-- ── GST & Billing (full-width row spanning columns 1-2) ── -->
            <div class="b2b-card b2b-billing-row">
                <div class="b2b-card-header">
                    <span class="hdr-icon amber"><i class="fas fa-file-invoice"></i></span>
                    <div>
                        <h3>GST &amp; Billing Details</h3>
                        <p>Tax context and billing snapshot auto-resolved from agreement</p>
                    </div>
                </div>
                <div class="b2b-card-body">

                    <div class="b2b-section">
                        <div class="b2b-section-label">
                            <span>GST &amp; Billing Context</span>
                            <small>Auto-resolved from quote</small>
                        </div>
                        <div class="b2b-fg">
                            <div class="b2b-field f1">
                                <label asp-for="GstSlabCode"></label>
                                <input asp-for="GstSlabCode" id="GstSlabCode" readonly placeholder="Pending quote" />
                                <input asp-for="GstSlabId" type="hidden" id="GstSlabId" />
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="BillingType"></label>
                                <input asp-for="BillingType" id="BillingType" readonly placeholder="From agreement" />
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="GstSlabName"></label>
                                <input asp-for="GstSlabName" id="GstSlabName" readonly placeholder="Pending quote" />
                            </div>
                        </div>
                    </div>

                    <div class="b2b-section">
                        <div class="b2b-section-label">
                            <span>Billing Snapshot</span>
                            <small>Agreement-linked</small>
                        </div>
                        <div class="b2b-fg">
                            <div class="b2b-field f1">
                                <label asp-for="BillingTo"></label>
                                <input asp-for="BillingTo" readonly />
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="CreditDays"></label>
                                <input asp-for="CreditDays" id="CreditDays" readonly />
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="CompanyGstNo"></label>
                                <input asp-for="CompanyGstNo" id="CompanyGstNo" readonly placeholder="Auto" />
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="CompanyCreditLimit"></label>
                                <input asp-for="CompanyCreditLimit" id="CompanyCreditLimit" readonly />
                            </div>
                            <div class="b2b-field f2">
                                <label asp-for="BillingAddress"></label>
                                <textarea asp-for="BillingAddress" id="BillingAddress" readonly placeholder="Auto-filled from client"></textarea>
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="BillingStateName"></label>
                                <input asp-for="BillingStateName" id="BillingStateName" readonly placeholder="Auto" />
                            </div>
                            <div class="b2b-field f1">
                                <label asp-for="BillingPincode"></label>
                                <input asp-for="BillingPincode" id="BillingPincode" readonly placeholder="Auto" />
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const clientSelect          = document.getElementById('ClientId');
            const sourceSelect          = document.getElementById('Source');
            const checkInInput          = document.getElementById('CheckInDate');
            const checkOutInput         = document.getElementById('CheckOutDate');
            const refreshQuoteButton    = document.getElementById('refreshQuoteButton');
            const collectAdvanceToggle  = document.getElementById('CollectAdvancePayment');

            let _roomTypes = [];

            function $el(id) { return document.getElementById(id); }

            function setValue(id, value) {
                const el = $el(id);
                if (el) el.value = value ?? '';
            }

            function setText(id, value) {
                const el = $el(id);
                if (el) el.textContent = value;
            }

            // ── Auto-refresh quote (debounced) ──────────────────────────────
            let _quoteTimer = null;
            function scheduleQuoteRefresh() {
                clearTimeout(_quoteTimer);
                _quoteTimer = setTimeout(function () {
                    const lines = getSelectedLines();
                    if (lines.length > 0 && checkInInput.value && checkOutInput.value) {
                        refreshQuote();
                    }
                }, 600);
            }

            // ── Advance Payment Toggle ────────────────────────────────────────
            function syncAdvanceFields() {
                const hint = $el('advancePaymentHint');
                if (hint) {
                    hint.style.display = collectAdvanceToggle.checked ? 'block' : 'none';
                }
            }

            // ── Room Selection Cards ──────────────────────────────────────────
            function populateRoomTypes(roomTypes) {
                _roomTypes = roomTypes || [];
                const placeholder = $el('roomSelPlaceholder');
                const grid        = $el('roomSelGrid');
                grid.innerHTML    = '';

                if (!_roomTypes.length) {
                    placeholder.style.display = '';
                    placeholder.innerHTML = '<i class="fas fa-info-circle" style="font-size:22px;margin-bottom:6px;display:block;opacity:.5;color:#f59e0b;"></i>No active room types found in this agreement. Check the Agreement Master.';
                    grid.style.display = 'none';
                    return;
                }

                placeholder.style.display = 'none';
                grid.style.display = '';

                const defIn  = checkInInput.value  || '';
                const defOut = checkOutInput.value || '';

                _roomTypes.forEach(function (rt) {
                    const safeId   = rt.id;
                    const safeName = (rt.name || '').replace(/"/g, '&quot;');
                    const rateStr  = Number(rt.ratePerNight || 0).toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2});
                    const season   = rt.season || '—';
                    const meal     = rt.mealPlan || '—';

                    const card = document.createElement('div');
                    card.className = 'room-card';
                    card.dataset.rtid = safeId;
                    card.innerHTML = `
                        <div class="room-card-hdr">
                            <span class="rt-name">${rt.name}</span>
                            <span class="rt-rate">₹${rateStr}</span>
                            <span class="rt-season">${season}</span>
                            <span class="rt-meal">${meal}</span>
                            <div class="room-qty-wrap">
                                <label>Rooms</label>
                                <input type="number" class="room-qty-input"
                                       data-rtid="${safeId}" data-rtname="${safeName}" data-rtmeal="${(rt.mealPlan||'').replace(/"/g,'&quot;')}"
                                       value="0" min="0" max="50" />
                            </div>
                        </div>
                        <div class="room-card-detail">
                            <div class="rc-field" style="min-width:130px;">
                                <label>Check-In</label>
                                <input type="date" class="rc-checkin" value="${defIn}" />
                            </div>
                            <div class="rc-field" style="min-width:130px;">
                                <label>Check-Out</label>
                                <input type="date" class="rc-checkout" value="${defOut}" />
                            </div>
                            <div class="rc-field" style="min-width:70px; max-width:80px;">
                                <label>Adults</label>
                                <input type="number" class="rc-adults" value="1" min="1" max="50" />
                            </div>
                            <div class="rc-field" style="min-width:70px; max-width:80px;">
                                <label>Children</label>
                                <input type="number" class="rc-children" value="0" min="0" max="20" />
                            </div>
                            <div class="rc-field" style="min-width:80px; max-width:100px;">
                                <label>Meal Plan</label>
                                <input type="text" class="rc-mealplan" value="${meal}" readonly />
                            </div>
                        </div>`;
                    grid.appendChild(card);
                });

                // Toggle detail row visibility when qty changes + auto-refresh
                grid.querySelectorAll('.room-qty-input').forEach(function (inp) {
                    inp.addEventListener('input', function () {
                        const v    = parseInt(this.value, 10) || 0;
                        const card = this.closest('.room-card');
                        card.classList.toggle('rc-active', v > 0);
                        scheduleQuoteRefresh();
                    });
                });

                // Auto-refresh when per-line dates change
                grid.querySelectorAll('.rc-checkin, .rc-checkout').forEach(function (inp) {
                    inp.addEventListener('change', scheduleQuoteRefresh);
                });

                // Sync default dates when global date fields change
                function syncDefaultDates() {
                    grid.querySelectorAll('.room-card:not(.rc-active)').forEach(function (card) {
                        const ci = card.querySelector('.rc-checkin');
                        const co = card.querySelector('.rc-checkout');
                        if (ci) ci.value = checkInInput.value || '';
                        if (co) co.value = checkOutInput.value || '';
                    });
                }
                checkInInput.removeEventListener('change', syncDefaultDates);
                checkOutInput.removeEventListener('change', syncDefaultDates);
                checkInInput.addEventListener('change', syncDefaultDates);
                checkOutInput.addEventListener('change', syncDefaultDates);
            }

            function getSelectedLines() {
                const lines = [];
                document.querySelectorAll('#roomSelGrid .room-card').forEach(function (card) {
                    const qtyInp = card.querySelector('.room-qty-input');
                    const rooms  = parseInt(qtyInp?.value, 10) || 0;
                    if (rooms > 0) {
                        lines.push({
                            roomTypeId:   parseInt(qtyInp.dataset.rtid, 10),
                            roomTypeName: qtyInp.dataset.rtname || '',
                            requiredRooms: rooms,
                            checkInDate:  card.querySelector('.rc-checkin')?.value  || checkInInput.value  || '',
                            checkOutDate: card.querySelector('.rc-checkout')?.value || checkOutInput.value || '',
                            adults:       parseInt(card.querySelector('.rc-adults')?.value, 10) || 1,
                            children:     parseInt(card.querySelector('.rc-children')?.value, 10) || 0,
                            mealPlan:     card.querySelector('.rc-mealplan')?.value || qtyInp.dataset.rtmeal || ''
                        });
                    }
                });
                return lines;
            }

            function syncRoomLinesToHiddenInputs(lines) {
                const container = $el('roomLinesContainer');
                if (!container) return;
                container.innerHTML = '';
                (lines || []).forEach(function (line, i) {
                    const esc = (s) => (s || '').replace(/"/g, '&quot;');
                    container.insertAdjacentHTML('beforeend',
                        `<input type="hidden" name="RoomLines[${i}].RoomTypeId" value="${line.roomTypeId}" />`
                        + `<input type="hidden" name="RoomLines[${i}].RoomTypeName" value="${esc(line.roomTypeName)}" />`
                        + `<input type="hidden" name="RoomLines[${i}].RequiredRooms" value="${line.requiredRooms}" />`
                        + `<input type="hidden" name="RoomLines[${i}].CheckInDate" value="${line.checkInDate}" />`
                        + `<input type="hidden" name="RoomLines[${i}].CheckOutDate" value="${line.checkOutDate}" />`
                        + `<input type="hidden" name="RoomLines[${i}].Adults" value="${line.adults}" />`
                        + `<input type="hidden" name="RoomLines[${i}].Children" value="${line.children}" />`
                        + `<input type="hidden" name="RoomLines[${i}].MealPlan" value="${esc(line.mealPlan)}" />`
                    );
                });
            }

            // ── Agreement meta ────────────────────────────────────────────────
            function populateAgreementMeta(agreement) {
                setValue('AgreementId', agreement ? agreement.id : '');
                setValue('AgreementCode', agreement ? agreement.code : '');
                setValue('AgreementName', agreement ? agreement.name : '');
                setValue('BillingType', agreement ? agreement.billingType : '');
                setValue('CreditDays', agreement ? agreement.creditDays : '');
                setValue('MealPlan', agreement ? (agreement.mealPlan || '') : '');
                setValue('AgreementDisplay', agreement ? `${agreement.name} (${agreement.code})` : '');
            }

            // ── Load Client Context ───────────────────────────────────────────
            async function loadClientContext() {
                const clientId = clientSelect.value;
                populateAgreementMeta(null);
                if (!clientId) {
                    ['ClientCode','ClientName','CompanyContactPerson','CompanyContactNo','CompanyEmail',
                     'CompanyGstNo','BillingAddress','BillingStateName','BillingPincode','CompanyCreditLimit',
                     'GstSlabId','GstSlabCode','GstSlabName'].forEach(id => setValue(id, ''));
                    populateRoomTypes([]);
                    const ph = $el('roomSelPlaceholder');
                    if (ph) { ph.style.display = ''; ph.innerHTML = '<i class="fas fa-building" style="font-size:22px;margin-bottom:6px;display:block;opacity:.45;"></i>Select a B2B client to load room types from the agreement'; }
                    setText('quoteMessage', 'Select a client with an assigned agreement, then choose stay dates and room types to refresh the quote.');
                    return;
                }

                try {
                    const res  = await fetch(`@Url.Action("GetClientContext", "B2BBooking")?clientId=${encodeURIComponent(clientId)}`);
                    const data = await res.json();
                    if (!data.success) return;

                    setValue('ClientCode',           data.client.code           || '');
                    setValue('ClientName',            data.client.name           || '');
                    setValue('CompanyContactPerson',  data.client.contactPerson  || '');
                    setValue('CompanyContactNo',      data.client.contactNo      || '');
                    setValue('CompanyEmail',          data.client.corporateEmail || '');
                    setValue('CompanyGstNo',          data.client.gstNo          || '');
                    setValue('BillingAddress',        data.client.address        || '');
                    setValue('BillingStateName',      data.client.stateName      || '');
                    setValue('BillingPincode',        data.client.pincode        || '');
                    setValue('CompanyCreditLimit',    data.client.creditAmount   || '0.00');

                    populateAgreementMeta(data.agreement || null);
                    populateRoomTypes(data.roomTypes || []);

                    if (!data.agreement) {
                        setText('quoteMessage', data.message || 'No active agreement is assigned to this client. Update B2B Client Master first.');
                    }
                } catch (err) {
                    console.error('loadClientContext error:', err);
                }
            }

            // ── Refresh Quote (multi-room POST) ───────────────────────────────
            async function refreshQuote() {
                const checkInDate  = checkInInput.value;
                const checkOutDate = checkOutInput.value;
                const agreementId  = $el('AgreementId')?.value;
                const lines        = getSelectedLines();

                if (!checkInDate || !checkOutDate) {
                    setText('quoteMessage', 'Please enter check-in and check-out dates before refreshing the quote.');
                    return;
                }
                if (lines.length === 0) {
                    setText('quoteMessage', 'Please enter rooms (> 0) for at least one room type before refreshing the quote.');
                    return;
                }
                if (!agreementId) {
                    setText('quoteMessage', 'No agreement found for the selected client. Cannot compute quote.');
                    return;
                }

                let data;
                try {
                    const res = await fetch('@Url.Action("GetQuote", "B2BBooking")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            agreementId:  parseInt(agreementId, 10),
                            checkInDate,
                            checkOutDate,
                            lines: lines.map(l => ({
                                roomTypeId: l.roomTypeId,
                                requiredRooms: l.requiredRooms,
                                checkInDate: l.checkInDate || null,
                                checkOutDate: l.checkOutDate || null
                            }))
                        })
                    });
                    data = await res.json();
                } catch (err) {
                    console.error('refreshQuote error:', err);
                    setText('quoteMessage', 'Network error occurred while fetching quote.');
                    return;
                }

                const availBadge = $el('availabilityBadge');
                const submitBtn  = $el('submitBtn');
                const breakdown  = $el('quoteLineBreakdown');
                const lineTable  = $el('quoteLineTable');

                if (!data.success) {
                    setText('quoteMessage', data.message || 'Unable to compute quote. Check agreement room rates.');
                    setText('quotedBase', '0.00'); setText('quotedTax', '0.00'); setText('quotedGrand', '0.00');
                    setText('quotedGst', 'Pending');
                    setValue('GstSlabId', ''); setValue('GstSlabCode', ''); setValue('GstSlabName', '');
                    if (availBadge) availBadge.style.display = 'none';
                    if (breakdown)  breakdown.style.display  = 'none';
                    return;
                }

                // ── Per-line breakdown in quote panel ────────────────────────
                if (data.lines && data.lines.length > 0) {
                    let html = '';
                    data.lines.forEach(function (ln) {
                        const avail = ln.available
                            ? '<span style="color:#86efac;font-size:10px;margin-left:4px;">✓</span>'
                            : '<span style="color:#fca5a5;font-size:10px;margin-left:4px;">✗ Unavailable</span>';
                        const dateRange = (ln.checkInDate && ln.checkOutDate)
                            ? `<span style="font-size:10px;opacity:.7;margin-left:6px;">${ln.checkInDate} → ${ln.checkOutDate}</span>`
                            : '';
                        html += `<div class="quote-line-entry"><span>${ln.roomTypeName} × ${ln.requiredRooms}${avail}${dateRange}</span><span>₹${Number(ln.grandTotal||0).toFixed(2)}</span></div>`;
                    });
                    lineTable.innerHTML = html;
                    breakdown.style.display = '';
                } else {
                    if (breakdown) breakdown.style.display = 'none';
                }

                // ── Grand totals ─────────────────────────────────────────────
                const t = data.totals || {};
                setText('quotedBase',  Number(t.baseAmount || 0).toFixed(2));
                setText('quotedTax',   Number(t.taxAmount  || 0).toFixed(2));
                setText('quotedGrand', Number(t.grandTotal || 0).toFixed(2));

                const slabLabel = (data.lines && data.lines[0] && data.lines[0].gstSlabName) || 'No active slab';
                setText('quotedGst', slabLabel);
                setValue('GstSlabId', ''); setValue('GstSlabCode', ''); setValue('GstSlabName', slabLabel);

                // ── Availability badge ────────────────────────────────────────
                if (availBadge) {
                    availBadge.style.display = 'block';
                    if (data.roomsAvailable) {
                        availBadge.innerHTML = `<span style="display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border-radius:6px;background:rgba(20,184,166,.2);color:#ccfbf1;font-size:12px;font-weight:600;"><i class="fas fa-check-circle"></i> ${data.availabilityMessage}</span>`;
                        if (submitBtn) submitBtn.disabled = false;
                    } else {
                        availBadge.innerHTML = `<span style="display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border-radius:6px;background:rgba(239,68,68,.2);color:#fecaca;font-size:12px;font-weight:600;"><i class="fas fa-times-circle"></i> ${data.availabilityMessage}</span>`;
                        if (submitBtn) submitBtn.disabled = true;
                    }
                }

                // Sync hidden inputs for form submission
                syncRoomLinesToHiddenInputs(lines);

                const totalRooms = lines.reduce(function(a,b){return a+b.requiredRooms;}, 0);
                setText('quoteMessage', `Quote for ${t.nights || 0} night(s) — ${lines.length} room type(s), ${totalRooms} room(s) total.`);
            }

            // ── Form submit guard ─────────────────────────────────────────────
            const form = document.getElementById('b2bBookingForm');
            if (form) {
                form.addEventListener('submit', function (e) {
                    const lines = getSelectedLines();
                    if (lines.length === 0) {
                        e.preventDefault();
                        setText('quoteMessage', 'Please select at least one room type with rooms > 0 before submitting.');
                        $el('roomSelGrid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        return;
                    }
                    syncRoomLinesToHiddenInputs(lines);
                });
            }

            // ── Wire events ───────────────────────────────────────────────────
            clientSelect.addEventListener('change', loadClientContext);
            refreshQuoteButton.addEventListener('click', refreshQuote);
            checkInInput.addEventListener('change', scheduleQuoteRefresh);
            checkOutInput.addEventListener('change', scheduleQuoteRefresh);
            collectAdvanceToggle.addEventListener('change', syncAdvanceFields);
            syncAdvanceFields();

            if (clientSelect.value) { loadClientContext(); }
        })();
    </script>
}