@model IEnumerable<HotelApp.Web.Models.B2BClient>
@{
    ViewData["Title"] = "B2B Client Master";
    var rows = Model?.ToList() ?? new List<HotelApp.Web.Models.B2BClient>();
    var activeCount = rows.Count(x => x.IsActive);
    var blacklistedCount = rows.Count(x => x.Blacklisted);
    var mappedAgreements = rows.Count(x => x.AgreementId.HasValue);
}

<style>
    .company-index-surface { max-width: 1480px; margin: 0 auto; padding: 20px 24px; }
    .company-index-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 18px; margin-bottom: 18px; }
    .company-index-header h2 { margin: 8px 0 0; }
    .company-index-kicker { display: inline-flex; align-items: center; gap: 8px; padding: 6px 11px; border-radius: 999px; background: #eff6ff; color: #1d4ed8; font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
    .company-index-header p { margin: 6px 0 0; color: #64748b; max-width: 760px; }
    .company-index-stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin-bottom: 18px; }
    .company-index-stat { background: #fff; border: 1px solid rgba(15, 23, 42, .08); border-radius: 18px; box-shadow: 0 14px 34px rgba(15, 23, 42, .06); padding: 18px 20px; }
    .company-index-stat strong { display: block; font-size: .78rem; text-transform: uppercase; letter-spacing: .05em; color: #64748b; margin-bottom: 8px; }
    .company-index-stat .value { font-size: 1.5rem; font-weight: 800; color: #0f172a; line-height: 1; }
    .company-index-stat .note { margin-top: 8px; color: #475569; font-size: .84rem; }
    .company-index-table-shell { background: #fff; border: 1px solid rgba(15, 23, 42, .08); border-radius: 20px; box-shadow: 0 14px 34px rgba(15, 23, 42, .06); overflow: hidden; }
    .company-index-toolbar { display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 18px 20px; border-bottom: 1px solid #e2e8f0; background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); }
    .company-index-toolbar h3 { margin: 0; font-size: 1rem; color: #0f172a; }
    .company-index-toolbar p { margin: 4px 0 0; color: #64748b; font-size: .84rem; }
    .company-index-toolbar .company-pill { display: inline-flex; align-items: center; gap: 8px; padding: 7px 12px; border-radius: 999px; background: #eff6ff; color: #1d4ed8; font-size: .82rem; font-weight: 600; }
    .company-index-table-wrap { overflow-x: auto; }
    .company-index-table { width: 100%; border-collapse: separate; border-spacing: 0; min-width: 1220px; }
    .company-index-table th { padding: 12px 14px; background: #f8fafc; border-bottom: 1px solid #dbe4ee; color: #334155; font-size: .76rem; text-transform: uppercase; letter-spacing: .04em; }
    .company-index-table td { padding: 14px; border-bottom: 1px solid #e2e8f0; vertical-align: top; color: #0f172a; }
    .company-index-table tr:last-child td { border-bottom: none; }
    .company-list-title { display: grid; gap: 4px; }
    .company-list-title strong { font-size: .96rem; }
    .company-list-subtext { color: #64748b; font-size: .83rem; line-height: 1.45; }
    .company-metric { display: grid; gap: 4px; }
    .company-metric strong { font-size: .92rem; color: #0f172a; }
    .company-metric span { color: #64748b; font-size: .82rem; }
    @@media (max-width: 900px) {
        .company-index-surface { padding: 14px 16px; }
        .company-index-header { flex-direction: column; align-items: stretch; }
        .company-index-stats { grid-template-columns: 1fr; }
        .company-index-toolbar { flex-direction: column; align-items: stretch; }
    }
</style>

<div class="company-index-surface">
    <div class="company-index-header">
        <div>
            <div class="company-index-kicker"><i class="fas fa-building-circle-check"></i> Account control register</div>
            <h2><i class="fas fa-building-user"></i> B2B Client Master</h2>
            <p>Monitor corporate accounts with clearer agreement assignment visibility, cleaner billing summaries, and faster operational review.</p>
        </div>
        <a asp-action="Create" class="btn-create">
            <i class="fas fa-plus"></i> Add Company Master
        </a>
    </div>

    <div class="company-index-stats">
        <div class="company-index-stat">
            <strong>Total Accounts</strong>
            <div class="value">@rows.Count</div>
            <div class="note">Corporate, travel-agent, and OTA clients managed here.</div>
        </div>
        <div class="company-index-stat">
            <strong>Active Accounts</strong>
            <div class="value">@activeCount</div>
            <div class="note">Blacklisted accounts: @blacklistedCount</div>
        </div>
        <div class="company-index-stat">
            <strong>Agreement Tagged</strong>
            <div class="value">@mappedAgreements</div>
            <div class="note">Accounts ready for agreement-driven booking rules.</div>
        </div>
    </div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
}

@if (rows.Any())
{
    <div class="company-index-table-shell">
        <div class="company-index-toolbar">
            <div>
                <h3>Client Register</h3>
                <p>Compact account view for agreement tagging, contact readiness, tax identity, and credit posture.</p>
            </div>
            <span class="company-pill"><i class="fas fa-link"></i> Agreement selection lives on the client master</span>
        </div>
        <div class="company-index-table-wrap">
        <table class="company-index-table">
            <thead>
                <tr>
                    <th>Company</th>
                    <th>Agreement</th>
                    <th>Type</th>
                    <th>Primary Contact</th>
                    <th>Billing</th>
                    <th>Credit Control</th>
                    <th>GST / PAN</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in rows)
                {
                    <tr>
                        <td>
                            <div class="company-list-title">
                                <strong>@row.ClientName</strong>
                                <span class="company-list-subtext">@row.ClientCode | @row.DisplayName</span>
                            </div>
                        </td>
                        <td>
                            <div class="company-metric">
                                <strong>@(string.IsNullOrWhiteSpace(row.AgreementName) ? "Not assigned" : row.AgreementName)</strong>
                                <span>@(string.IsNullOrWhiteSpace(row.AgreementCode) ? "Assign from Agreement Master" : row.AgreementCode)</span>
                            </div>
                        </td>
                        <td>@row.CompanyType</td>
                        <td>
                            <div class="company-metric">
                                <strong>@row.ContactPerson</strong>
                                <span>@row.ContactNo</span>
                                <span>@row.CorporateEmail</span>
                            </div>
                        </td>
                        <td>
                            <div class="company-metric">
                                <strong>@row.BillingType / @row.BillingCycle</strong>
                                <span>@row.StateName</span>
                            </div>
                        </td>
                        <td>
                            <div class="company-metric">
                                <strong>Limit: @((row.CreditAmount ?? 0).ToString("N2"))</strong>
                                <span>Outstanding: @row.OutstandingAmount.ToString("N2")</span>
                            </div>
                        </td>
                        <td>
                            <div class="company-metric">
                                <strong>@row.GstNo</strong>
                                <span>PAN: @row.Pan</span>
                            </div>
                        </td>
                        <td>
                            @if (row.IsActive)
                            {
                                <span class="badge badge-available">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-maintenance">Inactive</span>
                            }

                            @if (row.Blacklisted)
                            {
                                <div style="margin-top:6px;"><span class="badge badge-maintenance">Blacklisted</span></div>
                            }
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a asp-action="Details" asp-route-id="@row.Id" class="btn-action btn-view"><i class="fas fa-eye"></i><span>View</span></a>
                                <a asp-action="Edit" asp-route-id="@row.Id" class="btn-action btn-edit"><i class="fas fa-pen"></i><span>Edit</span></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
}
else
{
    <div class="empty-state">
        <i class="fas fa-building-user"></i>
        <h3>No Company Masters Found</h3>
        <p>Create the first company master to start corporate, travel-agent, and OTA account setup.</p>
        <a asp-action="Create" class="btn-create"><i class="fas fa-plus"></i> Add Company Master</a>
    </div>
}
</div>