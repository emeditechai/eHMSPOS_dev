@model HotelApp.Web.Models.B2BClient
@using HotelApp.Web.Models
@{
    var isReadOnly = ViewBag.IsReadOnly == true;
    ViewData["Title"] = isReadOnly ? "View B2B Client" : "Edit B2B Client";
}

<div class="company-page-surface">
    <div class="company-page-header">
        <div>
            <div class="company-mode-badge"><i class="fas @(isReadOnly ? "fa-eye" : "fa-pen")"></i> @(isReadOnly ? "View" : "Edit")</div>
            <h2><i class="fas fa-building-user"></i> B2B Client Master</h2>
            <p class="text-muted mb-0">@((isReadOnly ? "Review" : "Update") + " company identity, agreement allocation, billing discipline, and compliance settings from one compact page.")</p>
        </div>
        <a asp-action="Index" class="btn-cancel"><i class="fas fa-arrow-left"></i> Back to Company List</a>
    </div>

    <form asp-action="Edit" method="post" class="company-shell">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        @await Html.PartialAsync("_ClientFormFields", Model)
        <div class="company-actions">
            <a asp-action="Index" class="btn-cancel"><i class="fas fa-arrow-left"></i> Back</a>
            @if (!isReadOnly)
            {
                <button type="submit" class="btn-save"><i class="fas fa-save"></i> Save Changes</button>
            }
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const billingType = document.getElementById('BillingType');
            const creditAmount = document.getElementById('CreditAmount');
            const creditDays = document.getElementById('CreditDays');
            const allowExceedLimit = document.getElementById('AllowExceedLimit');
            const tdsApplicable = document.getElementById('TdsApplicable');
            const tdsPercentage = document.getElementById('TdsPercentage');
            const stateSelect = document.getElementById('StateId');
            const citySelect = document.getElementById('City');
            const stateCode = document.getElementById('StateCode');
            const placeOfSupply = document.getElementById('PlaceOfSupplyStateId');

            async function loadCities(stateId) {
                if (!citySelect) {
                    return;
                }

                const selectedCity = citySelect.value;
                citySelect.innerHTML = '<option value="">Select city</option>';

                if (!stateId) {
                    return;
                }

                const response = await fetch(`@Url.Action("GetCities", "B2BClientMaster")?stateId=${encodeURIComponent(stateId)}`);
                const data = await response.json();
                if (!data.success) {
                    return;
                }

                for (const city of data.cities) {
                    const option = document.createElement('option');
                    option.value = city.name;
                    option.textContent = city.name;
                    if (city.name === selectedCity) {
                        option.selected = true;
                    }
                    citySelect.appendChild(option);
                }
            }

            function syncCreditControls() {
                const creditMode = billingType && billingType.value === 'Credit';
                if (creditAmount && !creditAmount.hasAttribute('readonly')) {
                    creditAmount.disabled = !creditMode;
                    if (!creditMode) {
                        creditAmount.value = '';
                    }
                }

                if (creditDays && !creditDays.hasAttribute('readonly')) {
                    creditDays.disabled = !creditMode;
                    if (!creditMode) {
                        creditDays.value = '0';
                    }
                }

                if (allowExceedLimit && !allowExceedLimit.disabled) {
                    allowExceedLimit.disabled = !creditMode;
                    if (!creditMode) {
                        allowExceedLimit.checked = false;
                    }
                }
            }

            function syncTdsControls() {
                const enabled = tdsApplicable && tdsApplicable.checked;
                if (tdsPercentage && !tdsPercentage.hasAttribute('readonly')) {
                    tdsPercentage.disabled = !enabled;
                    if (!enabled) {
                        tdsPercentage.value = '';
                    }
                }
            }

            function syncStateMeta() {
                if (!stateSelect || !stateCode) {
                    return;
                }

                const selected = stateSelect.options[stateSelect.selectedIndex];
                stateCode.value = selected ? (selected.dataset.code || '') : '';

                if (placeOfSupply && !placeOfSupply.value) {
                    placeOfSupply.value = stateSelect.value;
                }
            }

            billingType?.addEventListener('change', syncCreditControls);
            tdsApplicable?.addEventListener('change', syncTdsControls);
            stateSelect?.addEventListener('change', async function () {
                syncStateMeta();
                await loadCities(stateSelect.value);
            });

            syncCreditControls();
            syncTdsControls();
            syncStateMeta();
            if (stateSelect?.value) {
                loadCities(stateSelect.value);
            }
        })();
    </script>
}