@model HotelApp.Web.ViewModels.AssetDashboardViewModel
@{
    ViewData["Title"] = "Asset Management";
}

@section Styles {
    <link rel="stylesheet" href="~/css/asset-dashboard.css" asp-append-version="true" />
}


<div class="asset-hero">
    <div class="asset-hero-title">
        <h1><i class="fas fa-boxes-stacked"></i> Asset Management</h1>
        <div class="asset-hero-subtitle">Track inventory, movements, and asset health across your property</div>
    </div>
    <div class="asset-hero-badge">
        <i class="fas fa-calendar-range"></i>
        @Model.FromDate.ToString("dd MMM yyyy") &nbsp;—&nbsp; @Model.ToDate.ToString("dd MMM yyyy")
    </div>
</div>


<div class="asset-filter-card">
    <form method="get" action="@Url.Action("Index", "AssetManagement")">
        <div class="asset-filter-inner">
            <div class="asset-filter-fields">
                <div class="asset-filter-group">
                    <label class="asset-filter-label">From Date</label>
                    <input class="asset-filter-input" type="date" name="fromDate" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="asset-filter-group">
                    <label class="asset-filter-label">To Date</label>
                    <input class="asset-filter-input" type="date" name="toDate" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="asset-filter-actions">
                    <button class="asset-btn-apply" type="submit">
                        <i class="fas fa-filter"></i> Apply
                    </button>
                    <a class="asset-btn-reset" href="@Url.Action("Index", "AssetManagement")">
                        <i class="fas fa-rotate-left"></i> Reset
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>


<div class="asset-kpi-grid">
    <div class="asset-kpi-card asset-kpi-green">
        <i class="fas fa-right-left asset-kpi-icon"></i>
        <div class="asset-kpi-label">Movements</div>
        <div class="asset-kpi-value">@Model.Summary.MovementsCount</div>
    </div>

    <div class="asset-kpi-card asset-kpi-blue">
        <i class="fas fa-arrow-down asset-kpi-icon"></i>
        <div class="asset-kpi-label">Total IN Qty</div>
        <div class="asset-kpi-value">@Model.Summary.TotalInQty.ToString("0.##")</div>
    </div>

    <div class="asset-kpi-card asset-kpi-purple">
        <i class="fas fa-arrow-up asset-kpi-icon"></i>
        <div class="asset-kpi-label">Total OUT Qty</div>
        <div class="asset-kpi-value">@Model.Summary.TotalOutQty.ToString("0.##")</div>
    </div>

    <div class="asset-kpi-card asset-kpi-red">
        <i class="fas fa-triangle-exclamation asset-kpi-icon"></i>
        <div class="asset-kpi-label">Damage / Loss (Range)</div>
        <div class="asset-kpi-value">@Model.Summary.DamageLossCount</div>
    </div>

    <div class="asset-kpi-card asset-kpi-orange">
        <i class="fas fa-hourglass-half asset-kpi-icon"></i>
        <div class="asset-kpi-label">Pending Damage / Loss</div>
        <div class="asset-kpi-value">@Model.Summary.DamageLossPendingCount</div>
    </div>

    <div class="asset-kpi-card asset-kpi-teal">
        <i class="fas fa-rotate asset-kpi-icon"></i>
        <div class="asset-kpi-label">Recoveries (Range)</div>
        <div class="asset-kpi-value">@Model.Summary.RecoveriesCount</div>
    </div>

    <div class="asset-kpi-card asset-kpi-green">
        <i class="fas fa-indian-rupee-sign asset-kpi-icon"></i>
        <div class="asset-kpi-label">Recovery Amount</div>
        <div class="asset-kpi-value">₹@Model.Summary.RecoveryAmount.ToString("N0")</div>
    </div>

    <div class="asset-kpi-card asset-kpi-indigo">
        <i class="fas fa-box-open asset-kpi-icon"></i>
        <div class="asset-kpi-label">Low Stock Items</div>
        <div class="asset-kpi-value">@Model.Summary.LowStockItemsCount</div>
    </div>
</div>


<div class="asset-quick-card">
    <div class="asset-quick-info">
        <div class="asset-quick-title"><i class="fas fa-bolt" style="color:#f59e0b;"></i> Quick Actions</div>
        <div class="asset-quick-sub">Jump directly to a key section</div>
    </div>
    <div class="asset-quick-links">
        <a class="asset-quick-btn items" href="@Url.Action("Items", "AssetManagement")">
            <i class="fas fa-box"></i> Item Master
        </a>
        <a class="asset-quick-btn movement" href="@Url.Action("CreateMovement", "AssetManagement")">
            <i class="fas fa-right-left"></i> Stock Movement
        </a>
        <a class="asset-quick-btn report" href="@Url.Action("StockReport", "AssetManagement")">
            <i class="fas fa-chart-column"></i> Stock Report
        </a>
        <a class="asset-quick-btn damage" href="@Url.Action("DamageLoss", "AssetManagement")">
            <i class="fas fa-triangle-exclamation"></i> Damage / Loss
        </a>
    </div>
</div>


<div class="asset-tables-grid">

    
    <div class="asset-table-card">
        <div class="asset-table-header">
            <div class="asset-table-header-title">
                <i class="fas fa-box-open" style="color:#e65100;"></i> Low Stock (Current)
            </div>
            <div class="asset-table-header-sub">Top 10 items below minimum threshold</div>
        </div>
        @if (Model.LowStockItems.Any())
        {
            <table class="asset-data-table">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th class="th-right">On Hand</th>
                        <th class="th-right">Threshold</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.LowStockItems)
                {
                    <tr>
                        <td>
                            <span class="item-name">@row.Name</span>
                            <span class="item-code">(@row.Code)</span>
                        </td>
                        <td class="td-right">
                            <span class="qty-badge low">@row.OnHandQty.ToString("0.##")</span>
                        </td>
                        <td class="td-right">
                            <span class="qty-badge thresh">@(row.ThresholdQty?.ToString("0.##") ?? "—")</span>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else
        {
            <div class="asset-empty">
                <i class="fas fa-circle-check"></i>
                All items are above threshold
            </div>
        }
    </div>

    
    <div class="asset-table-card">
        <div class="asset-table-header">
            <div class="asset-table-header-title">
                <i class="fas fa-clock-rotate-left" style="color:#1565c0;"></i> Recent Movements
            </div>
            <div class="asset-table-header-sub">Latest 10 movements in selected range</div>
        </div>
        @if (Model.RecentMovements.Any())
        {
            <table class="asset-data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Reference</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.RecentMovements)
                {
                    <tr>
                        <td style="white-space:nowrap;">@row.MovementDate.ToString("dd MMM yyyy")</td>
                        <td><span class="qty-badge move">@row.MovementType</span></td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(row.BookingNumber))
                            {
                                <span style="font-size:.72rem;color:#94a3b8;">Booking</span>
                                <span class="qty-badge ref">@row.BookingNumber</span>
                            }
                            else if (!string.IsNullOrWhiteSpace(row.ToDepartment))
                            {
                                <span style="font-size:.72rem;color:#94a3b8;">Dept</span>
                                <span>@row.ToDepartment</span>
                            }
                            else
                            {
                                <span style="color:#cbd5e1;">—</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else
        {
            <div class="asset-empty">
                <i class="fas fa-inbox"></i>
                No movements found in the selected range
            </div>
        }
    </div>
</div>


@if (Model.NegativeStockItems.Any())
{
    <div class="asset-alert-card">
        <div class="asset-alert-header">
            <div class="asset-alert-title">
                <i class="fas fa-circle-exclamation"></i> Negative Stock — Attention Required
            </div>
            <span class="asset-alert-count">@Model.Summary.NegativeStockItemsCount item(s)</span>
        </div>
        <table class="asset-data-table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th class="th-right">On Hand Qty</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.NegativeStockItems)
            {
                <tr>
                    <td>
                        <span class="item-name">@row.Name</span>
                        <span class="item-code">(@row.Code)</span>
                    </td>
                    <td class="td-right">
                        <span class="qty-badge neg">@row.OnHandQty.ToString("0.##")</span>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
