@model HotelApp.Web.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>eLUX Stay | Property Management</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
</head>
<body>
    <!-- Background slideshow (max 3 images, shuffles every 3 s) -->
    <div class="bg-slideshow" id="bgSlideshow">
        <div class="bg-slide active" style="background-image: url('/images/login-bg1.png');"></div>
        <div class="bg-slide" style="background-image: url('/images/login-bg2.png');"></div>
        <div class="bg-slide" style="background-image: url('/images/login-bg3.png');"></div>
    </div>

    <div class="container">
        <div class="welcome-section">
            <h1>eLUX Stay</h1>
            <p>Property Management System for hotel staff and operations teams. Sign in to manage your property.</p>
            <ul class="features">
                <li><i class="fas fa-check-circle"></i> Room &amp; Booking Control</li>
                <li><i class="fas fa-check-circle"></i> B2B &amp; Corporate Billing</li>
                <li><i class="fas fa-check-circle"></i> GST &amp; Financial Reports</li>
                <li><i class="fas fa-check-circle"></i> Asset &amp; Inventory Management</li>
            </ul>
        </div>
        
        <div class="login-section">
            <div class="logo">
                <h2>eLUX <span>Stay</span></h2>
            </div>
            
            <div class="login-form">
                <h3>Staff Login</h3>
                
                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnUrl" />
                    
                    @if (TempData["SessionMessage"] is string sessionMsg && !string.IsNullOrWhiteSpace(sessionMsg))
                    {
                        <div id="sessionMsgBanner" data-msg="@sessionMsg" style="display:none"></div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" role="alert">
                            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@err.ErrorMessage</div>
                            }
                        </div>
                    }
                    
                    <div class="form-group">
                        <label asp-for="Username">User Name</label>
                        <div class="input-with-icon">
                            <i class="fas fa-user"></i>
                            <input asp-for="Username" type="text" placeholder="Enter your user name" required autocomplete="username">
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label asp-for="Password">Password</label>
                        <div class="input-with-icon has-right-icon">
                            <i class="fas fa-lock"></i>
                            <input asp-for="Password" id="password" type="password" placeholder="Enter your password" required autocomplete="current-password">
                            <button type="button" class="toggle-password" aria-label="Show password" aria-pressed="false">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="options">
                        <div class="remember-me">
                            <input type="checkbox" id="remember">
                            <label for="remember">Remember me</label>
                        </div>
                        <a href="#" class="forgot-password" id="forgotPasswordLink">Forgot Password?</a>
                    </div>
                    <div style="font-size:0.72rem; color:rgba(255,255,255,0.9); margin-top:-6px; margin-bottom:4px; text-shadow:0 1px 4px rgba(0,0,0,0.6);">
                        <i class="fas fa-triangle-exclamation" style="color:#fdbb2d; font-size:0.65rem;"></i>
                        Not recommended on shared terminals.
                    </div>
                    
                    <button type="submit" class="login-btn">Sign In</button>
                </form>

                <div style="text-align:center; margin-top:16px; border-top:1px solid rgba(255,255,255,0.25); padding-top:12px;">
                    <a href="#" id="licRevalidateLink"
                       style="font-size:.75rem; color:rgba(255,255,255,0.85); text-decoration:none; text-shadow:0 1px 4px rgba(0,0,0,0.6); font-weight:500;"
                       title="Force re-validation against the central license server">
                        <i class="fas fa-rotate-right" style="font-size:.68rem;"></i>&nbsp;Re-validate License
                    </a>
                    <div style="font-size:0.68rem; color:rgba(255,255,255,0.75); margin-top:8px; text-shadow:0 1px 4px rgba(0,0,0,0.6);">
                        eLUX Stay HMS &nbsp;&middot;&nbsp; v2.0 &nbsp;&middot;&nbsp; &copy; Emeditech Plus LLP
                    </div>
                </div>
                
            </div>
        </div>
    </div>

    <!-- Background slideshow script -->
    <script>
        (function () {
            var slides = document.querySelectorAll('#bgSlideshow .bg-slide');
            if (!slides.length) return;
            var current = 0;
            setInterval(function () {
                var prev = current;
                current = (current + 1) % slides.length;

                // Slide current out to the left
                slides[prev].classList.add('exit');
                slides[prev].classList.remove('active');

                // Slide next in from the right
                slides[current].classList.add('active');

                // After transition, reset the exited slide back off-screen right
                setTimeout(function () {
                    slides[prev].classList.remove('exit');
                }, 1000);
            }, 10000);
        })();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Show session / timeout message via SweetAlert if present
        (function () {
            const banner = document.getElementById('sessionMsgBanner');
            if (banner) {
                const msg = banner.getAttribute('data-msg');
                if (msg) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Session Ended',
                        text: msg,
                        confirmButtonText: 'OK',
                        confirmButtonColor: '#1a2a6c',
                        timer: 6000,
                        timerProgressBar: true
                    });
                }
            }
        })();
    </script>
    <script>
        // Re-validate License — AJAX inline validation with SweetAlert result
        (function () {
            const link = document.getElementById('licRevalidateLink');
            if (!link) return;

            link.addEventListener('click', function (e) {
                e.preventDefault();

                const token = (document.querySelector('input[name="__RequestVerificationToken"]') || {}).value || '';

                Swal.fire({
                    title: 'Validating License…',
                    text: 'Checking hardware and remote central server…',
                    allowOutsideClick: false,
                    allowEscapeKey: false,
                    didOpen: function () { Swal.showLoading(); }
                });

                fetch('/License/ReValidate', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token,
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.success) {
                        // Cache is now set server-side; redirect so middleware
                        // confirms the cache hit and loads the Login page cleanly.
                        Swal.close();
                        window.location.href = '/Account/Login';
                    } else {
                        var errs = data.errors || ['Validation failed. Contact Vendor Emeditech Plus LLP.'];
                        window.location.href = '/License/Invalid?errors=' + encodeURIComponent(errs.join('||'));
                    }
                })
                .catch(function () {
                    window.location.href = '/License/Invalid?errors=' + encodeURIComponent('Could not reach the validation server. Please check your connection and try again.');
                });
            });
        })();
    </script>
    <script>
        // Forgot Password — no self-service reset; prompt admin contact
        (function () {
            const link = document.getElementById('forgotPasswordLink');
            if (!link) return;
            link.addEventListener('click', function (e) {
                e.preventDefault();
                Swal.fire({
                    icon: 'info',
                    title: 'Password Reset',
                    text: 'Please contact your system administrator to reset your password.',
                    confirmButtonText: 'OK',
                    confirmButtonColor: '#1a2a6c'
                });
            });
        })();
    </script>
    <script>
        (function () {
            const passwordInput = document.getElementById('password');
            const toggleBtn = document.querySelector('.toggle-password');

            if (!passwordInput || !toggleBtn) return;

            toggleBtn.addEventListener('click', function () {
                const isPassword = passwordInput.type === 'password';
                passwordInput.type = isPassword ? 'text' : 'password';

                const icon = toggleBtn.querySelector('i');
                if (icon) {
                    icon.classList.toggle('fa-eye', !isPassword);
                    icon.classList.toggle('fa-eye-slash', isPassword);
                }

                toggleBtn.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
                toggleBtn.setAttribute('aria-pressed', isPassword ? 'true' : 'false');
            });
        })();
    </script>
</body>
</html>
