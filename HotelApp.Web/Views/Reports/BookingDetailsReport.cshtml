function exportDetailsPdf() {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ orientation: 'landscape', unit: 'pt', format: 'a4' });
    const W = doc.internal.pageSize.getWidth();
    const margin = 30;

    // ── Document header ──
    let y = margin;
    doc.setFont('helvetica', 'bold'); doc.setFontSize(14); doc.setTextColor(30, 27, 75);
    doc.text('Booking Details Report', W / 2, y, { align: 'center' }); y += 16;

    @if (!string.IsNullOrWhiteSpace(Model.HotelName))
    {
    @:doc.setFont('helvetica','normal'); doc.setFontSize(10); doc.setTextColor(100);
    @:doc.text('@Model.HotelName.Replace("'", "\\'")'.trim(), W/2, y, { align:'center' }); y += 13;
    }
    @if (!string.IsNullOrWhiteSpace(Model.HotelAddress))
    {
    @:doc.setFontSize(8); doc.text('@Model.HotelAddress.Replace("'", "\\'")'.trim(), W/2, y, { align:'center' }); y += 11;
    }
    @if (!string.IsNullOrWhiteSpace(Model.GSTCode))
    {
    @:doc.text('GSTIN: @Model.GSTCode', W/2, y, { align:'center' }); y += 11;
    }
    doc.setFontSize(9); doc.setTextColor(80);
    doc.text('Period: @Model.FromDate.ToString("dd MMM yyyy") to @Model.ToDate.ToString("dd MMM yyyy")', W/2, y, { align: 'center' }); y += 10;
    doc.setFont('helvetica','bold'); doc.setFontSize(8); doc.setTextColor(50);
    doc.text(
        `Bookings: @Model.Summary.TotalBookings  |  Total Bill: \u20B9@Model.Summary.TotalBillAmount.ToString("N2")  |  Collected: \u20B9@Model.Summary.TotalPaidAmount.ToString("N2")  |  Due: \u20B9@Model.Summary.TotalDueAmount.ToString("N2")`,
        W/2, y + 4, { align: 'center' }
    ); y += 16;

    // ── Build grouped table body ──
    // 13 cols: BookingNo | CheckIn/Out | Guest | Rooms/Types | BkType |
    //          LineType | Description | Base(₹) | GST(₹) | LineTotal(₹) |
    //          TotalBill | Paid | Status
    const body    = [];
    const rowMeta = []; // 'H' | 'Stay' | 'OtherCharge' | 'RoomService' | 'None'

    bookingData.forEach(b => {
        const lines = linesMap[b.bookingId] || [];
        // Booking header row (indigo bg, bold)
        body.push([
            b.bookingNumber,
            b.checkIn + ' \u2192 ' + b.checkOut,
            b.guest + '\n' + b.nights + 'N / ' + b.iGuest + ' Guest(s)',
            b.rooms + '\n' + b.roomTypes,
            b.bookingType + (b.b2bClient && b.b2bClient !== '-' ? '\n' + b.b2bClient : ''),
            '', '',                            // LineType, Description blank on header
            '', '', '',                        // Base, GST, LineTotal blank
            '\u20B9' + Number(b.totalBill).toLocaleString('en-IN',{minimumFractionDigits:2}),
            '\u20B9' + Number(b.totalPaid).toLocaleString('en-IN',{minimumFractionDigits:2}),
            b.status
        ]);
        rowMeta.push('H');

        if (lines.length === 0) {
            body.push(['','','','','', '\u2014','No billing details','','','', '','','']);
            rowMeta.push('None');
        } else {
            lines.forEach(l => {
                body.push([
                    '', '', '', '', '',        // booking cols blank
                    lineTypeLabel(l.lineType),
                    l.description,
                    Number(l.baseAmount).toFixed(2),
                    Number(l.gstAmount).toFixed(2),
                    Number(l.totalAmount).toFixed(2),
                    '', '', ''                 // booking total cols blank on line rows
                ]);
                rowMeta.push(l.lineType);
            });
        }
    });

    const headLabels = [
        'Booking No','Check-In \u2192 Out','Guest','Rooms / Types','Type',
        'Line Type','Description','Base (\u20B9)','GST (\u20B9)','Line Total (\u20B9)',
        'Total Bill (\u20B9)','Paid (\u20B9)','Status'
    ];

    doc.autoTable({
        head: [headLabels],
        body: body,
        startY: y,
        margin: { left: margin, right: margin },
        styles: { fontSize: 6.5, cellPadding: 3.5, overflow: 'linebreak', lineColor: [220,220,220], lineWidth: 0.3 },
        headStyles: { fillColor: [79,70,229], textColor: 255, fontStyle: 'bold', fontSize: 7 },
        columnStyles: {
            0:  { cellWidth: 84 },
            1:  { cellWidth: 76 },
            2:  { cellWidth: 80 },
            3:  { cellWidth: 70 },
            4:  { cellWidth: 42 },
            5:  { cellWidth: 56 },
            6:  { cellWidth: 120 },
            7:  { cellWidth: 52, halign: 'right' },
            8:  { cellWidth: 44, halign: 'right' },
            9:  { cellWidth: 56, halign: 'right', fontStyle: 'bold' },
            10: { cellWidth: 56, halign: 'right', fontStyle: 'bold' },
            11: { cellWidth: 52, halign: 'right' },
            12: { cellWidth: 44 },
        },
        didParseCell: (data) => {
            if (data.section !== 'body') return;
            const meta = rowMeta[data.row.index];
            if (meta === 'H') {
                data.cell.styles.fillColor     = [232, 234, 255];
                data.cell.styles.textColor     = [30,  27,  75];
                data.cell.styles.fontStyle     = 'bold';
                data.cell.styles.fontSize      = 7;
                data.cell.styles.minCellHeight = 20;
            } else if (meta === 'Stay') {
                data.cell.styles.fillColor = [248, 248, 255];
            } else if (meta === 'OtherCharge') {
                data.cell.styles.fillColor = [255, 251, 235];
            } else if (meta === 'RoomService') {
                data.cell.styles.fillColor = [236, 253, 245];
            } else {
                data.cell.styles.fillColor = [249, 250, 251];
                data.cell.styles.textColor = [156, 163, 175];
                data.cell.styles.fontStyle = 'italic';
            }
        },
        didDrawPage: (d) => {
            const pg = doc.internal.getCurrentPageInfo().pageNumber;
            const total = doc.internal.getNumberOfPages();
            doc.setFontSize(7); doc.setTextColor(150);
            doc.text('Page ' + pg + ' of ' + total, W - margin, doc.internal.pageSize.getHeight() - 10, { align: 'right' });
            doc.text('Generated: ' + new Date().toLocaleString(), margin, doc.internal.pageSize.getHeight() - 10);
        }
    });

    doc.save('BookingDetails_Details_@(Model.FromDate.ToString("yyyyMMdd"))_@(Model.ToDate.ToString("yyyyMMdd")).pdf');
}

