@model HotelApp.Web.ViewModels.MonthlyReportViewModel
@{
    ViewData["Title"] = $"Monthly Report – {Model.MonthName}";
    var labels    = Model.Daily.Select(d => d.Date.ToString("dd")).ToArray();
    var revenues  = Model.Daily.Select(d => d.Revenue).ToArray();
    var occupancy = Model.Daily.Select(d => d.OccupancyPct).ToArray();
    var rtLabels  = Model.RoomTypes.Select(r => r.RoomType).ToArray();
    var rtRevenue = Model.RoomTypes.Select(r => r.Revenue).ToArray();

    var months = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.MonthNames
        .Take(12).Select((n, i) => new { Name = n, Value = i + 1 }).ToList();
    var years  = Enumerable.Range(DateTime.Today.Year - 3, 5).ToList();
}

@section Styles {
<style>
    .mr-header { display:flex; align-items:center; gap:14px; margin-bottom:24px; }
    .mr-header-icon { width:48px; height:48px; border-radius:14px;
        background:linear-gradient(135deg,#f59e0b,#ef4444);
        display:flex; align-items:center; justify-content:center;
        color:#fff; font-size:1.4rem; box-shadow:0 4px 14px rgba(239,68,68,.25); flex-shrink:0; }
    .mr-header h2 { margin:0; font-size:1.55rem; font-weight:700; color:#1e1b4b; }
    .mr-header p  { margin:2px 0 0; font-size:.85rem; color:#6b7280; }

    .mr-filter { background:#fff; border-radius:16px; padding:20px 24px;
        box-shadow:0 1px 8px rgba(0,0,0,.07); margin-bottom:22px; border:1px solid #e9eaf0; }
    .mr-filter form { display:flex; flex-wrap:wrap; gap:14px; align-items:flex-end; }
    .mr-filter label { font-size:.8rem; font-weight:600; color:#374151; margin-bottom:4px; display:block; }
    .mr-filter select { border:1px solid #d1d5db; border-radius:8px; padding:8px 12px;
        font-size:.9rem; color:#111827; outline:none; background:#fff; }
    .mr-filter select:focus { border-color:#f59e0b; box-shadow:0 0 0 3px rgba(245,158,11,.15); }
    .mr-filter .btn-filter { background:linear-gradient(135deg,#f59e0b,#ef4444); color:#fff;
        border:none; border-radius:8px; padding:9px 20px; font-size:.9rem; font-weight:600; cursor:pointer; }
    .mr-filter .btn-print { background:#fff; border:1px solid #d1d5db; border-radius:8px;
        padding:9px 18px; font-size:.9rem; font-weight:600; color:#374151; cursor:pointer; }

    .mr-kpi-row { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:16px; margin-bottom:24px; }
    .mr-kpi { background:#fff; border-radius:14px; padding:18px 20px;
        box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #e9eaf0; }
    .mr-kpi .kpi-label { font-size:.78rem; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px; }
    .mr-kpi .kpi-value { font-size:1.6rem; font-weight:700; color:#1e1b4b; }
    .mr-kpi .kpi-sub   { font-size:.78rem; color:#9ca3af; margin-top:2px; }
    .mr-kpi.amber  .kpi-value { color:#f59e0b; }
    .mr-kpi.red    .kpi-value { color:#ef4444; }
    .mr-kpi.green  .kpi-value { color:#10b981; }
    .mr-kpi.blue   .kpi-value { color:#0ea5e9; }

    .mr-charts-row { display:grid; grid-template-columns:3fr 2fr; gap:20px; margin-bottom:24px; }
    .mr-card { background:#fff; border-radius:16px; padding:20px 24px;
        box-shadow:0 1px 8px rgba(0,0,0,.07); border:1px solid #e9eaf0; margin-bottom:20px; }
    .mr-card h4 { margin:0 0 16px; font-size:1rem; font-weight:700; color:#374151; }
    .mr-card canvas { max-height:250px; }

    .mr-table { width:100%; border-collapse:collapse; font-size:.88rem; }
    .mr-table thead th { background:#fffbeb; padding:10px 14px; text-align:left;
        font-size:.78rem; font-weight:700; color:#92400e; border-bottom:2px solid #fde68a; }
    .mr-table tbody tr:hover { background:#fffbeb; }
    .mr-table tbody td { padding:9px 14px; border-bottom:1px solid #f3f4f6; color:#374151; }
    .mr-table tfoot td { padding:10px 14px; font-weight:700; background:#fff7ed; border-top:2px solid #fed7aa; }

    /* Print styles */
    @@media print {
        .mr-filter, .mr-filter .btn-print, nav, footer, .navbar-toggle { display:none !important; }
        .main-content { padding:0; }
        .mr-card { box-shadow:none; border:1px solid #e5e7eb; page-break-inside:avoid; }
        body { background:#fff; }
    }

    @@media(max-width:768px) {
        .mr-charts-row { grid-template-columns:1fr; }
        .mr-kpi-row { grid-template-columns:repeat(2,1fr); }
    }
</style>
}

<div class="main-content">
    <!-- Header -->
    <div class="mr-header">
        <div class="mr-header-icon"><i class="fas fa-calendar-alt"></i></div>
        <div>
            <h2>Monthly Report — @Model.MonthName</h2>
            <p>Complete performance snapshot for the selected month</p>
        </div>
    </div>

    <!-- Filter -->
    <div class="mr-filter">
        <form method="get">
            <div>
                <label>Month</label>
                <select name="month">
                    @foreach (var m in months)
                    {
                        if (m.Value == Model.Month)
                        { <option value="@m.Value" selected>@m.Name</option> }
                        else
                        { <option value="@m.Value">@m.Name</option> }
                    }
                </select>
            </div>
            <div>
                <label>Year</label>
                <select name="year">
                    @foreach (var y in years)
                    {
                        if (y == Model.Year)
                        { <option value="@y" selected>@y</option> }
                        else
                        { <option value="@y">@y</option> }
                    }
                </select>
            </div>
            <button type="submit" class="btn-filter"><i class="fas fa-search"></i> View Report</button>
            <button type="button" class="btn-print" onclick="window.print()"><i class="fas fa-print"></i> Print / Save PDF</button>
        </form>
    </div>

    @if (Model.Daily.Any())
    {
        <!-- KPI Cards -->
        <div class="mr-kpi-row">
            <div class="mr-kpi blue">
                <div class="kpi-label">Total Bookings</div>
                <div class="kpi-value">@Model.Summary.TotalBookings</div>
                <div class="kpi-sub">Check-ins in @Model.MonthName</div>
            </div>
            <div class="mr-kpi green">
                <div class="kpi-label">Total Revenue</div>
                <div class="kpi-value">₹@Model.Summary.TotalRevenue.ToString("N0")</div>
                <div class="kpi-sub">Gross billing</div>
            </div>
            <div class="mr-kpi amber">
                <div class="kpi-label">Avg Daily Rate</div>
                <div class="kpi-value">₹@Model.Summary.AverageDailyRate.ToString("N0")</div>
                <div class="kpi-sub">Per occupied night</div>
            </div>
            <div class="mr-kpi red">
                <div class="kpi-label">Cancellations</div>
                <div class="kpi-value">@Model.Summary.CancelledBookings</div>
                <div class="kpi-sub">Cancelled bookings</div>
            </div>
            <div class="mr-kpi">
                <div class="kpi-label">Occupied Nights</div>
                <div class="kpi-value">@Model.Summary.TotalOccupiedNights</div>
                <div class="kpi-sub">Room nights sold</div>
            </div>
        </div>

        <!-- Charts -->
        <div class="mr-charts-row">
            <div class="mr-card">
                <h4><i class="fas fa-chart-bar" style="color:#f59e0b;margin-right:6px"></i>Daily Revenue</h4>
                <canvas id="mrRevenueChart"></canvas>
            </div>
            <div class="mr-card">
                <h4><i class="fas fa-chart-pie" style="color:#6366f1;margin-right:6px"></i>Revenue by Room Type</h4>
                <canvas id="mrRoomTypeChart"></canvas>
            </div>
        </div>

        <!-- Occupancy chart -->
        <div class="mr-card">
            <h4><i class="fas fa-percentage" style="color:#10b981;margin-right:6px"></i>Daily Occupancy Rate</h4>
            <canvas id="mrOccupancyChart"></canvas>
        </div>

        <!-- Summary Table -->
        <div class="mr-card">
            <h4><i class="fas fa-table" style="color:#6b7280;margin-right:6px"></i>Revenue by Room Type</h4>
            <table class="mr-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Room Type</th>
                        <th>Bookings</th>
                        <th>Revenue (₹)</th>
                        <th>Share %</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int idx = 1; }
                    @foreach (var rt in Model.RoomTypes)
                    {
                        <tr>
                            <td>@idx++</td>
                            <td>@rt.RoomType</td>
                            <td>@rt.Bookings</td>
                            <td>₹@rt.Revenue.ToString("N2")</td>
                            <td>@rt.RevenuePct%</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="2">Total</td>
                        <td></td>
                        <td>₹@Model.Summary.TotalRevenue.ToString("N2")</td>
                        <td>100%</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
    else
    {
        <div style="text-align:center;padding:60px;color:#9ca3af">
            <i class="fas fa-calendar-times" style="font-size:3rem;margin-bottom:12px;display:block"></i>
            No booking data for @Model.MonthName.
        </div>
    }
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>
(function() {
    const labels    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(labels));
    const revenues  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(revenues));
    const occupancy = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(occupancy));
    const rtLabels  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(rtLabels));
    const rtRevenue = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(rtRevenue));

    Chart.defaults.font.family = "'Inter','Segoe UI',sans-serif";

    if (document.getElementById('mrRevenueChart')) {
        new Chart(document.getElementById('mrRevenueChart'), {
            type:'bar',
            data:{ labels, datasets:[{ label:'Revenue (₹)', data:revenues,
                backgroundColor:'rgba(245,158,11,0.75)', borderColor:'#f59e0b',
                borderWidth:1, borderRadius:4 }] },
            options:{ responsive:true, plugins:{ legend:{display:false} },
                scales:{ y:{ beginAtZero:true, ticks:{ callback:v=>'₹'+v.toLocaleString('en-IN') } } } }
        });
    }

    if (document.getElementById('mrRoomTypeChart')) {
        const palette=['#6366f1','#0ea5e9','#10b981','#f59e0b','#ef4444','#8b5cf6','#ec4899'];
        new Chart(document.getElementById('mrRoomTypeChart'), {
            type:'doughnut',
            data:{ labels:rtLabels, datasets:[{ data:rtRevenue, backgroundColor:palette, borderWidth:2 }] },
            options:{ responsive:true, plugins:{ legend:{ position:'bottom', labels:{ boxWidth:12, padding:10 } } } }
        });
    }

    if (document.getElementById('mrOccupancyChart')) {
        new Chart(document.getElementById('mrOccupancyChart'), {
            type:'line',
            data:{ labels, datasets:[{ label:'Occupancy %', data:occupancy,
                borderColor:'#10b981', backgroundColor:'rgba(16,185,129,0.1)',
                borderWidth:2, fill:true, tension:0.4, pointRadius:3 }] },
            options:{ responsive:true, plugins:{ legend:{display:false} },
                scales:{ y:{ beginAtZero:true, max:100, ticks:{ callback:v=>v+'%' } } } }
        });
    }
})();
</script>
}
