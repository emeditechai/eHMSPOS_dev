@model HotelApp.Web.ViewModels.GuestDetailsReportViewModel
@{
    ViewData["Title"] = "Guest Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/room-dashboard.css" asp-append-version="true" />
    <style>
        /* ── Page Header ── */
        .gd-page-header {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 24px;
        }
        .gd-header-icon {
            width: 48px; height: 48px;
            border-radius: 14px;
            background: linear-gradient(135deg,#8b5cf6,#6d28d9);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 1.4rem;
            box-shadow: 0 4px 14px rgba(139,92,246,.35);
            flex-shrink: 0;
        }
        .gd-page-header h2 {
            margin: 0;
            font-size: 1.55rem;
            font-weight: 700;
            color: #1e1b4b;
            letter-spacing: -.3px;
        }
        .gd-page-header p {
            margin: 2px 0 0;
            font-size: .85rem;
            color: #6b7280;
        }

        /* ── Filter Card ── */
        .gd-filter-card {
            background: #fff;
            border-radius: 16px;
            padding: 20px 24px;
            box-shadow: 0 1px 8px rgba(0,0,0,.07);
            margin-bottom: 22px;
            border: 1px solid #e9eaf0;
        }
        .gd-filter-row {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            align-items: flex-end;
            justify-content: space-between;
        }
        .gd-filter-fields { display: flex; flex-wrap: wrap; gap: 16px; align-items: flex-end; }
        .gd-field label {
            display: block;
            font-size: .78rem;
            font-weight: 700;
            color: #374151;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: .5px;
        }
        .gd-field input[type="date"] {
            border: 1.5px solid #d1d5db;
            border-radius: 10px;
            padding: 9px 14px;
            font-size: .9rem;
            color: #1f2937;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
            background: #f9fafb;
        }
        .gd-field input[type="date"]:focus {
            border-color: #8b5cf6;
            box-shadow: 0 0 0 3px rgba(139,92,246,.15);
            background: #fff;
        }
        .gd-filter-actions { display: flex; gap: 10px; align-items: flex-end; }
        .gd-btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 9px 20px;
            border-radius: 10px;
            font-size: .875rem;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: all .2s;
            text-decoration: none;
            white-space: nowrap;
        }
        .gd-btn-primary { background:linear-gradient(135deg,#8b5cf6,#6d28d9); color:#fff; box-shadow:0 3px 10px rgba(139,92,246,.35); }
        .gd-btn-primary:hover { transform:translateY(-1px); box-shadow:0 6px 16px rgba(139,92,246,.4); color:#fff; }
        .gd-btn-ghost { background:#f3f4f6; color:#374151; border:1.5px solid #e5e7eb; }
        .gd-btn-ghost:hover { background:#e5e7eb; transform:translateY(-1px); color:#1f2937; }

        /* ── Summary Cards ── */
        .gd-summary-row {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 22px;
        }
        .gd-summary-card {
            flex: 1;
            min-width: 150px;
            border-radius: 16px;
            padding: 18px 22px;
            color: #fff;
            position: relative;
            overflow: hidden;
            box-shadow: 0 4px 18px rgba(0,0,0,.12);
        }
        .gd-summary-card::before {
            content: '';
            position: absolute;
            top: -18px; right: -18px;
            width: 80px; height: 80px;
            border-radius: 50%;
            background: rgba(255,255,255,.12);
        }
        .gd-sc-label { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.8px; opacity:.85; margin-bottom:8px; }
        .gd-sc-value { font-size:1.75rem; font-weight:800; line-height:1; }
        .gd-sc-icon  { position:absolute; bottom:12px; right:16px; font-size:1.8rem; opacity:.2; }
        .gd-sc-guests      { background:linear-gradient(135deg,#10b981,#059669); }
        .gd-sc-bookings    { background:linear-gradient(135deg,#ef4444,#dc2626); }
        .gd-sc-cancelled   { background:linear-gradient(135deg,#f97316,#ea580c); }
        .gd-sc-nights      { background:linear-gradient(135deg,#8b5cf6,#7c3aed); }
        .gd-sc-revenue     { background:linear-gradient(135deg,#3b82f6,#2563eb); }
        .gd-sc-outstanding { background:linear-gradient(135deg,#ef4444,#b91c1c); }

        /* ── Table Card ── */
        .gd-table-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 1px 8px rgba(0,0,0,.07);
            border: 1px solid #e9eaf0;
            overflow: hidden;
        }
        .gd-table-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            padding: 18px 22px 14px;
            border-bottom: 1px solid #f0f0f5;
        }
        .gd-table-title    { font-size:1rem; font-weight:700; color:#1f2937; }
        .gd-table-subtitle { font-size:.8rem; color:#9ca3af; margin-top:2px; }
        .gd-export-group   { display:flex; gap:8px; flex-wrap:wrap; }
        .gd-btn-csv   { background:linear-gradient(135deg,#10b981,#059669); color:#fff; box-shadow:0 3px 10px rgba(16,185,129,.3); }
        .gd-btn-excel { background:linear-gradient(135deg,#3b82f6,#2563eb); color:#fff; box-shadow:0 3px 10px rgba(59,130,246,.3); }
        .gd-btn-pdf   { background:linear-gradient(135deg,#ef4444,#dc2626); color:#fff; box-shadow:0 3px 10px rgba(239,68,68,.3); }
        .gd-btn-csv:hover   { transform:translateY(-1px); box-shadow:0 6px 16px rgba(16,185,129,.4); color:#fff; }
        .gd-btn-excel:hover { transform:translateY(-1px); box-shadow:0 6px 16px rgba(59,130,246,.4); color:#fff; }
        .gd-btn-pdf:hover   { transform:translateY(-1px); box-shadow:0 6px 16px rgba(239,68,68,.4); color:#fff; }

        /* ── Table ── */
        .gd-table { width:100%; border-collapse:collapse; font-size:.875rem; }
        .gd-table thead tr { background:#f5f3ff; }
        .gd-table thead th {
            padding: 12px 16px;
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: #6b7280;
            border-bottom: 2px solid #e9eaf0;
            white-space: nowrap;
        }
        .gd-table tbody tr { transition:background .15s; border-bottom:1px solid #f3f4f6; }
        .gd-table tbody tr:hover { background:#f5f3ff; }
        .gd-table tbody td { padding:13px 16px; color:#374151; vertical-align:middle; }
        .gd-table .text-end { text-align:right; }
        .gd-guest-name { font-weight:700; color:#1f2937; }
        .gd-email      { font-size:.8rem; color:#6b7280; }
        .gd-cancelled-zero { color:#9ca3af; }
        .gd-cancelled-pos  { color:#dc2626; font-weight:700; }
        .gd-outstanding-amt { color:#dc2626; font-weight:700; }
        .gd-empty-row td {
            text-align:center;
            padding:48px 20px;
            color:#9ca3af;
        }
        .gd-empty-row i { font-size:1.8rem; display:block; margin-bottom:10px; opacity:.4; }
    </style>
}

<!-- Page Header -->
<div class="gd-page-header">
    <div class="gd-header-icon"><i class="fas fa-user-friends"></i></div>
    <div>
        <h2>Guest Details</h2>
        <p>Guest-wise booking and revenue summary</p>
    </div>
</div>

<!-- Filters -->
<div class="gd-filter-card">
    <form method="get" action="@Url.Action("GuestDetails", "Reports")">
        <div class="gd-filter-row">
            <div class="gd-filter-fields">
                <div class="gd-field">
                    <label for="fromDate">Check-in From</label>
                    <input id="fromDate" name="fromDate" type="date" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="gd-field">
                    <label for="toDate">Check-in To</label>
                    <input id="toDate" name="toDate" type="date" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
                </div>
            </div>
            <div class="gd-filter-actions">
                <button class="gd-btn gd-btn-primary" type="submit"><i class="fas fa-filter"></i> Apply</button>
                <a class="gd-btn gd-btn-ghost" href="@Url.Action("GuestDetails", "Reports")"><i class="fas fa-rotate-left"></i> Reset</a>
            </div>
        </div>
    </form>
</div>

<!-- Summary Cards -->
<div class="gd-summary-row">
    <div class="gd-summary-card gd-sc-guests">
        <div class="gd-sc-label">Total Guests</div>
        <div class="gd-sc-value">@Model.Summary.TotalGuests</div>
        <i class="fas fa-users gd-sc-icon"></i>
    </div>
    <div class="gd-summary-card gd-sc-bookings">
        <div class="gd-sc-label">Total Bookings</div>
        <div class="gd-sc-value">@Model.Summary.TotalBookings</div>
        <i class="fas fa-calendar-check gd-sc-icon"></i>
    </div>
    <div class="gd-summary-card gd-sc-cancelled">
        <div class="gd-sc-label">Cancelled</div>
        <div class="gd-sc-value">@Model.Summary.CancelledBookings</div>
        <i class="fas fa-calendar-xmark gd-sc-icon"></i>
    </div>
    <div class="gd-summary-card gd-sc-nights">
        <div class="gd-sc-label">Total Nights</div>
        <div class="gd-sc-value">@Model.Summary.TotalNights</div>
        <i class="fas fa-moon gd-sc-icon"></i>
    </div>
    <div class="gd-summary-card gd-sc-revenue">
        <div class="gd-sc-label">Revenue</div>
        <div class="gd-sc-value">₹@Model.Summary.TotalRevenue.ToString("N0")</div>
        <i class="fas fa-rupee-sign gd-sc-icon"></i>
    </div>
    <div class="gd-summary-card gd-sc-outstanding">
        <div class="gd-sc-label">Outstanding</div>
        <div class="gd-sc-value">₹@Model.Summary.TotalBalance.ToString("N0")</div>
        <i class="fas fa-hourglass-half gd-sc-icon"></i>
    </div>
</div>

<!-- Table Card -->
<div class="gd-table-card">
    <div class="gd-table-header">
        <div>
            <div class="gd-table-title">Guests</div>
            <div class="gd-table-subtitle">@Model.Rows.Count row@(Model.Rows.Count == 1 ? "" : "s") found</div>
        </div>
        <div class="gd-export-group">
            <button class="gd-btn gd-btn-csv"   type="button" onclick="exportToCsv()"><i class="fas fa-file-csv"></i> CSV</button>
            <button class="gd-btn gd-btn-excel" type="button" onclick="exportToExcel()"><i class="fas fa-file-excel"></i> Excel</button>
            <button class="gd-btn gd-btn-pdf"   type="button" onclick="exportToPdf()"><i class="fas fa-file-pdf"></i> PDF</button>
        </div>
    </div>

    <div style="overflow-x:auto;">
        <table class="gd-table" id="guestDetailsTable">
            <thead>
                <tr>
                    <th>Guest</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>City</th>
                    <th class="text-end">Bookings</th>
                    <th class="text-end">Cancelled</th>
                    <th class="text-end">Nights</th>
                    <th class="text-end">Revenue</th>
                    <th class="text-end">Outstanding</th>
                    <th>Last Check-in</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Rows.Any())
            {
                <tr class="gd-empty-row">
                    <td colspan="10"><i class="fas fa-users"></i>No guest records found for the selected period.</td>
                </tr>
            }
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td><span class="gd-guest-name">@(string.IsNullOrWhiteSpace(row.GuestName) ? "Guest" : row.GuestName)</span></td>
                    <td>@(string.IsNullOrWhiteSpace(row.Phone) ? "-" : row.Phone)</td>
                    <td><span class="gd-email">@(string.IsNullOrWhiteSpace(row.Email) ? "-" : row.Email)</span></td>
                    <td>@(string.IsNullOrWhiteSpace(row.City) ? "-" : row.City)</td>
                    <td class="text-end">@row.BookingCount</td>
                    <td class="text-end"><span class="@(row.CancelledCount > 0 ? "gd-cancelled-pos" : "gd-cancelled-zero")">@row.CancelledCount</span></td>
                    <td class="text-end">@row.TotalNights</td>
                    <td class="text-end">₹@row.TotalRevenue.ToString("N2")</td>
                    <td class="text-end"><span class="@(row.TotalBalance > 0 ? "gd-outstanding-amt" : "")">₹@row.TotalBalance.ToString("N2")</span></td>
                    <td>@row.LastStayDate.ToString("dd MMM yyyy")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.4/jspdf.plugin.autotable.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
        const downloadBlob = (blob, filename) => {
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            a.remove();
            setTimeout(() => URL.revokeObjectURL(url), 500);
        };

        const getRows = () => {
            const table = document.getElementById('guestDetailsTable');
            const bodyRows = Array.from(table.querySelectorAll('tbody tr'))
                .filter(tr => tr.style.display !== 'none');

            return bodyRows.map(tr => {
                const tds = Array.from(tr.querySelectorAll('td'));
                return {
                    guest: (tds[0]?.innerText || '').trim(),
                    phone: (tds[1]?.innerText || '').trim(),
                    email: (tds[2]?.innerText || '').trim(),
                    city: (tds[3]?.innerText || '').trim(),
                    bookings: (tds[4]?.innerText || '').trim(),
                    cancelled: (tds[5]?.innerText || '').trim(),
                    nights: (tds[6]?.innerText || '').trim(),
                    revenue: (tds[7]?.innerText || '').trim(),
                    outstanding: (tds[8]?.innerText || '').trim(),
                    lastStay: (tds[9]?.innerText || '').trim(),
                };
            });
        };

        const exportToCsv = () => {
            const rows = getRows();
            const header = ['Guest','Phone','Email','City','Bookings','Cancelled','Nights','Revenue','Outstanding','Last Stay'];

            const escape = (v) => {
                const s = String(v ?? '');
                if (/[\n\r,"]/g.test(s)) return '"' + s.replace(/"/g, '""') + '"';
                return s;
            };

            const lines = [header.map(escape).join(',')];
            rows.forEach(r => lines.push([r.guest, r.phone, r.email, r.city, r.bookings, r.cancelled, r.nights, r.revenue, r.outstanding, r.lastStay].map(escape).join(',')));

            const from = document.getElementById('fromDate')?.value || '';
            const to = document.getElementById('toDate')?.value || '';
            const csv = '\uFEFF' + lines.join('\n');
            downloadBlob(new Blob([csv], { type: 'text/csv;charset=utf-8;' }), `GuestDetails_${from}_${to}.csv`);
        };

        const exportToExcel = () => {
            const rows = getRows();
            const escHtml = (s) => String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

            let html = '<table border="1">';
            html += '<tr>' + ['Guest','Phone','Email','City','Bookings','Cancelled','Nights','Revenue','Outstanding','Last Stay'].map(h => `<th>${escHtml(h)}</th>`).join('') + '</tr>';
            rows.forEach(r => {
                html += '<tr>' + [r.guest, r.phone, r.email, r.city, r.bookings, r.cancelled, r.nights, r.revenue, r.outstanding, r.lastStay].map(v => `<td>${escHtml(v)}</td>`).join('') + '</tr>';
            });
            html += '</table>';

            const content = `<!doctype html><html><head><meta charset="utf-8"></head><body>${html}</body></html>`;
            const from = document.getElementById('fromDate')?.value || '';
            const to = document.getElementById('toDate')?.value || '';
            downloadBlob(new Blob([content], { type: 'application/vnd.ms-excel;charset=utf-8;' }), `GuestDetails_${from}_${to}.xls`);
        };

        const exportToPdf = () => {
            if (!window.jspdf || !window.jspdf.jsPDF) {
                alert('PDF export library failed to load. Please refresh and try again.');
                return;
            }

            const rows = getRows();
            const from = document.getElementById('fromDate')?.value || '';
            const to = document.getElementById('toDate')?.value || '';

            const jsPDF = window.jspdf.jsPDF;
            const doc = new jsPDF({ orientation: 'landscape', unit: 'pt', format: 'a4' });

            doc.setFontSize(14);
            doc.text(`Guest Details (${from} to ${to})`, 40, 40);

            const autoTableFn = doc.autoTable || (jsPDF.API && jsPDF.API.autoTable);
            if (!autoTableFn) {
                alert('PDF table plugin failed to load. Please refresh and try again.');
                return;
            }

            (doc.autoTable || autoTableFn).call(doc, {
                startY: 60,
                head: [[ 'Guest','Phone','Email','City','Bookings','Cancelled','Nights','Revenue','Outstanding','Last Stay' ]],
                body: rows.map(r => [r.guest, r.phone, r.email, r.city, r.bookings, r.cancelled, r.nights, r.revenue, r.outstanding, r.lastStay]),
                styles: { fontSize: 8 },
                headStyles: { fillColor: [15, 23, 42] }
            });

            doc.save(`GuestDetails_${from}_${to}.pdf`);
        };
    </script>
}
