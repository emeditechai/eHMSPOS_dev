@model HotelApp.Web.ViewModels.BanquetAddPaymentViewModel
@{
    ViewData["Title"] = "Add Payment";
    var banks        = ViewBag.Banks as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var hasVenue     = Model.VenueTotal   > 0;
    var hasPackage   = Model.PackageTotal > 0;
    var hasAddon     = Model.AddonTotal   > 0;
    // A head is "payable" only when its due > 0
    var venuePayable   = Model.VenueDue   > 0;
    var packagePayable = Model.PackageDue > 0;
    var addonPayable   = Model.AddonDue   > 0;
}

@section Styles {
<style>
/* ── Page Shell ─────────────────────────────────────── */
.pay-page-header {
    display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.6rem;
    background:linear-gradient(135deg,#1a2a6c 0%,#4338ca 100%);
    border-radius:16px; padding:1rem 1.5rem; margin-bottom:1.4rem;
    box-shadow:0 6px 24px rgba(26,42,108,.22); position:relative; overflow:hidden;
}
.pay-page-header::before {
    content:''; position:absolute; right:-50px; top:-50px;
    width:160px; height:160px; background:rgba(255,255,255,.06); border-radius:50%;
}
.pay-page-title { display:flex; align-items:center; gap:14px; }
.pay-page-icon  { width:46px; height:46px; border-radius:12px; background:rgba(255,255,255,.15);
                  display:flex; align-items:center; justify-content:center; font-size:1.3rem; color:#fff; }
.pay-page-title h2  { margin:0; font-size:1.15rem; font-weight:700; color:#fff; }
.pay-page-title span{ font-size:.8rem; color:rgba(255,255,255,.7); display:block; margin-top:1px; }

/* ── Form Card ───────────────────────────────────────── */
.pay-form-card {
    background:#fff; border-radius:14px;
    box-shadow:0 2px 12px rgba(0,0,0,.07); border:1px solid #e5e7eb;
    overflow:hidden;
}

/* ── Summary Bar ─────────────────────────────────────── */
.pay-summary-bar {
    display:flex; gap:0; border-bottom:1px solid #e5e7eb; background:#f9fafb;
}
.pay-summary-item {
    flex:1; padding:.75rem 1.25rem; border-right:1px solid #e5e7eb;
}
.pay-summary-item:last-child { border-right:none; }
.psi-label { font-size:.72rem; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:.06em; }
.psi-value { font-size:1.1rem; font-weight:800; color:#111827; margin-top:2px; }
.psi-value.collecting { color:#16a34a; }
.psi-value.net-payable { color:#1d4ed8; }

/* ── Body: two-column grid ───────────────────────────── */
.pay-body {
    display:grid; grid-template-columns:1.3fr 1fr; gap:0; align-items:start;
}
.pay-col { padding:1.4rem 1.5rem; }
.pay-col-left  { border-right:1px solid #e5e7eb; }
@@media(max-width:820px) {
    .pay-body { grid-template-columns:1fr; }
    .pay-col-left { border-right:none; border-bottom:1px solid #e5e7eb; }
}

/* ── Section headers ─────────────────────────────────── */
.pay-section-hdr {
    display:flex; align-items:center; gap:9px;
    font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.07em;
    color:#6b7280; padding-bottom:8px; border-bottom:2px solid #f3f4f6; margin-bottom:14px;
}
.pay-section-hdr i { color:#4338ca; font-size:.85rem; }
.pay-section { margin-bottom:20px; }

/* ── Field helpers ───────────────────────────────────── */
.fg { display:flex; flex-direction:column; margin-bottom:14px; }
.fg label { font-size:.8rem; font-weight:600; color:#374151; margin-bottom:5px; }
.fg input, .fg select, .fg textarea {
    padding:10px 13px; border:1px solid #d1d5db; border-radius:8px;
    font-size:.9rem; color:#111827; background:#fff;
    transition:border-color .18s, box-shadow .18s; width:100%;
}
.fg input:focus, .fg select:focus, .fg textarea:focus {
    outline:none; border-color:#4338ca; box-shadow:0 0 0 3px rgba(67,56,202,.12);
}
.req { color:#e11d48; }
.fg2 { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
@@media(max-width:500px){ .fg2{ grid-template-columns:1fr; } }

/* ── Billing Head Rows ───────────────────────────────── */
.head-row {
    display:grid; grid-template-columns:auto 1fr auto; align-items:start; gap:12px;
    padding:12px 14px; border:1.5px solid #e5e7eb; border-radius:10px; margin-bottom:10px;
    transition:border-color .18s, box-shadow .18s;
}
.head-row.active { border-color:#4338ca; box-shadow:0 0 0 3px rgba(67,56,202,.08); }
.head-row.disabled {
    opacity:.6; background:#f9fafb; cursor:not-allowed;
}
.head-row.disabled .head-chk { cursor:not-allowed; }
.head-row.disabled .head-amount-wrap input { background:#f3f4f6; color:#9ca3af; cursor:not-allowed; }
.head-row.disabled .head-btns button { pointer-events:none; opacity:.4; }
.paid-badge {
    display:inline-flex; align-items:center; gap:4px;
    background:#d1fae5; color:#065f46; border:1px solid #6ee7b7;
    border-radius:20px; padding:2px 10px; font-size:.72rem; font-weight:700;
}
.head-chk { width:18px; height:18px; accent-color:#4338ca; cursor:pointer; flex-shrink:0; margin-top:3px; }
.head-info { display:flex; flex-direction:column; gap:3px; }
.head-name { font-size:.9rem; font-weight:700; color:#111827; }
.head-due  { font-size:.77rem; color:#6b7280; }
.head-due span { font-weight:700; color:#e11d48; }
.head-amount-wrap input {
    width:130px; padding:8px 11px; border:1px solid #d1d5db; border-radius:8px;
    font-size:.9rem; font-weight:700; color:#111827; text-align:right;
    transition:border-color .18s; background:#fff;
}
.head-amount-wrap input:focus { outline:none; border-color:#4338ca; box-shadow:0 0 0 3px rgba(67,56,202,.1); }
.head-amount-wrap input:disabled { background:#f3f4f6; color:#9ca3af; }
.head-btns { display:flex; gap:4px; margin-top:5px; }
.head-btns button {
    padding:4px 9px; font-size:.72rem; font-weight:700; border-radius:6px;
    border:1px solid #d1d5db; background:#f9fafb; color:#374151; cursor:pointer; transition:all .15s;
}
.head-btns button:hover { background:#4338ca; color:#fff; border-color:#4338ca; }

/* ── Gross/Net display ───────────────────────────────── */
.amount-row {
    display:flex; justify-content:space-between; align-items:center;
    border-radius:10px; padding:10px 14px; margin-top:6px;
}
.amount-row.gross { background:#f0fdf4; border:1px solid #86efac; }
.amount-row.net   { background:#eff6ff; border:1px solid #bfdbfe; }
.amount-row .ar-lbl { font-size:.82rem; font-weight:700; }
.amount-row .ar-val { font-size:1.05rem; font-weight:800; }
.amount-row.gross .ar-lbl { color:#166534; } .amount-row.gross .ar-val { color:#15803d; }
.amount-row.net   .ar-lbl { color:#1e40af; } .amount-row.net   .ar-val { color:#1d4ed8; }

/* ── Discount Toggle ─────────────────────────────────── */
.disc-toggle { display:flex; gap:0; border:1px solid #d1d5db; border-radius:8px; overflow:hidden; margin-bottom:12px; }
.disc-toggle label {
    flex:1; margin:0; cursor:pointer;
    display:flex; align-items:center; justify-content:center; gap:5px;
    padding:8px 12px; font-size:.8rem; font-weight:600; color:#6b7280;
    background:#f9fafb; border-right:1px solid #d1d5db; transition:all .18s; user-select:none;
}
.disc-toggle label:last-child { border-right:none; }
.disc-toggle label.active { background:linear-gradient(135deg,#1a2a6c,#4338ca); color:#fff !important; }
.disc-input-row { display:flex; align-items:center; gap:10px; }
.disc-input-row input { flex:1; }
.disc-badge {
    font-size:.78rem; font-weight:700; color:#4338ca; background:#ede9fe;
    border:1px solid #c4b5fd; border-radius:6px; padding:4px 9px; white-space:nowrap;
}

/* ── Round Off ───────────────────────────────────────── */
.roundoff-row {
    display:flex; align-items:center; gap:10px; padding:10px 13px;
    background:#fefce8; border:1px solid #fef08a; border-radius:8px; cursor:pointer; user-select:none;
}
.roundoff-row input[type=checkbox] { width:16px; height:16px; accent-color:#ca8a04; cursor:pointer; }
.roundoff-row span { font-size:.85rem; font-weight:600; color:#92400e; }
.roundoff-row .ro-detail { font-size:.78rem; color:#78350f; margin-left:4px; }

/* ── Payment Method Tabs ─────────────────────────────── */
.pm-tabs { display:flex; flex-wrap:wrap; gap:.4rem; margin-bottom:14px; }
.pm-tab {
    border:1px solid #e5e7eb; background:#fff; color:#374151;
    padding:.4rem .75rem; border-radius:8px; font-weight:700; font-size:.85rem;
    cursor:pointer; line-height:1; transition:all .18s;
}
.pm-tab.is-active { border-color:#667eea; background:rgba(102,126,234,.12); color:#3730a3; }
.pm-fields-box {
    border:1px solid #e5e7eb; border-radius:10px; background:#f9fafb;
    padding:.75rem; margin-bottom:14px;
    display:grid; grid-template-columns:1fr 1fr; gap:.7rem;
}
.pm-fields-box .fg { margin-bottom:0; }
.pm-fields-box.three-col { grid-template-columns:1fr 1fr 1fr; }

/* ── Footer ──────────────────────────────────────────── */
.pay-footer {
    display:flex; justify-content:flex-end; gap:.65rem;
    padding:.9rem 1.5rem; background:#f9fafb;
    border-top:1px solid #e5e7eb; border-radius:0 0 14px 14px;
}
.btn-record {
    display:inline-flex; align-items:center; gap:8px;
    padding:.6rem 1.5rem; border-radius:8px; border:none; cursor:pointer;
    font-size:.93rem; font-weight:700; transition:all .18s;
    background:linear-gradient(135deg,#16a34a,#15803d); color:#fff;
    box-shadow:0 2px 8px rgba(22,163,74,.25);
}
.btn-record:hover { opacity:.92; transform:translateY(-1px); }
.btn-cancel-link {
    display:inline-flex; align-items:center; gap:7px;
    padding:.6rem 1.2rem; border-radius:8px; border:1px solid #d1d5db;
    background:#fff; color:#374151; font-size:.9rem; font-weight:600;
    text-decoration:none; transition:all .18s;
}
.btn-cancel-link:hover { background:#f9fafb; border-color:#9ca3af; }
</style>
}

<!-- Page Header -->
<div class="pay-page-header">
    <div class="pay-page-title">
        <div class="pay-page-icon"><i class="fas fa-indian-rupee-sign"></i></div>
        <div>
            <h2>Add Payment</h2>
            <span>@Model.BanquetBookingNumber &mdash; @Model.EventName</span>
        </div>
    </div>
    <a asp-action="Details" asp-route-id="@Model.BanquetBookingId" class="btn-cancel-link">
        <i class="fas fa-arrow-left"></i> Back to Booking
    </a>
</div>

<div class="pay-form-card">
    <form asp-action="AddPayment" method="post" id="payForm" onsubmit="return prepareSubmit()">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="BanquetBookingId" />
        <input type="hidden" asp-for="BanquetBookingNumber" />
        <input type="hidden" asp-for="EventName" />
        <input type="hidden" asp-for="TotalAmount" />
        <input type="hidden" asp-for="BalanceAmount" />
        <input type="hidden" asp-for="VenueTotal" />
        <input type="hidden" asp-for="PackageTotal" />
        <input type="hidden" asp-for="AddonTotal" />
        <input type="hidden" asp-for="DiscountAmount"  id="hiddenDiscountAmount" />
        <input type="hidden" asp-for="RoundOffAmount"  id="hiddenRoundOff" />
        <input type="hidden" asp-for="HeadAllocations" id="hiddenHeadAllocations" />
        <input type="hidden" asp-for="DiscountType"    id="discTypeInput" value="None" />
        <!-- hidden select keeps model binding for PaymentMethod -->
        <select asp-for="PaymentMethod" id="pmMethodHidden" style="display:none" tabindex="-1">
            <option value="Cash">Cash</option>
            <option value="Card">Card</option>
            <option value="UPI">UPI</option>
            <option value="BankTransfer">BankTransfer</option>
            <option value="Cheque">Cheque</option>
            <option value="DD">DD</option>
        </select>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger mx-3 mt-3"></div>

        <!-- ── Summary Bar ── -->
        <div class="pay-summary-bar">
            <div class="pay-summary-item">
                <div class="psi-label">Total Due</div>
                <div class="psi-value">&#x20B9;@Model.BalanceAmount.ToString("N2")</div>
            </div>
            <div class="pay-summary-item">
                <div class="psi-label">Gross Collecting</div>
                <div class="psi-value collecting" id="summaryGross">&#x20B9;0.00</div>
            </div>
            <div class="pay-summary-item">
                <div class="psi-label">Net Payable Now</div>
                <div class="psi-value net-payable" id="summaryNet">&#x20B9;0.00</div>
            </div>
        </div>

        <!-- ── Two-column body ── -->
        <div class="pay-body">

            <!-- ─── LEFT: Billing heads + Discount + Round-off ─── -->
            <div class="pay-col pay-col-left">

                <!-- Billing Head Allocation -->
                <div class="pay-section">
                    <div class="pay-section-hdr"><i class="fas fa-layer-group"></i> Billing Head Allocation</div>
                    <p style="font-size:.78rem;color:#6b7280;margin-bottom:12px">
                        Select the heads to pay. Uncheck a head to exclude it from this payment.
                    </p>

                    @if (hasVenue) {
                    <div class="head-row @(venuePayable ? "active" : "disabled")" id="row-V">
                        <input type="checkbox" class="head-chk" id="chk-V"
                               @(venuePayable ? "checked" : "disabled")
                               onchange="toggleHead('V')" />
                        <div class="head-info">
                            <div class="head-name">
                                <i class="fas fa-building me-1" style="color:#4338ca"></i> Venue Hire
                                @if (!venuePayable) { <span class="paid-badge ms-2"><i class="fas fa-check-circle"></i> Fully Paid</span> }
                            </div>
                            <div class="head-due">Due: <span>&#x20B9;@Model.VenueDue.ToString("N2")</span></div>
                        </div>
                        <div>
                            <div class="head-amount-wrap">
                                <input type="number" id="amt-V" step="0.01" min="0"
                                       max="@Model.VenueDue.ToString("F2")"
                                       value="@(venuePayable ? Model.VenueDue.ToString("F2") : "0.00")"
                                       @(venuePayable ? "" : "disabled")
                                       oninput="recalc()" />
                            </div>
                            <div class="head-btns">
                                <button type="button" onclick="setHead('V',0)">Clear</button>
                                <button type="button" onclick="setHead('V',@Model.VenueDue.ToString("F2")/2)">50%</button>
                                <button type="button" onclick="setHead('V',@Model.VenueDue.ToString("F2"))">Due</button>
                            </div>
                        </div>
                    </div>
                    }

                    @if (hasPackage) {
                    <div class="head-row @(packagePayable ? "active" : "disabled")" id="row-P">
                        <input type="checkbox" class="head-chk" id="chk-P"
                               @(packagePayable ? "checked" : "disabled")
                               onchange="toggleHead('P')" />
                        <div class="head-info">
                            <div class="head-name">
                                <i class="fas fa-utensils me-1" style="color:#0891b2"></i> Package Charges
                                @if (!packagePayable) { <span class="paid-badge ms-2"><i class="fas fa-check-circle"></i> Fully Paid</span> }
                            </div>
                            <div class="head-due">Due: <span>&#x20B9;@Model.PackageDue.ToString("N2")</span></div>
                        </div>
                        <div>
                            <div class="head-amount-wrap">
                                <input type="number" id="amt-P" step="0.01" min="0"
                                       max="@Model.PackageDue.ToString("F2")"
                                       value="@(packagePayable ? Model.PackageDue.ToString("F2") : "0.00")"
                                       @(packagePayable ? "" : "disabled")
                                       oninput="recalc()" />
                            </div>
                            <div class="head-btns">
                                <button type="button" onclick="setHead('P',0)">Clear</button>
                                <button type="button" onclick="setHead('P',@Model.PackageDue.ToString("F2")/2)">50%</button>
                                <button type="button" onclick="setHead('P',@Model.PackageDue.ToString("F2"))">Due</button>
                            </div>
                        </div>
                    </div>
                    }

                    @if (hasAddon) {
                    <div class="head-row @(addonPayable ? "active" : "disabled")" id="row-A">
                        <input type="checkbox" class="head-chk" id="chk-A"
                               @(addonPayable ? "checked" : "disabled")
                               onchange="toggleHead('A')" />
                        <div class="head-info">
                            <div class="head-name">
                                <i class="fas fa-puzzle-piece me-1" style="color:#d97706"></i> Addon Services
                                @if (!addonPayable) { <span class="paid-badge ms-2"><i class="fas fa-check-circle"></i> Fully Paid</span> }
                            </div>
                            <div class="head-due">Due: <span>&#x20B9;@Model.AddonDue.ToString("N2")</span></div>
                        </div>
                        <div>
                            <div class="head-amount-wrap">
                                <input type="number" id="amt-A" step="0.01" min="0"
                                       max="@Model.AddonDue.ToString("F2")"
                                       value="@(addonPayable ? Model.AddonDue.ToString("F2") : "0.00")"
                                       @(addonPayable ? "" : "disabled")
                                       oninput="recalc()" />
                            </div>
                            <div class="head-btns">
                                <button type="button" onclick="setHead('A',0)">Clear</button>
                                <button type="button" onclick="setHead('A',@Model.AddonDue.ToString("F2")/2)">50%</button>
                                <button type="button" onclick="setHead('A',@Model.AddonDue.ToString("F2"))">Due</button>
                            </div>
                        </div>
                    </div>
                    }

                    <div class="amount-row gross mt-2">
                        <span class="ar-lbl"><i class="fas fa-coins me-1"></i> Gross Collecting</span>
                        <span class="ar-val" id="grossDisplay">&#x20B9;0.00</span>
                    </div>
                </div>

                <!-- Discount -->
                <div class="pay-section">
                    <div class="pay-section-hdr"><i class="fas fa-tag"></i> Discount (Optional)</div>
                    <div class="disc-toggle">
                        <label id="lbl-none"    class="active" onclick="setDiscType('None')"><i class="fas fa-ban"></i> None</label>
                        <label id="lbl-percent"                onclick="setDiscType('Percent')"><i class="fas fa-percent"></i> Percentage</label>
                        <label id="lbl-flat"                   onclick="setDiscType('Flat')"><i class="fas fa-indian-rupee-sign"></i> Flat Amount</label>
                    </div>
                    <div id="discPercentRow" style="display:none" class="fg">
                        <label>Discount % <span class="req">*</span></label>
                        <div class="disc-input-row">
                            <input asp-for="DiscountPercent" type="number" step="0.01" min="0" max="100"
                                   id="discPercentInput" placeholder="0.00" oninput="recalc()" />
                            <span class="disc-badge" id="discPercentBadge">&#x20B9;0.00 off</span>
                        </div>
                    </div>
                    <div id="discFlatRow" style="display:none" class="fg">
                        <label>Discount Amount (&#x20B9;) <span class="req">*</span></label>
                        <div class="disc-input-row">
                            <input type="number" step="0.01" min="0" id="discFlatInput" placeholder="0.00" oninput="recalc()" />
                            <span class="disc-badge" id="discFlatBadge">0.00%</span>
                        </div>
                    </div>
                </div>

                <!-- Round Off -->
                <div class="pay-section">
                    <div class="pay-section-hdr"><i class="fas fa-circle-notch"></i> Round Off</div>
                    <label class="roundoff-row">
                        <input type="checkbox" id="chkRoundOff" onchange="recalc()" checked />
                        <span>Apply Round Off (Nearest &#x20B9;)</span>
                        <span class="ro-detail" id="roDetail"></span>
                    </label>
                    <div class="amount-row net mt-2">
                        <span class="ar-lbl"><i class="fas fa-check-circle me-1"></i> Net Payable Now</span>
                        <span class="ar-val" id="netDisplay">&#x20B9;0.00</span>
                    </div>
                </div>

            </div><!-- /pay-col-left -->

            <!-- ─── RIGHT: Payment Method + Fields + Notes ─── -->
            <div class="pay-col">

                <!-- Payment Method (tabs) -->
                <div class="pay-section">
                    <div class="pay-section-hdr"><i class="fas fa-credit-card"></i> Payment Method</div>
                    <div class="pm-tabs" id="pmTabs">
                        <button type="button" class="pm-tab is-active" data-method="Cash"         onclick="setPmMethod(this)">Cash</button>
                        <button type="button" class="pm-tab"           data-method="Card"         onclick="setPmMethod(this)">Card</button>
                        <button type="button" class="pm-tab"           data-method="UPI"          onclick="setPmMethod(this)">UPI</button>
                        <button type="button" class="pm-tab"           data-method="BankTransfer" onclick="setPmMethod(this)">Bank Transfer</button>
                        <button type="button" class="pm-tab"           data-method="Cheque"       onclick="setPmMethod(this)">Cheque</button>
                        <button type="button" class="pm-tab"           data-method="DD"           onclick="setPmMethod(this)">DD</button>
                    </div>

                    <!-- Card fields -->
                    <div class="pm-fields-box three-col" id="cardFields" style="display:none">
                        <div class="fg">
                            <label asp-for="CardType">Card Type <span class="req">*</span></label>
                            <select asp-for="CardType">
                                <option value="">--</option>
                                <option value="Visa">Visa</option>
                                <option value="Mastercard">Mastercard</option>
                                <option value="RuPay">RuPay</option>
                                <option value="Amex">Amex</option>
                            </select>
                        </div>
                        <div class="fg">
                            <label asp-for="CardLastFourDigits">Last 4 Digits <span class="req">*</span></label>
                            <input asp-for="CardLastFourDigits" maxlength="4" placeholder="XXXX" />
                        </div>
                        <div class="fg">
                            <label asp-for="BankId">Bank <span class="req">*</span></label>
                            <select asp-for="BankId">
                                <option value="">-- Select --</option>
                                @foreach (dynamic b in banks)
                                { <option value="@b.Id">@b.BankName</option> }
                            </select>
                        </div>
                    </div>

                    <!-- UPI / Bank Transfer bank pick -->
                    <div class="pm-fields-box" id="bankFields" style="display:none">
                        <div class="fg">
                            <label asp-for="BankId">Bank</label>
                            <select asp-for="BankId" id="bankSelect2">
                                <option value="">-- Select --</option>
                                @foreach (dynamic b in banks)
                                { <option value="@b.Id">@b.BankName</option> }
                            </select>
                        </div>
                    </div>

                    <!-- Cheque / DD fields -->
                    <div class="pm-fields-box" id="chequeFields" style="display:none">
                        <div class="fg">
                            <label asp-for="BankId">Bank <span class="req">*</span></label>
                            <select asp-for="BankId" id="bankSelect3">
                                <option value="">-- Select --</option>
                                @foreach (dynamic b in banks)
                                { <option value="@b.Id">@b.BankName</option> }
                            </select>
                        </div>
                        <div class="fg">
                            <label asp-for="ChequeDate">Cheque Date <span class="req">*</span></label>
                            <input asp-for="ChequeDate" type="date" />
                        </div>
                    </div>
                </div>

                <!-- Reference + Notes -->
                <div class="pay-section">
                    <div class="pay-section-hdr"><i class="fas fa-ellipsis-h"></i> Other Details</div>
                    <div class="fg">
                        <label asp-for="PaymentReference">Reference / UTR / Cheque#</label>
                        <input asp-for="PaymentReference" placeholder="Transaction ID, Cheque No., etc." />
                    </div>
                    <div class="fg">
                        <label asp-for="Remarks">Notes</label>
                        <textarea asp-for="Remarks" rows="3" placeholder="Additional notes (optional)" style="resize:none"></textarea>
                    </div>
                </div>

            </div><!-- /pay-col -->

        </div><!-- /pay-body -->

        <!-- ── Footer ── -->
        <div class="pay-footer">
            <a asp-action="Details" asp-route-id="@Model.BanquetBookingId" class="btn-cancel-link">
                <i class="fas fa-times"></i> Cancel
            </a>
            <button type="submit" class="btn-record">
                <i class="fas fa-check"></i> Record Payment
            </button>
        </div>

    </form>
</div>

@section Scripts {
@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
<script>
(function(){
    const HEADS  = ['V','P','A'];
    let discType = 'None';

    /* ── Billing head toggle ─────────────────────── */
    window.toggleHead = function(code) {
        const chk = document.getElementById('chk-' + code);
        const inp = document.getElementById('amt-' + code);
        const row = document.getElementById('row-' + code);
        if (!inp) return;
        // If the checkbox itself is disabled (due = 0), do nothing
        if (chk && chk.disabled) { chk.checked = false; return; }
        if (chk && chk.checked) {
            inp.disabled = false;
            if (row) { row.classList.add('active'); row.classList.remove('disabled'); }
        } else {
            inp.value = '0'; inp.disabled = true;
            if (row) { row.classList.remove('active'); row.classList.add('disabled'); }
        }
        recalc();
    };

    window.setHead = function(code, val) {
        const inp = document.getElementById('amt-' + code);
        if (!inp || inp.disabled) return;
        inp.value = parseFloat(val || 0).toFixed(2);
        recalc();
    };

    /* ── Recalculate totals ───────────────────────── */
    window.recalc = function() {
        let gross = 0;
        HEADS.forEach(c => {
            const inp = document.getElementById('amt-' + c);
            if (inp && !inp.disabled) gross += parseFloat(inp.value) || 0;
        });
        gross = Math.round(gross * 100) / 100;

        let discAmt = 0;
        if (discType === 'Percent') {
            const pct = parseFloat(document.getElementById('discPercentInput').value) || 0;
            discAmt = Math.round(gross * pct / 100 * 100) / 100;
            document.getElementById('discPercentBadge').textContent = '\u20B9' + discAmt.toFixed(2) + ' off';
        } else if (discType === 'Flat') {
            discAmt = Math.min(parseFloat(document.getElementById('discFlatInput').value) || 0, gross);
            const pct = gross > 0 ? (discAmt / gross * 100) : 0;
            document.getElementById('discFlatBadge').textContent = pct.toFixed(2) + '%';
        }
        document.getElementById('hiddenDiscountAmount').value = discAmt.toFixed(2);

        const chkRO = document.getElementById('chkRoundOff');
        let roAmt   = 0;
        if (chkRO && chkRO.checked) {
            const afterDisc = gross - discAmt;
            const rounded   = Math.round(afterDisc);
            roAmt = Math.round((rounded - afterDisc) * 100) / 100;
            const sign = roAmt >= 0 ? '+' : '';
            document.getElementById('roDetail').textContent =
                'Round Off: ' + sign + '\u20B9' + roAmt.toFixed(2) + ' | Net: \u20B9' + rounded.toFixed(2);
        } else {
            document.getElementById('roDetail').textContent = '';
        }
        document.getElementById('hiddenRoundOff').value = roAmt.toFixed(2);

        const net = Math.max(0, Math.round((gross - discAmt + roAmt) * 100) / 100);
        const fmt = v => '\u20B9' + v.toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2});

        document.getElementById('grossDisplay').textContent = fmt(gross);
        document.getElementById('netDisplay').textContent   = fmt(net);
        document.getElementById('summaryGross').textContent = fmt(gross);
        document.getElementById('summaryNet').textContent   = fmt(net);
    };

    /* ── Discount type ───────────────────────────── */
    window.setDiscType = function(type) {
        discType = type;
        document.getElementById('discTypeInput').value = type;
        ['None','Percent','Flat'].forEach(t =>
            document.getElementById('lbl-' + t.toLowerCase()).classList.toggle('active', t === type));
        document.getElementById('discPercentRow').style.display = type === 'Percent' ? '' : 'none';
        document.getElementById('discFlatRow').style.display    = type === 'Flat'    ? '' : 'none';
        if (type !== 'Percent') { const e = document.getElementById('discPercentInput'); if(e) e.value=''; }
        if (type !== 'Flat')    { const e = document.getElementById('discFlatInput');   if(e) e.value=''; }
        recalc();
    };

    /* ── Payment method tabs ─────────────────────── */
    window.setPmMethod = function(btn) {
        document.querySelectorAll('.pm-tab').forEach(t => t.classList.remove('is-active'));
        btn.classList.add('is-active');
        const m = btn.dataset.method;
        document.getElementById('pmMethodHidden').value = m;
        document.getElementById('cardFields').style.display   = m === 'Card'                        ? '' : 'none';
        document.getElementById('bankFields').style.display   = ['UPI','BankTransfer'].includes(m)  ? '' : 'none';
        document.getElementById('chequeFields').style.display = ['Cheque','DD'].includes(m)         ? '' : 'none';
    };

    /* ── Submit: build head allocations JSON ─────── */
    window.prepareSubmit = function() {
        const allocs = [];
        HEADS.forEach(code => {
            const chk = document.getElementById('chk-' + code);
            const inp = document.getElementById('amt-' + code);
            if (!inp) return;
            if (chk && !chk.checked) return;
            const amt = parseFloat(inp.value) || 0;
            if (amt > 0) allocs.push({ code, amount: amt });
        });
        if (allocs.length === 0) {
            alert('Please select at least one billing head and enter an amount.');
            return false;
        }
        document.getElementById('hiddenHeadAllocations').value = JSON.stringify(allocs);
        return true;
    };

    /* ── Init ────────────────────────────────────── */
    document.getElementById('discTypeInput').value = 'None';
    recalc();
})();
</script>
}
