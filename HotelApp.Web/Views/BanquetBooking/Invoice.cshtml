@model HotelApp.Web.Models.BanquetBooking
@{
    Layout = null;
    var hs = ViewBag.HotelSettings as HotelApp.Web.Models.HotelSettings;
    var isB2B = string.Equals(Model.CustomerType, "B2B", StringComparison.OrdinalIgnoreCase);
    var billToName    = isB2B && !string.IsNullOrWhiteSpace(Model.CompanyName) ? Model.CompanyName : Model.GuestName;
    var billToGSTIN   = isB2B ? Model.CompanyGSTIN : Model.GuestGSTIN;
    var billToAddress = isB2B ? Model.CompanyAddress : Model.GuestAddress;
    var invoiceDate   = DateTime.Today;

    // Totals from payment records
    var payments      = Model.Payments.Where(p => p.Status is "Captured" or "Success").ToList();
    var cashCollected = payments.Where(p => !p.IsRefund).Sum(p => p.Amount)
                      - payments.Where(p =>  p.IsRefund).Sum(p => p.Amount);
    var totalPayDisc  = payments.Where(p => !p.IsRefund).Sum(p => p.DiscountAmount);
    var totalPaid     = cashCollected + totalPayDisc;
    var balanceDue    = Math.Max(0m, Model.TotalAmount - totalPaid);
    var hasPayDisc    = totalPayDisc > 0;

    // Group head-wise rows into single receipt-level rows for the payment history table
    // Use ReceiptGroupNumber when available (head-wise payments share one), else ReceiptNumber
    var paymentRows = payments
        .GroupBy(p => p.ReceiptGroupNumber ?? p.ReceiptNumber)
        .Select(g => new {
            ReceiptNumber    = g.Key,
            PaidOn           = g.Min(p => p.PaidOn),
            PaymentMethod    = g.First().PaymentMethod,
            CardType         = g.First().CardType,
            PaymentReference = g.First().PaymentReference,
            IsAdvancePayment = g.Any(p => p.IsAdvancePayment),
            IsRefund         = g.All(p => p.IsRefund),
            Amount           = g.Sum(p => p.IsRefund ? -p.Amount : p.Amount),
            DiscountAmount   = g.Sum(p => p.DiscountAmount),
            Remarks          = g.First().Remarks
        })
        .OrderBy(g => g.PaidOn)
        .ToList();
    var isCheckedOut = Model.Status == "CheckedOut";
    var isInterState = Model.IsInterState;

    // Line-item GST totals
    var pkgCGST  = Model.PackageLines.Sum(l => l.CGSTAmount);
    var pkgSGST  = Model.PackageLines.Sum(l => l.SGSTAmount);
    var pkgIGST  = Model.PackageLines.Sum(l => l.IGSTAmount);
    var adnCGST  = Model.AddonLines.Sum(l => l.CGSTAmount);
    var adnSGST  = Model.AddonLines.Sum(l => l.SGSTAmount);
    var adnIGST  = Model.AddonLines.Sum(l => l.IGSTAmount);

    // GST rates computed from amounts (venue has no explicit rate field)
    var venCGSTRate = Model.VenueBaseAmount > 0 ? (int)Math.Round(Model.VenueCGSTAmount / Model.VenueBaseAmount * 100) : 0;
    var venIGSTRate = Model.VenueBaseAmount > 0 ? (int)Math.Round(Model.VenueIGSTAmount / Model.VenueBaseAmount * 100) : 0;
    var pkgSAC      = Model.PackageLines.FirstOrDefault()?.SACCode ?? "";
    var adnSAC      = Model.AddonLines.Select(l => l.SACCode).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct().Count() > 1
                      ? "Multiple" : (Model.AddonLines.FirstOrDefault()?.SACCode ?? "");
    var pkgCGSTRate = Model.PackageLines.FirstOrDefault()?.CGSTPercent ?? 0m;
    var pkgSGSTRate = Model.PackageLines.FirstOrDefault()?.SGSTPercent ?? 0m;
    var pkgIGSTRate = Model.PackageLines.FirstOrDefault()?.IGSTPercent ?? 0m;
    var adnCGSTRate = Model.AddonLines.FirstOrDefault()?.CGSTPercent ?? 0m;
    var adnSGSTRate = Model.AddonLines.FirstOrDefault()?.SGSTPercent ?? 0m;
    var adnIGSTRate = Model.AddonLines.FirstOrDefault()?.IGSTPercent ?? 0m;
    // Place of supply derived from supplier GSTIN (mandatory per CGST Rule 46)
    var supplierStateCode = hs?.GSTCode?.Length >= 2 ? hs.GSTCode.Substring(0, 2) : "";
    var placeOfSupply     = !string.IsNullOrWhiteSpace(supplierStateCode)
                            ? $"{GSTStateCodeToName(supplierStateCode)} ({supplierStateCode})"
                            : "—";
    var amtWords    = AmountInWords(Model.TotalAmount);
}
@functions {
    static string AmountInWords(decimal amount)
    {
        if (amount < 0) return "Minus " + AmountInWords(-amount);
        var intPart = (long)Math.Floor(amount);
        var paise   = (int)Math.Round((amount - intPart) * 100);
        var words   = intPart == 0 ? "Zero" : NTW(intPart);
        return words + " Rupees" + (paise > 0 ? " and " + NTW(paise) + " Paise" : " Only");
    }
    static string NTW(long n)
    {
        if (n == 0) return "";
        string[] ones = { "","One","Two","Three","Four","Five","Six","Seven","Eight","Nine",
                          "Ten","Eleven","Twelve","Thirteen","Fourteen","Fifteen","Sixteen",
                          "Seventeen","Eighteen","Nineteen" };
        string[] tens = { "","","Twenty","Thirty","Forty","Fifty","Sixty","Seventy","Eighty","Ninety" };
        if (n >= 10000000) return NTW(n / 10000000) + " Crore " + NTW(n % 10000000);
        if (n >= 100000)   return NTW(n / 100000)   + " Lakh "  + NTW(n % 100000);
        if (n >= 1000)     return NTW(n / 1000)     + " Thousand " + NTW(n % 1000);
        if (n >= 100)      return ones[n / 100] + " Hundred " + NTW(n % 100);
        if (n >= 20)       return tens[n / 10] + (n % 10 > 0 ? " " + ones[n % 10] : "");
        return ones[n];
    }
    // Maps 2-digit GST state code to state name (per GSTIN state code list)
    static string GSTStateCodeToName(string code) => code switch {
        "01" => "Jammu & Kashmir", "02" => "Himachal Pradesh", "03" => "Punjab",
        "04" => "Chandigarh",      "05" => "Uttarakhand",       "06" => "Haryana",
        "07" => "Delhi",           "08" => "Rajasthan",         "09" => "Uttar Pradesh",
        "10" => "Bihar",           "11" => "Sikkim",            "12" => "Arunachal Pradesh",
        "13" => "Nagaland",        "14" => "Manipur",           "15" => "Mizoram",
        "16" => "Tripura",         "17" => "Meghalaya",         "18" => "Assam",
        "19" => "West Bengal",     "20" => "Jharkhand",         "21" => "Odisha",
        "22" => "Chhattisgarh",    "23" => "Madhya Pradesh",    "24" => "Gujarat",
        "25" => "Daman & Diu",     "26" => "Dadra & Nagar Haveli", "27" => "Maharashtra",
        "28" => "Andhra Pradesh",  "29" => "Karnataka",         "30" => "Goa",
        "31" => "Lakshadweep",     "32" => "Kerala",            "33" => "Tamil Nadu",
        "34" => "Puducherry",      "35" => "Andaman & Nicobar", "36" => "Telangana",
        "37" => "Andhra Pradesh",  "38" => "Ladakh",            "97" => "Other Territory",
        _ => code
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Invoice — @(Model.InvoiceNumber ?? Model.BanquetBookingNumber)</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { font-family: 'Segoe UI', -apple-system, Arial, sans-serif; font-size: 12px; color: #1a1a2e; background: #dce3ee; }

/* ── Print setup ─────────────────────────────────────────────────────────── */
@@page { size: A4 portrait; margin: 8mm 10mm; }
@@media print {
    html, body { background: white; }
    .no-print { display: none !important; }
    .invoice-wrapper { box-shadow: none; margin: 0; max-width: 100%; border-radius: 0; }

    /* repeat header on every page */
    .rpt-table thead { display: table-header-group; }
    .rpt-table tbody { display: table-row-group; }
    .rpt-table tfoot { display: table-footer-group; }

    .bill-block, .event-meta, .totals-wrap, .inv-footer { page-break-inside: avoid; break-inside: avoid; }
    table.line-table { page-break-inside: auto; }
    table.line-table tr { page-break-inside: avoid; break-inside: avoid; }
    -webkit-print-color-adjust: exact; print-color-adjust: exact;
}

/* ── Wrapper ─────────────────────────────────────────────────────────────── */
.invoice-wrapper {
    max-width: 850px;
    margin: 20px auto;
    background: #fff;
    border-radius: 4px;
    box-shadow: 0 4px 32px rgba(0,0,0,.15);
    overflow: hidden;
    border-top: 5px solid #0f2b5b;
}

/* ── Header ─────────────────────────────────────────────────────────────── */
.inv-header {
    background: #fff;
    padding: 22px 32px 18px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    border-bottom: 2px solid #e5e7eb;
}
.hotel-block { flex: 1; }
.hotel-block .hotel-name  { font-size: 22px; font-weight: 800; color: #0f2b5b; letter-spacing: -.2px; line-height: 1.2; }
.hotel-block .hotel-meta  { font-size: 10.5px; color: #6b7280; margin-top: 5px; line-height: 1.85; }
.hotel-block .hotel-gstin { font-size: 11px; color: #374151; font-weight: 600; margin-top: 5px; }
.doc-block { text-align: right; flex-shrink: 0; border: 1.5px solid #0f2b5b; border-radius: 6px; padding: 12px 18px; min-width: 215px; }
.doc-block .doc-title { font-size: 15px; font-weight: 800; letter-spacing: .6px; text-transform: uppercase; color: #0f2b5b; padding-bottom: 8px; border-bottom: 1px solid #c7d2fe; margin-bottom: 8px; }
.doc-block .doc-sub  { font-size: 11px; color: #374151; line-height: 2.0; }
.doc-block .doc-sub strong { color: #0f2b5b; }
.final-stamp {
    display: inline-block; margin-top: 8px;
    padding: 3px 12px; background: #dcfce7; border: 1.5px solid #16a34a; border-radius: 4px;
    color: #15803d; font-size: 9.5px; font-weight: 800; letter-spacing: .08em;
    text-transform: uppercase;
}
.proforma-stamp {
    display: inline-block; margin-top: 8px;
    padding: 3px 12px; background: #fffbeb; border: 1.5px dashed #d97706; border-radius: 4px;
    color: #92400e; font-size: 9.5px; font-weight: 800; letter-spacing: .08em;
    text-transform: uppercase;
}

/* ── Bill To / Event Info ─────────────────────────────────────────────────── */
.bill-event-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-bottom: 1px solid #e2e8f0;
}
.bill-block {
    padding: 16px 28px;
}
.bill-block:first-child { border-right: 1px solid #e2e8f0; }
.bill-block .blk-title {
    font-size: 10px; font-weight: 700; color: #0f2b5b;
    text-transform: uppercase; letter-spacing: .08em; margin-bottom: 8px;
    padding-bottom: 4px; border-bottom: 1.5px solid #c7d2fe;
}
.bill-block .blk-name { font-size: 15px; font-weight: 700; color: #1e293b; margin-bottom: 3px; }
.bill-block .blk-line { font-size: 11.5px; color: #475569; line-height: 1.65; }

/* ── Event Meta strip ─────────────────────────────────────────────────────── */
.event-meta {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    background: #eef2ff;
    border-bottom: 1px solid #e5e7eb;
}
.meta-cell {
    padding: 10px 16px;
    border-right: 1px solid #e8edf3;
}
.meta-cell:last-child { border-right: none; }
.meta-cell .mc-label { font-size: 9.5px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: .06em; }
.meta-cell .mc-val   { font-size: 12px; font-weight: 700; color: #1e293b; margin-top: 2px; }

/* ── Body ────────────────────────────────────────────────────────────────── */
.inv-body { padding: 16px 32px 20px; }
.sec-title {
    font-size: 10px; font-weight: 700; color: #0f2b5b;
    text-transform: uppercase; letter-spacing: .09em;
    margin: 16px 0 8px; padding: 6px 10px;
    background: #eef2ff; border-left: 3px solid #0f2b5b;
}
.sec-title:first-child { margin-top: 0; }

/* ── Line-item table ─────────────────────────────────────────────────────── */
table.line-table { width: 100%; border-collapse: collapse; margin-bottom: 4px; }
table.line-table th {
    background: #1e3a5f; color: #e0e7ff;
    font-size: 9.5px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .06em;
    padding: 7px 10px; text-align: left;
}
table.line-table tfoot td {
    padding: 8px 10px; font-weight: 700;
    background: #eef2ff; border-top: 2px solid #0f2b5b; color: #0f2b5b;
}
table.line-table td {
    padding: 8px 10px; font-size: 11.5px;
    border-bottom: 1px solid #f1f5f9; vertical-align: middle; color: #374151;
}
table.line-table tbody tr:nth-child(even) td { background: #f8fafc; }
table.line-table tbody tr:last-child td { border-bottom: none; }
table.line-table .tr { text-align: right !important; }
table.line-table .tc { text-align: center !important; }
.text-muted-sm { color: #94a3b8; font-size: 10px; }
.mono { font-family: 'Courier New', monospace; }

/* ── GST Summary Table (Indian Standard) ────────────────────────────────── */
table.gst-table { width: 100%; border-collapse: collapse; font-size: 11px; margin-bottom: 14px; }
table.gst-table th {
    background: #1e3a5f; color: #e0e7ff;
    font-size: 9.5px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .06em;
    padding: 7px 10px; text-align: left;
}
table.gst-table th.tr { text-align: right; }
table.gst-table td { padding: 7px 10px; border-bottom: 1px solid #e5e7eb; color: #374151; vertical-align: middle; }
table.gst-table td.tr { text-align: right; }
table.gst-table tbody tr:nth-child(even) td { background: #f8fafc; }
table.gst-table tfoot td { font-weight: 700; background: #eef2ff; border-top: 2px solid #0f2b5b; color: #0f2b5b; }
table.gst-table tfoot td.tr { text-align: right; }

/* ── Amount in Words ─────────────────────────────────────────────────────── */
.amt-words {
    background: #f0f4ff; border: 1px solid #c7d2fe; border-radius: 4px;
    padding: 8px 14px; margin-bottom: 14px; font-size: 11.5px; color: #1e3a5f; line-height: 1.7;
}
.amt-words strong { font-weight: 700; }

/* ── Terms Box ───────────────────────────────────────────────────────────── */
.terms-box {
    border: 1px solid #e5e7eb; border-radius: 4px;
    padding: 10px 14px; margin-top: 14px; font-size: 10px; color: #6b7280; line-height: 1.7;
}
.terms-box strong { color: #374151; font-size: 10.5px; }

/* ── Totals ──────────────────────────────────────────────────────────────── */
.totals-wrap { display: flex; justify-content: flex-end; margin-bottom: 14px; }
.totals-box {
    width: 330px; border: 1.5px solid #c7d2fe; border-radius: 6px; overflow: hidden;
}
.t-row {
    display: flex; justify-content: space-between;
    padding: 8px 14px; font-size: 12.5px; border-bottom: 1px solid #f1f5f9;
}
.t-row:last-child { border-bottom: none; }
.t-row.grand {
    background: #0f2b5b; color: #fff; font-size: 14px; font-weight: 800;
    padding: 12px 14px; border-bottom: none;
}
.t-row.paid-row  { color: #16a34a; font-weight: 600; }
.t-row.bal-row   { color: #dc2626; font-weight: 700; font-size: 13.5px; background: #fef2f2; }
.t-row.bal-zero  { color: #16a34a; font-weight: 700; font-size: 13.5px; background: #f0fdf4; }

/* ── Payment history ─────────────────────────────────────────────────────── */
table.pay-table { width: 100%; border-collapse: collapse; font-size: 11px; }
table.pay-table th { background: #1e3a5f; color: #e0e7ff; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; padding: 7px 10px; text-align: left; }
table.pay-table td { padding: 7px 10px; border-bottom: 1px solid #f1f5f9; color: #475569; }
table.pay-table td.tr { text-align: right; }
table.pay-table tr.refund-row td { background: #fff7ed; }
table.pay-table tbody tr:nth-child(even):not(.refund-row) td { background: #f8fafc; }

/* ── Footer ──────────────────────────────────────────────────────────────── */
.inv-footer {
    padding: 14px 28px 18px;
    border-top: 1px solid #e2e8f0;
    background: #f8fafc;
    display: flex; justify-content: space-between; align-items: flex-end;
}
.footer-note { font-size: 10.5px; color: #94a3b8; max-width: 380px; line-height: 1.6; }
.sig-block { text-align: center; font-size: 10.5px; color: #64748b; }
.sig-line  { width: 150px; border-bottom: 1px solid #94a3b8; margin: 0 auto 4px; height: 32px; }

/* ── Print button bar ────────────────────────────────────────────────────── */
.print-bar { text-align: center; padding: 14px; }
.btn-print {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 24px; background: #0f2b5b; color: white;
    border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer;
}
.btn-print:hover { background: #1e3a5f; }
.btn-back {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 18px; background: white; color: #475569;
    border: 1.5px solid #e2e8f0; border-radius: 8px;
    font-size: 13px; font-weight: 600; cursor: pointer;
    text-decoration: none; margin-left: 10px;
}
.btn-back:hover { border-color: #0f2b5b; color: #0f2b5b; }
</style>
</head>
<body>

<!-- Print controls (hidden on print) -->
<div class="print-bar no-print">
    <button class="btn-print" onclick="window.print()">
        <i class="fas fa-print"></i> Print / Save PDF
    </button>
    <a href="@Url.Action("Details", "BanquetBooking", new { id = Model.Id })" class="btn-back">
        <i class="fas fa-arrow-left"></i> Back to Booking
    </a>
</div>

<div class="invoice-wrapper">

    <!-- ── Header ──────────────────────────────────────────────────────── -->
    <div class="inv-header">
        <div class="hotel-block">
            <div class="hotel-name">@(hs?.HotelName ?? "Hotel")</div>
            <div class="hotel-meta">
                @if (!string.IsNullOrWhiteSpace(hs?.Address)) { @hs.Address <text><br /></text> }
                @if (!string.IsNullOrWhiteSpace(hs?.ContactNumber1)) { <text>Tel: @hs.ContactNumber1</text> }
                @if (!string.IsNullOrWhiteSpace(hs?.EmailAddress)) { <text>&nbsp;&nbsp;|&nbsp;&nbsp;@hs.EmailAddress</text> }
            </div>
            @if (!string.IsNullOrWhiteSpace(hs?.GSTCode))
            { <div class="hotel-gstin">GSTIN: @hs.GSTCode</div> }
        </div>
        <div class="doc-block">
            <div class="doc-title">@(isCheckedOut ? "Tax Invoice" : "Proforma Invoice")</div>
            <div class="doc-sub">
                Invoice No.: <strong>@(isCheckedOut ? Model.InvoiceNumber : "—")</strong><br />
                Invoice Date: <strong>@invoiceDate.ToString("dd MMM yyyy")</strong><br />
                Booking Ref.: <strong>@Model.BanquetBookingNumber</strong><br />
                Place of Supply: <strong>@placeOfSupply</strong><br />
                Reverse Charge: <strong>No</strong>
            </div>
            @if (isCheckedOut)
            {
                <div class="final-stamp">&#10003; Original Tax Invoice</div>
            }
            else
            {
                <div class="proforma-stamp">&#9888; Proforma Invoice — Not a Tax Invoice</div>
            }
            <div style="font-size:9px;color:#94a3b8;margin-top:5px;text-align:right;">Original for Recipient</div>
        </div>
    </div>

    <!-- ── Bill To / Booking Info ───────────────────────────────────────── -->
    <div class="bill-event-row">
        <div class="bill-block">
            <div class="blk-title">Bill To</div>
            <div class="blk-name">@billToName</div>
            @if (!string.IsNullOrWhiteSpace(Model.GuestPhone))
            { <div class="blk-line">Phone: @Model.GuestPhone</div> }
            @if (!string.IsNullOrWhiteSpace(Model.GuestEmail))
            { <div class="blk-line">Email: @Model.GuestEmail</div> }
            @if (!string.IsNullOrWhiteSpace(billToAddress))
            { <div class="blk-line">@billToAddress</div> }
            @if (!string.IsNullOrWhiteSpace(billToGSTIN))
            { <div class="blk-line">GSTIN: @billToGSTIN</div> }
            @if (isB2B && !string.IsNullOrWhiteSpace(Model.CompanyPAN))
            { <div class="blk-line">PAN: @Model.CompanyPAN</div> }
        </div>
        <div class="bill-block">
            <div class="blk-title">Event Details</div>
            <div class="blk-name">@Model.EventName</div>
            <div class="blk-line">Event Type: @(Model.EventTypeName ?? "—")</div>
            <div class="blk-line">Venue: @(Model.VenueName ?? "—") @(string.IsNullOrWhiteSpace(Model.VenueType) ? "" : $"({Model.VenueType})")</div>
            <div class="blk-line">Hire Type: @Model.VenueHireType &nbsp;|&nbsp; Meal: @Model.MealType</div>
            <div class="blk-line">Nature of Supply: @(Model.IsInterState ? "Inter-State Supply (IGST)" : "Intra-State Supply (CGST + SGST)")</div>
        </div>
    </div>

    <!-- ── Event Meta strip ─────────────────────────────────────────────── -->
    <div class="event-meta">
        <div class="meta-cell">
            <div class="mc-label">Event Date</div>
            <div class="mc-val">@Model.EventDate.ToString("dd MMM yyyy")</div>
        </div>
        <div class="meta-cell">
            <div class="mc-label">End Date</div>
            <div class="mc-val">@(Model.EventEndDate.HasValue ? Model.EventEndDate.Value.ToString("dd MMM yyyy") : "—")</div>
        </div>
        <div class="meta-cell">
            <div class="mc-label">Time</div>
            <div class="mc-val">
                @(Model.EventStartTime.HasValue ? Model.EventStartTime.Value.ToString("hh\\:mm") : "—")
                –
                @(Model.EventEndTime.HasValue ? Model.EventEndTime.Value.ToString("hh\\:mm") : "—")
            </div>
        </div>
        <div class="meta-cell">
            <div class="mc-label">Expected Pax</div>
            <div class="mc-val">@Model.AttendeeCount</div>
        </div>
        <div class="meta-cell">
            <div class="mc-label">Guarantee Pax</div>
            <div class="mc-val">@Model.GuaranteePax</div>
        </div>
        <div class="meta-cell">
            <div class="mc-label">Customer Type</div>
            <div class="mc-val">@Model.CustomerType</div>
        </div>
    </div>

    <!-- ── Invoice Body ──────────────────────────────────────────────────── -->
    <div class="inv-body">

        <!-- Venue Charge -->
        <div class="sec-title">Venue Charges</div>
        <table class="line-table">
            <thead>
                <tr>
                    <th>Description / Nature of Service</th>
                    <th>Hire Type</th>
                    <th class="tr">Taxable Value (₹)</th>
                    @if (!Model.IsInterState) {
                        <th class="tr">CGST Amt (₹)</th>
                        <th class="tr">SGST Amt (₹)</th>
                    } else {
                        <th class="tr">IGST Amt (₹)</th>
                    }
                    <th class="tr">Total Amount (₹)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><span style="font-weight:600">@(Model.VenueName ?? "Venue")</span>
                        @if (!string.IsNullOrWhiteSpace(Model.VenueType)) { <br /><span class="text-muted-sm">@Model.VenueType</span> }</td>
                    <td>@Model.VenueHireType</td>
                    <td class="tr mono">₹@Model.VenueBaseAmount.ToString("N2")</td>
                    @if (!Model.IsInterState) {
                        <td class="tr mono">₹@Model.VenueCGSTAmount.ToString("N2") <span class="text-muted-sm">(@venCGSTRate%)</span></td>
                        <td class="tr mono">₹@Model.VenueSGSTAmount.ToString("N2") <span class="text-muted-sm">(@venCGSTRate%)</span></td>
                    } else {
                        <td class="tr mono">₹@Model.VenueIGSTAmount.ToString("N2") <span class="text-muted-sm">(@venIGSTRate%)</span></td>
                    }
                    <td class="tr mono" style="font-weight:700">₹@((Model.VenueBaseAmount + Model.VenueGSTAmount).ToString("N2"))</td>
                </tr>
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="2">Total — Venue Hire Charges</td>
                    <td class="tr mono">₹@Model.VenueBaseAmount.ToString("N2")</td>
                    @if (!Model.IsInterState) {
                        <td class="tr mono">₹@Model.VenueCGSTAmount.ToString("N2")</td>
                        <td class="tr mono">₹@Model.VenueSGSTAmount.ToString("N2")</td>
                    } else {
                        <td class="tr mono">₹@Model.VenueIGSTAmount.ToString("N2")</td>
                    }
                    <td class="tr mono">₹@((Model.VenueBaseAmount + Model.VenueGSTAmount).ToString("N2"))</td>
                </tr>
            </tfoot>
        </table>

        <!-- Package Lines -->
        @if (Model.PackageLines.Any())
        {
            <div class="sec-title">Package Charges</div>
            <table class="line-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Description / Package Name</th>
                        <th>Type</th>
                        <th class="tc">Pax</th>
                        <th class="tr">Rate / Pax (₹)</th>
                        <th class="tr">Taxable Value (₹)</th>
                        @if (!Model.IsInterState) {
                            <th class="tr">CGST Amt (₹)</th>
                            <th class="tr">SGST Amt (₹)</th>
                        } else {
                            <th class="tr">IGST Amt (₹)</th>
                        }
                        <th class="tr">Total Amount (₹)</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var idx = 1; }
                    @foreach (var pl in Model.PackageLines)
                    {
                        <tr>
                            <td>@(idx++)</td>
                            <td>
                                <span style="font-weight:600">@pl.PackageName</span>
                                @if (!string.IsNullOrWhiteSpace(pl.SACCode))
                                { <span class="text-muted-sm"> &nbsp;SAC: @pl.SACCode</span> }
                            </td>
                            <td>@pl.PackageType &nbsp;<span class="text-muted-sm">(@pl.MealType)</span></td>
                            <td class="tc mono">@pl.Pax</td>
                            <td class="tr mono">₹@pl.PricePerPax.ToString("N2")</td>
                            <td class="tr mono">₹@pl.BaseAmount.ToString("N2")</td>
                            @if (!Model.IsInterState) {
                                <td class="tr mono">₹@pl.CGSTAmount.ToString("N2") <span class="text-muted-sm">(@pl.CGSTPercent%)</span></td>
                                <td class="tr mono">₹@pl.SGSTAmount.ToString("N2") <span class="text-muted-sm">(@pl.SGSTPercent%)</span></td>
                            } else {
                                <td class="tr mono">₹@pl.IGSTAmount.ToString("N2") <span class="text-muted-sm">(@pl.IGSTPercent%)</span></td>
                            }
                            <td class="tr mono" style="font-weight:700">₹@pl.TotalAmount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="5">Total — Package Charges</td>
                        <td class="tr mono">₹@Model.PackageBaseAmount.ToString("N2")</td>
                        @if (!Model.IsInterState) {
                            <td class="tr mono">₹@pkgCGST.ToString("N2")</td>
                            <td class="tr mono">₹@pkgSGST.ToString("N2")</td>
                        } else {
                            <td class="tr mono">₹@pkgIGST.ToString("N2")</td>
                        }
                        <td class="tr mono">₹@(Model.PackageBaseAmount + Model.PackageGSTAmount).ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        }
        @if (Model.AddonLines.Any())
        {
            <div class="sec-title">Additional Services</div>
            <table class="line-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Description / Service Name</th>
                        <th>Type</th>
                        <th class="tc">Qty</th>
                        <th class="tr">Rate (₹)</th>
                        <th class="tr">Taxable Value (₹)</th>
                        @if (!Model.IsInterState) {
                            <th class="tr">CGST Amt (₹)</th>
                            <th class="tr">SGST Amt (₹)</th>
                        } else {
                            <th class="tr">IGST Amt (₹)</th>
                        }
                        <th class="tr">Total Amount (₹)</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var adnIdx = 1; }
                    @foreach (var al in Model.AddonLines)
                    {
                        <tr>
                            <td>@(adnIdx++)</td>
                            <td>
                                <span style="font-weight:600">@al.ServiceName</span>
                                @if (!string.IsNullOrWhiteSpace(al.SACCode))
                                { <span class="text-muted-sm"> &nbsp;SAC: @al.SACCode</span> }
                                @if (!string.IsNullOrWhiteSpace(al.Notes))
                                { <div class="text-muted-sm">@al.Notes</div> }
                            </td>
                            <td>@al.ServiceType</td>
                            <td class="tc mono">@al.Qty.ToString("N0") <span class="text-muted-sm">(@al.RateType)</span></td>
                            <td class="tr mono">₹@al.Rate.ToString("N2")</td>
                            <td class="tr mono">₹@al.BaseAmount.ToString("N2")</td>
                            @if (!Model.IsInterState) {
                                <td class="tr mono">₹@al.CGSTAmount.ToString("N2") <span class="text-muted-sm">(@al.CGSTPercent%)</span></td>
                                <td class="tr mono">₹@al.SGSTAmount.ToString("N2") <span class="text-muted-sm">(@al.SGSTPercent%)</span></td>
                            } else {
                                <td class="tr mono">₹@al.IGSTAmount.ToString("N2") <span class="text-muted-sm">(@al.IGSTPercent%)</span></td>
                            }
                            <td class="tr mono" style="font-weight:700">₹@al.TotalAmount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="5">Total — Additional Services</td>
                        <td class="tr mono">₹@Model.AddonBaseAmount.ToString("N2")</td>
                        @if (!Model.IsInterState) {
                            <td class="tr mono">₹@adnCGST.ToString("N2")</td>
                            <td class="tr mono">₹@adnSGST.ToString("N2")</td>
                        } else {
                            <td class="tr mono">₹@adnIGST.ToString("N2")</td>
                        }
                        <td class="tr mono">₹@(Model.AddonBaseAmount + Model.AddonGSTAmount).ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        }

        <!-- GST Summary -->
        @{
            var hasCGST = !Model.IsInterState && Model.TotalCGSTAmount > 0;
            var hasSGST = !Model.IsInterState && Model.TotalSGSTAmount > 0;
            var hasIGST =  Model.IsInterState && Model.TotalIGSTAmount > 0;
        }
        @if (hasCGST || hasSGST || hasIGST)
        {
            <div class="sec-title">Tax Summary — SAC-wise Breakup (as per CGST Act)</div>
            <table class="gst-table">
                <thead>
                    <tr>
                        <th>SAC Code</th>
                        <th>Description</th>
                        <th class="tr">Taxable Value ₹</th>
                        @if (!Model.IsInterState) {
                            <th class="tr">CGST %</th><th class="tr">CGST ₹</th>
                            <th class="tr">SGST %</th><th class="tr">SGST ₹</th>
                        } else {
                            <th class="tr">IGST %</th><th class="tr">IGST ₹</th>
                        }
                        <th class="tr">Total Tax ₹</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.VenueBaseAmount > 0)
                    {
                        <tr>
                            <td class="text-muted-sm">—</td>
                            <td>Venue Hire</td>
                            <td class="tr mono">@Model.VenueBaseAmount.ToString("N2")</td>
                            @if (!Model.IsInterState) {
                                <td class="tr">@venCGSTRate%</td><td class="tr mono">@Model.VenueCGSTAmount.ToString("N2")</td>
                                <td class="tr">@venCGSTRate%</td><td class="tr mono">@Model.VenueSGSTAmount.ToString("N2")</td>
                            } else {
                                <td class="tr">@venIGSTRate%</td><td class="tr mono">@Model.VenueIGSTAmount.ToString("N2")</td>
                            }
                            <td class="tr mono" style="font-weight:600">@Model.VenueGSTAmount.ToString("N2")</td>
                        </tr>
                    }
                    @if (Model.PackageBaseAmount > 0)
                    {
                        <tr>
                            <td class="text-muted-sm">@pkgSAC</td>
                            <td>Package Charges</td>
                            <td class="tr mono">@Model.PackageBaseAmount.ToString("N2")</td>
                            @if (!Model.IsInterState) {
                                <td class="tr">@pkgCGSTRate%</td><td class="tr mono">@pkgCGST.ToString("N2")</td>
                                <td class="tr">@pkgSGSTRate%</td><td class="tr mono">@pkgSGST.ToString("N2")</td>
                            } else {
                                <td class="tr">@pkgIGSTRate%</td><td class="tr mono">@pkgIGST.ToString("N2")</td>
                            }
                            <td class="tr mono" style="font-weight:600">@Model.PackageGSTAmount.ToString("N2")</td>
                        </tr>
                    }
                    @if (Model.AddonBaseAmount > 0)
                    {
                        <tr>
                            <td class="text-muted-sm">@adnSAC</td>
                            <td>Additional Services</td>
                            <td class="tr mono">@Model.AddonBaseAmount.ToString("N2")</td>
                            @if (!Model.IsInterState) {
                                <td class="tr">@adnCGSTRate%</td><td class="tr mono">@adnCGST.ToString("N2")</td>
                                <td class="tr">@adnSGSTRate%</td><td class="tr mono">@adnSGST.ToString("N2")</td>
                            } else {
                                <td class="tr">@adnIGSTRate%</td><td class="tr mono">@adnIGST.ToString("N2")</td>
                            }
                            <td class="tr mono" style="font-weight:600">@Model.AddonGSTAmount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="2">Total</td>
                        <td class="tr mono">@Model.TotalBaseAmount.ToString("N2")</td>
                        @if (!Model.IsInterState) {
                            <td class="tr"></td><td class="tr mono">@Model.TotalCGSTAmount.ToString("N2")</td>
                            <td class="tr"></td><td class="tr mono">@Model.TotalSGSTAmount.ToString("N2")</td>
                        } else {
                            <td class="tr"></td><td class="tr mono">@Model.TotalIGSTAmount.ToString("N2")</td>
                        }
                        <td class="tr mono">@Model.TotalGSTAmount.ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        }

        <!-- Totals -->
        <div class="totals-wrap">
            <div class="totals-box">
                <div class="t-row"><span>Venue Hire Charges (Taxable)</span><span class="mono">₹@Model.VenueBaseAmount.ToString("N2")</span></div>
                @if (Model.PackageBaseAmount > 0)
                { <div class="t-row"><span>Package Charges (Taxable)</span><span class="mono">₹@Model.PackageBaseAmount.ToString("N2")</span></div> }
                @if (Model.AddonBaseAmount > 0)
                { <div class="t-row"><span>Additional Services (Taxable)</span><span class="mono">₹@Model.AddonBaseAmount.ToString("N2")</span></div> }
                <div class="t-row" style="color:#64748b;font-size:11.5px"><span>Total Taxable Value</span><span class="mono">₹@Model.TotalBaseAmount.ToString("N2")</span></div>
                @if (hasCGST)
                {
                    <div class="t-row" style="color:#64748b;font-size:11.5px"><span>CGST</span><span class="mono">₹@Model.TotalCGSTAmount.ToString("N2")</span></div>
                    <div class="t-row" style="color:#64748b;font-size:11.5px"><span>SGST</span><span class="mono">₹@Model.TotalSGSTAmount.ToString("N2")</span></div>
                }
                @if (hasIGST)
                { <div class="t-row" style="color:#64748b;font-size:11.5px"><span>IGST</span><span class="mono">₹@Model.TotalIGSTAmount.ToString("N2")</span></div> }
                @if (Model.ServiceChargeAmount > 0)
                { <div class="t-row"><span>Service Charge</span><span class="mono">₹@Model.ServiceChargeAmount.ToString("N2")</span></div> }
                @if (Model.DiscountAmount > 0)
                { <div class="t-row" style="color:#16a34a"><span>Discount</span><span class="mono">-₹@Model.DiscountAmount.ToString("N2")</span></div> }
                @if (Model.RoundOffAmount != 0)
                { <div class="t-row" style="color:#64748b;font-size:11.5px"><span>Round-Off</span><span class="mono">₹@Model.RoundOffAmount.ToString("N2")</span></div> }
                <div class="t-row grand"><span>Invoice Total (Incl. GST)</span><span class="mono">₹@Model.TotalAmount.ToString("N2")</span></div>
                <div class="t-row paid-row"><span>Amount Received</span><span class="mono">₹@cashCollected.ToString("N2")</span></div>
                @if (hasPayDisc)
                {
                    <div class="t-row" style="color:#16a34a;font-size:11.5px"><span><i class="fas fa-tag me-1"></i> Payment Discount</span><span class="mono">₹@totalPayDisc.ToString("N2")</span></div>
                    <div class="t-row paid-row" style="border-top:1px dashed #bbf7d0;padding-top:9px;font-weight:700"><span>Total Amount Settled</span><span class="mono">₹@totalPaid.ToString("N2")</span></div>
                }
                @if (balanceDue > 0)
                { <div class="t-row bal-row"><span>Balance Due</span><span class="mono">₹@balanceDue.ToString("N2")</span></div> }
                else
                { <div class="t-row bal-zero"><span>Balance Due</span><span class="mono">₹0.00</span></div> }
            </div>
        </div>

        <!-- Amount in Words -->
        <div class="amt-words">
            <strong>Invoice Amount in Words (INR):</strong> @amtWords
        </div>

        <!-- Payment History -->
        @if (payments.Any())
        {
            <div class="sec-title">Payment History</div>
            <table class="pay-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Receipt No.</th>
                        <th>Date</th>
                        <th>Method</th>
                        <th>Reference</th>
                        <th class="tr">Amount</th>
                        @if (hasPayDisc) { <th class="tr">Discount</th> }
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var pi = 1; }
                    @foreach (var p in paymentRows)
                    {
                        <tr class="@(p.IsRefund ? "refund-row" : "")">
                            <td>@(pi++)</td>
                            <td>@p.ReceiptNumber</td>
                            <td>@p.PaidOn.ToString("dd MMM yyyy")</td>
                            <td>@p.PaymentMethod @(string.IsNullOrWhiteSpace(p.CardType) ? "" : $"({p.CardType})")</td>
                            <td>@(p.PaymentReference ?? "—")</td>
                            <td class="tr mono @(p.Amount < 0 ? "text-danger" : "")">
                                @(p.Amount < 0 ? "-" : "")₹@Math.Abs(p.Amount).ToString("N2")
                            </td>
                            @if (hasPayDisc)
                            {
                                <td class="tr mono" style="color:#16a34a">
                                    @if (p.DiscountAmount > 0) { <text>₹@p.DiscountAmount.ToString("N2")</text> } else { <text>—</text> }
                                </td>
                            }
                            <td>@(p.Remarks ?? (p.IsAdvancePayment ? "Advance" : p.IsRefund ? "Refund" : "—"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="terms-box">
            <strong>Declaration &amp; Terms:</strong>
            We declare that this invoice shows the actual price of the services described and that all particulars are true and correct.<br />
            GST charged is in accordance with the applicable provisions of the CGST/SGST/IGST Act 2017 and the rules made thereunder.
            This supply does not attract Reverse Charge under Section 9(3) / 9(4) of the CGST Act.
            Payment is subject to the hotel's Cancellation &amp; Refund Policy. All disputes are subject to the jurisdiction of the courts
            at the place of supply. This is a computer-generated Tax Invoice and is valid without a physical signature.
        </div>

    </div><!-- /inv-body -->

    <!-- ── Footer ──────────────────────────────────────────────── -->
    <div class="inv-footer">
        <div class="footer-note">
            <strong>Thank you for choosing @(hs?.HotelName ?? "us")!</strong><br />
            GSTIN: @(hs?.GSTCode ?? "—") &nbsp;|&nbsp; Tel: @(hs?.ContactNumber1 ?? "") &nbsp;|&nbsp; @(hs?.EmailAddress ?? "")<br />
            <span style="font-size:9.5px;color:#b0b8c9;">This is an electronically generated Tax Invoice — Original for Recipient.</span>
        </div>
        <div class="sig-block">
            <div class="sig-line"></div>
            <div>Authorised Signatory</div>
            <div style="font-weight:700;margin-top:2px">@(hs?.HotelName ?? "Hotel")</div>
        </div>
    </div>

</div><!-- /invoice-wrapper -->

</body>
</html>
