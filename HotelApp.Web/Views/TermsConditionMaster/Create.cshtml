@model HotelApp.Web.Models.B2BTermsCondition
@{
    ViewData["Title"] = "Create Terms & Conditions";
}

<div class="page-header agreement-page-header">
    <div>
        <h2><i class="fas fa-scroll"></i> Terms &amp; Conditions Master</h2>
        <p class="text-muted mb-0">Create reusable legal and commercial clauses for B2B agreements.</p>
    </div>
    <a asp-action="Index" class="btn-cancel"><i class="fas fa-arrow-left"></i> Back to Terms List</a>
</div>

<form asp-action="Create" method="post" class="agreement-shell">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
    <partial name="_TermsConditionFormFields" model="Model" />
    <div class="agreement-actions">
        <a asp-action="Index" class="btn-cancel"><i class="fas fa-times"></i> Cancel</a>
        <button type="submit" class="btn-save"><i class="fas fa-save"></i> Save Terms</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}