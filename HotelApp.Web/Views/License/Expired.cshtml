@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>eLUX Stay | License Expired</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #1a0535 0%, #2d0a5e 40%, #4a1a8c 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,.35);
            max-width: 540px;
            width: 90%;
            padding: 48px 40px;
            text-align: center;
        }
        .icon { font-size: 4rem; color: #e53935; margin-bottom: 20px; }
        h1 { color: #333; font-size: 1.6rem; margin: 0 0 12px; }
        p  { color: #666; font-size: .95rem; line-height: 1.6; margin: 0 0 16px; }
        .contact-box {
            background: #fff8f8;
            border: 1.5px solid #ffcdd2;
            border-radius: 10px;
            padding: 16px 20px;
            margin: 20px auto 0;
            font-size: .88rem;
            color: #555;
        }
        .contact-box strong { color: #c62828; display: block; margin-bottom: 4px; }
        .brand {
            margin-bottom: 24px;
            font-size: 1.3rem;
            font-weight: 700;
            color: #6c3fe8;
            letter-spacing: 1px;
        }
        .brand span { color: #9b59b6; }
    </style>
</head>
<body>
    <div class="card">
        <div class="brand"><i class="fas fa-hotel"></i> eLUX <span>Stay</span></div>
        <div class="icon"><i class="fas fa-calendar-times"></i></div>
        <h1>License Expired</h1>
        <p>
            Your eLUX Stay software license has expired. The application is currently
            unavailable until the license is renewed.
        </p>
        <p>
            Please contact your software vendor or system administrator to renew your
            license and restore access.
        </p>
        <div class="contact-box">
            <strong><i class="fas fa-headset"></i> &nbsp;Need Help?</strong>
            Contact your authorized eLUX Stay reseller or email
            <a href="mailto:support@eluxstay.com">support@eluxstay.com</a>
            with your Client Code to initiate renewal.
        </div>
    </div>
</body>
</html>
