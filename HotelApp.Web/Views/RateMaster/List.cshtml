@model IEnumerable<HotelApp.Web.Models.RateMaster>
@{
    ViewData["Title"] = "Rate Master";
}

<div class="page-header">
    <h2><i class="fas fa-tags"></i> Rate Master</h2>
    <a asp-action="Create" class="btn-create">
        <i class="fas fa-plus"></i> Add New Rate
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        <i class="fas fa-check-circle"></i>
        @TempData["SuccessMessage"]
    </div>
}

@if (Model.Any())
{
    <div class="filter-bar" style="display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end; margin-bottom:16px; background:#f8f9fa; padding:14px 18px; border-radius:8px; border:1px solid #e2e8f0;">
        <div style="display:flex; flex-direction:column; gap:4px; min-width:160px;">
            <label style="font-size:12px; font-weight:600; color:#4a5568; text-transform:uppercase; letter-spacing:.5px;">Room Type</label>
            <select id="filterRoomType" class="form-select" style="border:1px solid #cbd5e0; border-radius:6px; padding:6px 10px; font-size:13px; background:#fff; color:#2d3748; cursor:pointer;">
                <option value="">All Room Types</option>
            </select>
        </div>
        <div style="display:flex; flex-direction:column; gap:4px; min-width:160px;">
            <label style="font-size:12px; font-weight:600; color:#4a5568; text-transform:uppercase; letter-spacing:.5px;">Customer Type</label>
            <select id="filterCustomerType" class="form-select" style="border:1px solid #cbd5e0; border-radius:6px; padding:6px 10px; font-size:13px; background:#fff; color:#2d3748; cursor:pointer;">
                <option value="">All Customer Types</option>
            </select>
        </div>
        <div style="display:flex; flex-direction:column; gap:4px; min-width:160px;">
            <label style="font-size:12px; font-weight:600; color:#4a5568; text-transform:uppercase; letter-spacing:.5px;">Source</label>
            <select id="filterSource" class="form-select" style="border:1px solid #cbd5e0; border-radius:6px; padding:6px 10px; font-size:13px; background:#fff; color:#2d3748; cursor:pointer;">
                <option value="">All Sources</option>
            </select>
        </div>
        <div style="display:flex; align-items:flex-end;">
            <button id="clearRateFilters" onclick="clearRateFilters()" style="padding:6px 16px; border:1px solid #cbd5e0; border-radius:6px; background:#fff; color:#4a5568; font-size:13px; cursor:pointer; display:none;">
                <i class="fas fa-times"></i> Clear
            </button>
        </div>
        <div style="margin-left:auto; display:flex; align-items:flex-end;">
            <span id="filterResultCount" style="font-size:13px; color:#718096;"></span>
        </div>
    </div>

    <div class="table-container">
        <table class="data-table" id="rateMasterTable">
            <thead>
                <tr>
                    <th>Room Type</th>
                    <th>Customer Type</th>
                    <th>Source</th>
                    <th>Meal Type</th>
                    <th>Base Rate</th>
                    <th>Extra Pax Rate</th>
                    <th>Tax %</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Weekday Rate?</th>
                    <th>Apply Discount</th>
                    <th>Dynamic Rate?</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rate in Model)
                {
                    <tr>
                        <td><strong>@rate.RoomType?.TypeName</strong></td>
                        <td>@rate.CustomerType</td>
                        <td>@rate.Source</td>
                        <td>@(rate.MealType ?? "EP")</td>
                        <td>₹@rate.BaseRate.ToString("N0")</td>
                        <td>₹@rate.ExtraPaxRate.ToString("N0")</td>
                        <td>@rate.TaxPercentage%</td>
                        <td>@rate.StartDate.ToString("dd/MM/yyyy")</td>
                        <td>@rate.EndDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (rate.IsWeekdayRate)
                            {
                                <span class="badge badge-active"><i class="fas fa-check"></i> Yes</span>
                            }
                            else
                            {
                                <span class="badge badge-inactive"><i class="fas fa-times"></i> No</span>
                            }
                        </td>
                        <td>@(rate.ApplyDiscount ?? "-")</td>
                        <td>
                            @if (rate.IsDynamicRate)
                            {
                                <span class="badge badge-active"><i class="fas fa-check"></i> Yes</span>
                            }
                            else
                            {
                                <span class="badge badge-inactive"><i class="fas fa-times"></i> No</span>
                            }
                        </td>
                        <td>
                            @if (rate.IsActive)
                            {
                                <span class="badge badge-available">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-maintenance">Inactive</span>
                            }
                        </td>
                        <td>
                            <div class="action-buttons">
                                <a asp-action="Details" asp-route-id="@rate.Id" class="btn-action btn-view" title="View Rate">
                                    <i class="fas fa-eye"></i>
                                    <span>View</span>
                                </a>
                                <a asp-action="Edit" asp-route-id="@rate.Id" class="btn-action btn-edit" title="Edit Rate">
                                    <i class="fas fa-pen"></i>
                                    <span>Edit</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="empty-state">
        <i class="fas fa-tags"></i>
        <h3>No Rates Found</h3>
        <p>Get started by adding your first rate configuration</p>
        <a asp-action="Create" class="btn-create">
            <i class="fas fa-plus"></i> Add New Rate
        </a>
    </div>
}

@section Scripts {
<script>
(function () {
    var table = document.getElementById('rateMasterTable');
    if (!table) return;

    var rows = Array.from(table.querySelectorAll('tbody tr'));

    // Column indices: 0=RoomType, 1=CustomerType, 2=Source
    function getColText(row, idx) {
        var cell = row.cells[idx];
        return cell ? cell.innerText.trim() : '';
    }

    function populateFilter(selectId, colIdx) {
        var sel = document.getElementById(selectId);
        if (!sel) return;
        var values = new Set();
        rows.forEach(function (r) { values.add(getColText(r, colIdx)); });
        values.forEach(function (v) {
            if (!v) return;
            var opt = document.createElement('option');
            opt.value = v; opt.textContent = v;
            sel.appendChild(opt);
        });
    }

    populateFilter('filterRoomType', 0);
    populateFilter('filterCustomerType', 1);
    populateFilter('filterSource', 2);

    function applyFilters() {
        var rt  = document.getElementById('filterRoomType').value.toLowerCase();
        var ct  = document.getElementById('filterCustomerType').value.toLowerCase();
        var src = document.getElementById('filterSource').value.toLowerCase();
        var visible = 0;

        rows.forEach(function (r) {
            var match =
                (!rt  || getColText(r, 0).toLowerCase() === rt)  &&
                (!ct  || getColText(r, 1).toLowerCase() === ct)  &&
                (!src || getColText(r, 2).toLowerCase() === src);
            r.style.display = match ? '' : 'none';
            if (match) visible++;
        });

        var anyFilter = rt || ct || src;
        var clearBtn = document.getElementById('clearRateFilters');
        if (clearBtn) clearBtn.style.display = anyFilter ? '' : 'none';

        var countEl = document.getElementById('filterResultCount');
        if (countEl) countEl.textContent = anyFilter ? 'Showing ' + visible + ' of ' + rows.length + ' record(s)' : '';
    }

    ['filterRoomType', 'filterCustomerType', 'filterSource'].forEach(function (id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('change', applyFilters);
    });

    window.clearRateFilters = function () {
        ['filterRoomType', 'filterCustomerType', 'filterSource'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) el.value = '';
        });
        applyFilters();
    };
})();
</script>
}
