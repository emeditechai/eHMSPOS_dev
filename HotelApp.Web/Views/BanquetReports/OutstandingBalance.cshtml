@using HotelApp.Web.Repositories
@model HotelApp.Web.ViewModels.BanquetOutstandingViewModel
@{
    ViewData["Title"] = "Banquet Outstanding Balance";
}

<div class="page-header">
    <h2><i class="fas fa-clock"></i> Banquet Outstanding Balance</h2>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body">
                <div class="text-muted small">Total Bookings With Balance</div>
                <div class="h4 fw-bold text-primary">@Model.Rows.Count()</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body">
                <div class="text-muted small">Total Outstanding</div>
                <div class="h4 fw-bold text-danger">₹@Model.TotalOutstanding.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body">
                <div class="text-muted small">Overdue (past event date)</div>
                <div class="h4 fw-bold text-warning">@Model.Rows.Count(r => r.DaysElapsed > 0)</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header fw-600"><i class="fas fa-list"></i> Outstanding Bookings</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table data-table mb-0">
                <thead>
                    <tr>
                        <th>Booking #</th><th>Event Date</th><th>Event Name</th><th>Client</th>
                        <th>Type</th><th>Phone</th><th>Total ₹</th><th>Paid ₹</th>
                        <th>Balance ₹</th><th>Credit Days</th><th>Days Elapsed</th><th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Rows)
                    {
                        var isOverdue = r.DaysElapsed > r.CreditDays;
                        <tr class="@(isOverdue ? "table-warning" : "")">
                            <td>
                                <a asp-controller="BanquetBooking" asp-action="Details"
                                   asp-route-id="0" class="fw-600">
                                   <code>@r.BanquetBookingNumber</code>
                                </a>
                            </td>
                            <td>@r.EventDate.ToString("dd MMM yyyy")</td>
                            <td>@r.EventName</td>
                            <td>@r.ClientName</td>
                            <td><span class="badge @(r.CustomerType == "B2B" ? "bg-info" : "bg-secondary")">@r.CustomerType</span></td>
                            <td>@r.GuestPhone</td>
                            <td>@r.TotalAmount.ToString("N2")</td>
                            <td>@r.DepositAmount.ToString("N2")</td>
                            <td class="fw-600 text-danger">@r.BalanceAmount.ToString("N2")</td>
                            <td>@r.CreditDays</td>
                            <td class="@(isOverdue ? "text-danger fw-600" : "")">@r.DaysElapsed</td>
                            <td><span class="badge @(r.Status == "Confirmed" ? "bg-primary" : r.Status == "EventComplete" ? "bg-success" : "bg-secondary")">@r.Status</span></td>
                        </tr>
                    }
                    @if (!Model.Rows.Any())
                    {
                        <tr><td colspan="12" class="text-center text-muted py-4">
                            <i class="fas fa-check-circle text-success fa-2x mb-2"></i><br/>
                            No outstanding balances. All bookings are settled.
                        </td></tr>
                    }
                </tbody>
                @if (Model.Rows.Any())
                {
                    <tfoot class="table-light fw-600">
                        <tr>
                            <td colspan="8">Total Outstanding</td>
                            <td class="text-danger">₹@Model.TotalOutstanding.ToString("N2")</td>
                            <td colspan="3"></td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
</div>
