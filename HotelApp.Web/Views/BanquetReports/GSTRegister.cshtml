@using HotelApp.Web.Repositories
@model HotelApp.Web.ViewModels.BanquetGSTRegisterViewModel
@{
    ViewData["Title"] = "Banquet GST Register";
}

<div class="page-header">
    <h2><i class="fas fa-file-invoice"></i> Banquet GST Register</h2>
</div>

<form method="get" class="filter-bar mb-4">
    <div class="filter-grid">
        <div class="master-form-group">
            <label>Payment Received From</label>
            <input type="date" name="fromDate" class="form-control" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
        </div>
        <div class="master-form-group">
            <label>Payment Received To</label>
            <input type="date" name="toDate" class="form-control" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
        </div>
        <div class="master-form-group" style="align-self:flex-end">
            <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Apply</button>
        </div>
    </div>
</form>

<!-- GST Summary Row -->
<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:24px">
    <div style="background:#fff;border-radius:12px;padding:18px 20px;border-left:4px solid #4f46e5;box-shadow:0 2px 8px rgba(0,0,0,.08)">
        <div style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px">Taxable Value</div>
        <div style="font-size:22px;font-weight:800;color:#4f46e5">₹@Model.TotalTaxableValue.ToString("N2")</div>
    </div>
    <div style="background:#fff;border-radius:12px;padding:18px 20px;border-left:4px solid #0891b2;box-shadow:0 2px 8px rgba(0,0,0,.08)">
        <div style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px">Total CGST</div>
        <div style="font-size:22px;font-weight:800;color:#0891b2">₹@Model.TotalCGST.ToString("N2")</div>
    </div>
    <div style="background:#fff;border-radius:12px;padding:18px 20px;border-left:4px solid #0891b2;box-shadow:0 2px 8px rgba(0,0,0,.08)">
        <div style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px">Total SGST</div>
        <div style="font-size:22px;font-weight:800;color:#0891b2">₹@Model.TotalSGST.ToString("N2")</div>
    </div>
    <div style="background:#fff;border-radius:12px;padding:18px 20px;border-left:4px solid #d97706;box-shadow:0 2px 8px rgba(0,0,0,.08)">
        <div style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px">Total IGST</div>
        <div style="font-size:22px;font-weight:800;color:#d97706">₹@Model.TotalIGST.ToString("N2")</div>
    </div>
    <div style="background:#fff;border-radius:12px;padding:18px 20px;border-left:4px solid #059669;box-shadow:0 2px 8px rgba(0,0,0,.08)">
        <div style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px">Total GST</div>
        <div style="font-size:22px;font-weight:800;color:#059669">₹@Model.TotalGST.ToString("N2")</div>
    </div>
</div>

<div class="card">
    <div class="card-header fw-600 d-flex justify-content-between align-items-center">
        <span><i class="fas fa-table"></i> GST Details</span>
        <button onclick="exportGST()" class="btn btn-sm btn-outline-success"><i class="fas fa-file-excel"></i> Export</button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table data-table mb-0" id="gstTable">
                <thead>
                    <tr>
                        <th>Receipt #</th><th>Booking #</th><th>Payment Date</th><th>Event Date</th><th>Client</th><th>Type</th>
                        <th>Supply</th><th>Line</th><th>SAC</th>
                        <th>Taxable ₹</th><th>CGST ₹</th><th>SGST ₹</th><th>IGST ₹</th><th>Total GST ₹</th><th>Total Paid ₹</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Rows)
                    {
                        <tr>
                            <td class="text-muted" style="font-size:11px">@r.ReceiptNumber</td>
                            <td><code>@r.BanquetBookingNumber</code></td>
                            <td>@(r.PaymentDate.HasValue ? r.PaymentDate.Value.ToString("dd MMM yyyy") : "—")</td>
                            <td>@r.EventDate.ToString("dd MMM yyyy")</td>
                            <td>@r.ClientName</td>
                            <td><span class="badge @(r.CustomerType == "B2B" ? "bg-info" : "bg-secondary")">@r.CustomerType</span></td>
                            <td>@r.SupplyType</td>
                            <td>@r.LineType</td>
                            <td class="text-muted">@r.SACCode</td>
                            <td>@r.TaxableValue.ToString("N2")</td>
                            <td>@r.CGST.ToString("N2")</td>
                            <td>@r.SGST.ToString("N2")</td>
                            <td>@r.IGST.ToString("N2")</td>
                            <td class="fw-600">@r.TotalGST.ToString("N2")</td>
                            <td class="fw-600 text-success">@((r.TaxableValue + r.TotalGST).ToString("N2"))</td>
                        </tr>
                    }
                    @if (!Model.Rows.Any())
                    {
                        <tr><td colspan="15" class="text-center text-muted py-4">No payments received in this period.</td></tr>
                    }
                </tbody>
                <tfoot class="table-light fw-600">
                    <tr>
                        <td colspan="9">Total</td>
                        <td>@Model.TotalTaxableValue.ToString("N2")</td>
                        <td>@Model.TotalCGST.ToString("N2")</td>
                        <td>@Model.TotalSGST.ToString("N2")</td>
                        <td>@Model.TotalIGST.ToString("N2")</td>
                        <td>@Model.TotalGST.ToString("N2")</td>
                        <td>@((Model.TotalTaxableValue + Model.TotalGST).ToString("N2"))</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
function exportGST() {
    let html = document.getElementById('gstTable').outerHTML;
    let blob = new Blob([html], {type:'application/vnd.ms-excel'});
    let url  = URL.createObjectURL(blob);
    let a    = document.createElement('a');
    a.href = url;
    a.download = 'banquet-gst-@Model.FromDate.ToString("yyyyMMdd")-to-@Model.ToDate.ToString("yyyyMMdd")' + '.xls';
    a.click();
}
</script>
}
