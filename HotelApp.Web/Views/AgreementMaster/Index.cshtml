@model IEnumerable<HotelApp.Web.Models.B2BAgreement>
@{
    ViewData["Title"] = "Agreement Master";
    var rows = Model?.ToList() ?? new List<HotelApp.Web.Models.B2BAgreement>();
    var activeCount = rows.Count(x => x.IsActive);
    var totalClients = rows.Sum(x => x.AssignedClientCount);
    var pendingApprovals = rows.Count(x => !string.Equals(x.ApprovalStatus, "Approved", StringComparison.OrdinalIgnoreCase));
}

<style>
    .agreement-index-surface { max-width: 1480px; margin: 0 auto; padding: 20px 24px; }
    .agreement-index-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 18px; margin-bottom: 18px; }
    .agreement-index-header h2 { margin: 8px 0 0; }
    .agreement-index-kicker { display: inline-flex; align-items: center; gap: 8px; padding: 6px 11px; border-radius: 999px; background: #ecfeff; color: #0f766e; font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
    .agreement-index-header p { margin: 6px 0 0; color: #64748b; max-width: 720px; }
    .agreement-index-stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin-bottom: 18px; }
    .agreement-stat-card { background: #fff; border: 1px solid rgba(15, 23, 42, .08); border-radius: 18px; box-shadow: 0 14px 34px rgba(15, 23, 42, .06); padding: 18px 20px; }
    .agreement-stat-card strong { display: block; font-size: .78rem; text-transform: uppercase; letter-spacing: .05em; color: #64748b; margin-bottom: 8px; }
    .agreement-stat-value { font-size: 1.5rem; font-weight: 800; color: #0f172a; line-height: 1; }
    .agreement-stat-note { margin-top: 8px; color: #475569; font-size: .84rem; }
    .agreement-index-table-shell { background: #fff; border: 1px solid rgba(15, 23, 42, .08); border-radius: 20px; box-shadow: 0 14px 34px rgba(15, 23, 42, .06); overflow: hidden; }
    .agreement-index-toolbar { display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 18px 20px; border-bottom: 1px solid #e2e8f0; background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); }
    .agreement-index-toolbar h3 { margin: 0; font-size: 1rem; color: #0f172a; }
    .agreement-index-toolbar p { margin: 4px 0 0; color: #64748b; font-size: .84rem; }
    .agreement-index-toolbar .agreement-pill { display: inline-flex; align-items: center; gap: 8px; padding: 7px 12px; border-radius: 999px; background: #ecfeff; color: #0f766e; font-size: .82rem; font-weight: 600; }
    .agreement-index-table-wrap { overflow-x: auto; }
    .agreement-index-table { width: 100%; border-collapse: separate; border-spacing: 0; min-width: 1180px; }
    .agreement-index-table th { padding: 12px 14px; background: #f8fafc; border-bottom: 1px solid #dbe4ee; color: #334155; font-size: .76rem; text-transform: uppercase; letter-spacing: .04em; }
    .agreement-index-table td { padding: 14px; border-bottom: 1px solid #e2e8f0; vertical-align: top; color: #0f172a; }
    .agreement-index-table tr:last-child td { border-bottom: none; }
    .agreement-list-title { display: grid; gap: 4px; }
    .agreement-list-title strong { font-size: .96rem; }
    .agreement-list-subtext { color: #64748b; font-size: .83rem; line-height: 1.45; }
    .agreement-metric { display: grid; gap: 4px; }
    .agreement-metric strong { font-size: .92rem; color: #0f172a; }
    .agreement-metric span { color: #64748b; font-size: .82rem; }
    .agreement-period { min-width: 180px; }
    @@media (max-width: 900px) {
        .agreement-index-surface { padding: 14px 16px; }
        .agreement-index-header { flex-direction: column; align-items: stretch; }
        .agreement-index-stats { grid-template-columns: 1fr; }
        .agreement-index-toolbar { flex-direction: column; align-items: stretch; }
    }
</style>

<div class="agreement-index-surface">
    <div class="agreement-index-header">
        <div>
            <div class="agreement-index-kicker"><i class="fas fa-layer-group"></i> Reusable contract catalogue</div>
            <h2><i class="fas fa-file-signature"></i> Agreement Master</h2>
            <p>Maintain reusable commercial agreements with stronger visibility into client assignments, approval state, and room-rate completeness.</p>
        </div>
        <a asp-action="Create" class="btn-create"><i class="fas fa-plus"></i> Add Agreement</a>
    </div>

    <div class="agreement-index-stats">
        <div class="agreement-stat-card">
            <strong>Total Agreements</strong>
            <div class="agreement-stat-value">@rows.Count</div>
            <div class="agreement-stat-note">Reusable contracts available for B2B client tagging.</div>
        </div>
        <div class="agreement-stat-card">
            <strong>Active Agreements</strong>
            <div class="agreement-stat-value">@activeCount</div>
            <div class="agreement-stat-note">Currently open for operational and booking use.</div>
        </div>
        <div class="agreement-stat-card">
            <strong>Linked Clients</strong>
            <div class="agreement-stat-value">@totalClients</div>
            <div class="agreement-stat-note">Pending approvals: @pendingApprovals</div>
        </div>
    </div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
}

@if (rows.Any())
{
    <div class="agreement-index-table-shell">
        <div class="agreement-index-toolbar">
            <div>
                <h3>Agreement Register</h3>
                <p>Compact operational view of contract identity, mapping health, and commercial readiness.</p>
            </div>
            <span class="agreement-pill"><i class="fas fa-users"></i> One agreement can serve multiple B2B clients</span>
        </div>
        <div class="agreement-index-table-wrap">
        <table class="agreement-index-table">
            <thead>
                <tr>
                    <th>Agreement Code</th>
                    <th>Contract</th>
                    <th>Linked Clients</th>
                    <th>Terms Mapping</th>
                    <th>Commercials</th>
                    <th>Effective Period</th>
                    <th>Approval</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in rows)
                {
                    <tr>
                        <td>
                            <div class="agreement-list-title">
                                <strong>@row.AgreementCode</strong>
                                <span class="agreement-list-subtext">Agreement ID: @row.Id</span>
                            </div>
                        </td>
                        <td>
                            <div class="agreement-list-title">
                                <strong>@row.AgreementName</strong>
                                <span class="agreement-list-subtext">@(string.IsNullOrWhiteSpace(row.ContractReference) ? row.AgreementType : row.ContractReference)</span>
                            </div>
                        </td>
                        <td>
                            <div class="agreement-metric">
                                <strong>@row.AssignedClientCount</strong>
                                <span>Client account(s) mapped</span>
                            </div>
                        </td>
                        <td>
                            <div class="agreement-metric">
                                <strong>@(string.IsNullOrWhiteSpace(row.TermsConditionName) ? "Terms pending" : row.TermsConditionName)</strong>
                                <span>@(string.IsNullOrWhiteSpace(row.CancellationPolicyName) ? "No cancellation policy" : row.CancellationPolicyName)</span>
                            </div>
                        </td>
                        <td>
                            <div class="agreement-metric">
                                <strong>@row.BillingType / @row.RatePlanType</strong>
                                <span>@row.RoomRateCount room-rate row(s)</span>
                            </div>
                        </td>
                        <td class="agreement-period">
                            <div class="agreement-metric">
                                <strong>@row.EffectiveFrom.ToString("dd MMM yyyy")</strong>
                                <span>to @row.EffectiveTo.ToString("dd MMM yyyy")</span>
                            </div>
                        </td>
                        <td>
                            <div class="agreement-metric">
                                <strong>@row.ApprovalStatus</strong>
                                <span>@(string.IsNullOrWhiteSpace(row.ApprovedByName) ? "Pending reviewer" : row.ApprovedByName)</span>
                            </div>
                        </td>
                        <td>@if (row.IsActive) { <span class="badge badge-available">Active</span> } else { <span class="badge badge-maintenance">Inactive</span> }</td>
                        <td><div class="action-buttons"><a asp-action="Details" asp-route-id="@row.Id" class="btn-action btn-view"><i class="fas fa-eye"></i><span>View</span></a><a asp-action="Edit" asp-route-id="@row.Id" class="btn-action btn-edit"><i class="fas fa-pen"></i><span>Edit</span></a></div></td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
}
else
{
    <div class="empty-state"><i class="fas fa-file-signature"></i><h3>No Agreements Found</h3><p>Create contract-ready commercial policies with rate rows, approval status, and terms mapping, then assign them from B2B Client Master.</p><a asp-action="Create" class="btn-create"><i class="fas fa-plus"></i> Add Agreement</a></div>
}
</div>