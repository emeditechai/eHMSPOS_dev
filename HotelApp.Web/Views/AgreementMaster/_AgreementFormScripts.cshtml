<script>
    (function () {
        const billingType = document.getElementById('BillingType');
        const creditDays = document.getElementById('creditDays');
        const creditLimit = document.getElementById('creditLimit');
        const amendmentToggle = document.getElementById('IsAmendmentAllowed');
        const amendmentCharge = document.getElementById('AmendmentChargeAmount');
        const autoRenew = document.getElementById('AutoRenew');
        const renewalNotice = document.getElementById('RenewalNoticeDays');
        const approvalStatus = document.getElementById('ApprovalStatus');
        const approvedBy = document.getElementById('ApprovedByUserId');
        const approvedDate = document.getElementById('ApprovedDate');
        const addRoomRateButton = document.getElementById('addRoomRateRow');
        const roomRateRows = document.getElementById('roomRateRows');
        const roomRateTemplate = document.getElementById('roomRateTemplate');

        function syncCreditFields() {
            if (!billingType || !creditDays || creditDays.hasAttribute('readonly')) {
                return;
            }

            const isCredit = (billingType.value || '').toLowerCase() === 'credit';
            creditDays.disabled = !isCredit;
            creditLimit.disabled = !isCredit;

            if (!isCredit) {
                creditDays.value = 0;
                creditLimit.value = '';
            }
        }

        function syncAmendmentFields() {
            if (!amendmentToggle || !amendmentCharge || amendmentCharge.hasAttribute('readonly')) {
                return;
            }

            const allowed = (amendmentToggle.value || '').toLowerCase() === 'true';
            amendmentCharge.disabled = !allowed;
            if (!allowed) {
                amendmentCharge.value = '';
            }
        }

        function syncRenewalFields() {
            if (!autoRenew || !renewalNotice || renewalNotice.hasAttribute('readonly')) {
                return;
            }

            const enabled = (autoRenew.value || '').toLowerCase() === 'true';
            renewalNotice.disabled = !enabled;
            if (!enabled) {
                renewalNotice.value = '';
            }
        }

        function syncApprovalFields() {
            if (!approvalStatus || !approvedBy || approvedDate?.hasAttribute('readonly')) {
                return;
            }

            const approved = (approvalStatus.value || '').toLowerCase() === 'approved';
            approvedBy.disabled = !approved;
            approvedDate.disabled = !approved;
            if (!approved) {
                approvedBy.value = '';
                approvedDate.value = '';
            }
        }

        function renumberRoomRateRows() {
            if (!roomRateRows) {
                return;
            }

            Array.from(roomRateRows.querySelectorAll('.room-rate-row')).forEach((row, index) => {
                row.querySelectorAll('input, select, textarea').forEach(field => {
                    const name = field.getAttribute('name');
                    if (name) {
                        field.setAttribute('name', name.replace(/RoomRates\[\d+\]/g, `RoomRates[${index}]`));
                    }
                });
            });
        }

        function addRoomRateRow() {
            if (!roomRateTemplate || !roomRateRows) {
                return;
            }

            const nextIndex = roomRateRows.querySelectorAll('.room-rate-row').length;
            const markup = roomRateTemplate.innerHTML.replaceAll('__index__', String(nextIndex));
            roomRateRows.insertAdjacentHTML('beforeend', markup);
        }

        billingType?.addEventListener('change', syncCreditFields);
        amendmentToggle?.addEventListener('change', syncAmendmentFields);
        autoRenew?.addEventListener('change', syncRenewalFields);
        approvalStatus?.addEventListener('change', syncApprovalFields);
        addRoomRateButton?.addEventListener('click', addRoomRateRow);

        roomRateRows?.addEventListener('click', event => {
            const button = event.target.closest('.remove-room-rate');
            if (!button) {
                return;
            }

            button.closest('.room-rate-row')?.remove();
            renumberRoomRateRows();
        });

        syncCreditFields();
        syncAmendmentFields();
        syncRenewalFields();
        syncApprovalFields();

        // ── Client-side mandatory field validation ──
        const AGR_REQUIRED = [
            { id: 'AgreementCode',  label: 'Agreement Code' },
            { id: 'AgreementName',  label: 'Agreement Name' },
            { id: 'AgreementType',  label: 'Agreement Type' },
            { id: 'EffectiveFrom',  label: 'Effective From' },
            { id: 'EffectiveTo',    label: 'Effective To' },
            { id: 'BillingType',    label: 'Billing Type' },
            { id: 'BillingCycle',   label: 'Billing Cycle' },
            { id: 'GstSlabId',      label: 'Default GST Slab' },
        ];

        function agrMarkField(el, valid) {
            const parent = el.closest('.agreement-field');
            if (parent) parent.classList.toggle('agr-field-invalid', !valid);
        }

        function agrShowToast(errors) {
            let toast = document.getElementById('agr-req-toast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'agr-req-toast';
                Object.assign(toast.style, {
                    position: 'fixed', top: '80px', right: '20px', zIndex: '9999',
                    background: '#fff', border: '2px solid #dc2626', borderRadius: '12px',
                    padding: '14px 18px', boxShadow: '0 8px 24px rgba(0,0,0,.18)',
                    maxWidth: '320px', fontSize: '.83rem'
                });
                document.body.appendChild(toast);
            }
            toast.innerHTML = `<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                <i class="fas fa-circle-exclamation" style="color:#dc2626;"></i>
                <strong style="color:#b91c1c;">Please fill in all required fields</strong>
                </div><ul style="margin:0;padding-left:18px;color:#374151;">
                ${errors.map(e => `<li>${e}</li>`).join('')}</ul>`;
            toast.style.display = 'block';
            clearTimeout(toast._t);
            toast._t = setTimeout(() => { toast.style.display = 'none'; }, 6000);
        }

        const _agrForm = document.querySelector('form.agreement-shell');
        if (_agrForm) {
            _agrForm.addEventListener('submit', function (e) {
                const errors = [];
                let firstEl = null;
                AGR_REQUIRED.forEach(({ id, label }) => {
                    const el = document.getElementById(id);
                    if (!el) return;
                    const valid = el.value.trim() !== '';
                    agrMarkField(el, valid);
                    if (!valid) { errors.push(label); if (!firstEl) firstEl = el; }
                });
                if (errors.length > 0) {
                    e.preventDefault();
                    agrShowToast(errors);
                    if (firstEl) {
                        firstEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        setTimeout(() => firstEl.focus(), 300);
                    }
                }
            });

            AGR_REQUIRED.forEach(({ id }) => {
                const el = document.getElementById(id);
                if (!el) return;
                const clear = () => agrMarkField(el, el.value.trim() !== '');
                el.addEventListener('change', clear);
                el.addEventListener('input', clear);
            });
        }
    })();
</script>