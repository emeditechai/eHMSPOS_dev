@model HotelApp.Web.Models.B2BAgreement
@{
    ViewData["Title"] = "Create Agreement";
}

<div class="agreement-page-surface">
    <div class="page-header agreement-page-header">
        <div>
            <div class="agreement-mode-badge"><i class="fas fa-plus-circle"></i> Create</div>
            <h2><i class="fas fa-file-contract"></i> Agreement Master</h2>
            <p class="text-muted mb-0">Build a reusable commercial contract with compact billing, policy, approval, and room-rate sections.</p>
        </div>
        <a asp-action="Index" class="btn-cancel"><i class="fas fa-arrow-left"></i> Back to Agreement List</a>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="agreement-shell">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="validation-summary"></div>
        <partial name="_AgreementFormFields" model="Model" />
        <div class="agreement-actions">
            <a asp-action="Index" class="btn-cancel"><i class="fas fa-times"></i> Cancel</a>
            <button type="submit" class="btn-save"><i class="fas fa-save"></i> Save Agreement</button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <partial name="_AgreementFormScripts" />
}