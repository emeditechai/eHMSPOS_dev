@model IEnumerable<HotelApp.Web.Models.GstSlab>
@{
    ViewData["Title"] = "GST Slab Master";
}

<div class="page-header">
    <h2><i class="fas fa-percent"></i> GST Slab Master</h2>
    <a asp-action="Create" class="btn-create"><i class="fas fa-plus"></i> Add GST Master</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
}

@if (Model.Any())
{
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Master</th>
                    <th>Tariff Coverage</th>
                    <th>Band Count</th>
                    <th>Max GST %</th>
                    <th>Effective Period</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model)
                {
                    <tr>
                        <td>
                            <strong>@row.SlabName</strong>
                            <div class="text-muted small">@row.SlabCode</div>
                        </td>
                        <td>
                            @if (row.MinimumTariffFrom.HasValue)
                            {
                                @(row.MinimumTariffFrom.Value.ToString("N2") + " - " + (row.MaximumTariffTo.HasValue ? row.MaximumTariffTo.Value.ToString("N2") : "Open"))
                            }
                            else
                            {
                                @:Not configured
                            }
                        </td>
                        <td>@row.ActiveBandCount band(s)</td>
                        <td>@((row.MaximumGstPercent ?? 0).ToString("0.##"))</td>
                        <td>@row.EffectiveFrom.ToString("dd MMM yyyy") - @(row.EffectiveTo.HasValue ? row.EffectiveTo.Value.ToString("dd MMM yyyy") : "Open")</td>
                        <td>@if (row.IsActive) { <span class="badge badge-available">Active</span> } else { <span class="badge badge-maintenance">Inactive</span> }</td>
                        <td><div class="action-buttons"><a asp-action="Details" asp-route-id="@row.Id" class="btn-action btn-view"><i class="fas fa-eye"></i><span>View</span></a><a asp-action="Edit" asp-route-id="@row.Id" class="btn-action btn-edit"><i class="fas fa-pen"></i><span>Edit</span></a></div></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="empty-state"><i class="fas fa-percent"></i><h3>No GST Masters Found</h3><p>Create a GST master, then add multiple tariff-based slabs under it for room-tariff driven tax resolution.</p><a asp-action="Create" class="btn-create"><i class="fas fa-plus"></i> Add GST Master</a></div>
}