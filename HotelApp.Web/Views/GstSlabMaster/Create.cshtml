@model HotelApp.Web.Models.GstSlab
@{
    ViewData["Title"] = "Create GST Slab";
}

<div class="page-header">
    <h2><i class="fas fa-percent"></i> GST Slab Master</h2>
    <a asp-action="Index" class="btn-cancel"><i class="fas fa-arrow-left"></i> Back to GST Master List</a>
</div>

<form asp-action="Create" method="post" class="gst-master-shell">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
    <partial name="_GstSlabFormFields" model="Model" />
    <div class="agreement-actions">
        <a asp-action="Index" class="btn-cancel"><i class="fas fa-times"></i> Cancel</a>
        <button type="submit" class="btn-save"><i class="fas fa-save"></i> Save GST Master</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <partial name="_GstSlabFormScripts" />
}