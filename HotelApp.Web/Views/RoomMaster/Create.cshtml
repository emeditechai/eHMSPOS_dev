@model HotelApp.Web.Models.Room
@{
    ViewData["Title"] = "Create Room";
    var roomTypes = ViewBag.RoomTypes as IEnumerable<HotelApp.Web.Models.RoomType> ?? Enumerable.Empty<HotelApp.Web.Models.RoomType>();
    var floors = ViewBag.Floors as IEnumerable<HotelApp.Web.Models.Floor> ?? Enumerable.Empty<HotelApp.Web.Models.Floor>();
    var statuses = ViewBag.Statuses as IEnumerable<string> ?? Array.Empty<string>();
}

<style>
    .master-create-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        padding: 30px 50px;
        max-width: 95%;
        width: 100%;
        margin: 0 auto;
    }

    .master-create-header {
        display: flex;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid #f0f0f0;
    }

    .master-create-header h3 {
        margin: 0;
        color: var(--primary);
        font-size: 24px;
        font-weight: 600;
    }

    .master-form-section {
        margin-bottom: 25px;
    }

    .section-title {
        font-size: 16px;
        font-weight: 600;
        color: #333;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .section-title i {
        color: var(--primary);
    }

    .master-form-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px 25px;
    }

    .master-form-group {
        display: flex;
        flex-direction: column;
    }

    .master-form-group label {
        font-weight: 500;
        margin-bottom: 8px;
        color: #333;
        font-size: 14px;
    }

    .master-form-group input,
    .master-form-group select,
    .master-form-group textarea {
        padding: 12px 15px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.2s;
    }

    .master-form-group input:focus,
    .master-form-group select:focus,
    .master-form-group textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(26, 42, 108, 0.1);
    }

    .master-form-group textarea {
        min-height: 80px;
        resize: vertical;
    }

    .master-form-group-full {
        grid-column: 1 / -1;
    }

    .master-form-actions {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        padding-top: 25px;
        border-top: 2px solid #f0f0f0;
    }

    .master-form-actions .btn-save,
    .master-form-actions .btn-cancel {
        padding: 12px 30px;
        font-size: 15px;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.2s;
    }

    .page-header {
        max-width: 95%;
        margin: 0 auto 20px;
    }

    @@media (max-width: 1400px) {
        .master-form-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .master-form-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media screen and (min-width: 1200px) {
        .master-create-container {
            max-width: 98%;
        }
    }

    @@media print {
        body {
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        @@page {
            size: landscape;
            margin: 0.5cm;
        }
        .master-create-container {
            max-width: 100%;
            padding: 20px;
        }
    }
</style>

<div class="page-header">
    <h2><i class="fas fa-door-open"></i> Room Master</h2>
</div>

<div class="master-create-container">
    <div class="master-create-header">
        <h3><i class="fas fa-plus-circle"></i> Add New Room</h3>
    </div>
    
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="master-form-section">
            <div class="section-title">
                <i class="fas fa-info-circle"></i>
                Room Information
            </div>
            <div class="master-form-grid">
                <div class="master-form-group">
                    <label asp-for="RoomTypeId">Room Rate <span class="text-danger">*</span></label>
                    <select asp-for="RoomTypeId" id="RoomTypeId" required>
                        <option value="">-- Select Room Rate --</option>
                        @{
                            var roomTypes = ViewBag.RoomTypes as IEnumerable<HotelApp.Web.Models.RoomType>;
                            var activeRates = ViewBag.ActiveRates as Dictionary<int, HotelApp.Web.Models.RateMaster>;
                            var roomCountByType = ViewBag.RoomCountByType as Dictionary<int, int>;
                        }
                        @if (roomTypes != null)
                        {
                            foreach (var roomType in roomTypes)
                            {
                                var rate = activeRates?.ContainsKey(roomType.Id) == true ? activeRates[roomType.Id] : null;
                                var rateInfo = rate != null ? $"₹{rate.BaseRate:N0}" : "No Rate";
                                var created = roomCountByType?.ContainsKey(roomType.Id) == true ? roomCountByType[roomType.Id] : 0;
                                var maxAvail = roomType.Max_RoomAvailability ?? 0;
                                <option value="@roomType.Id"
                                        data-max="@maxAvail"
                                        data-created="@created">
                                    @roomType.TypeName — @rateInfo | Max: @maxAvail | Created: @created
                                </option>
                            }
                        }
                    </select>
                    <span asp-validation-for="RoomTypeId" class="text-danger"></span>
                    <small class="form-text text-muted">Rates are managed in Rate Master. Showing current active rates.</small>
                    <div id="roomTypeInfo" style="display:none; margin-top:6px; padding:6px 12px; border-radius:6px; font-size:13px; font-weight:500;"></div>
                </div>
                <div class="master-form-group">
                    <label asp-for="RoomNumber">Room Number <span class="text-danger">*</span></label>
                    <input asp-for="RoomNumber" type="text" placeholder="e.g., 201" required />
                    <span asp-validation-for="RoomNumber" class="text-danger"></span>
                </div>
                <div class="master-form-group">
                    <label asp-for="Floor">Floor <span class="text-danger">*</span></label>
                    <select asp-for="Floor" required>
                        <option value="">-- Select Floor --</option>
                        @foreach (var floor in floors)
                        {
                            <option value="@floor.Id">@floor.FloorName</option>
                        }
                    </select>
                    <span asp-validation-for="Floor" class="text-danger"></span>
                </div>
                <div class="master-form-group">
                    <label asp-for="Status">Status <span class="text-danger">*</span></label>
                    <select asp-for="Status" required>
                        <option value="">-- Select Status --</option>
                        @foreach (var status in statuses)
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
                <div class="master-form-group master-form-group-full">
                    <label asp-for="Notes">Notes</label>
                    <textarea asp-for="Notes" placeholder="e.g., AC repair ongoing"></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="master-form-actions">
            <a asp-action="List" class="btn-cancel">
                <i class="fas fa-times"></i> Cancel
            </a>
            <button type="submit" class="btn-save">
                <i class="fas fa-save"></i> Save Room
            </button>
        </div>
    </form>
</div>

<script>
    document.getElementById('RoomTypeId').addEventListener('change', function () {
        var info = document.getElementById('roomTypeInfo');
        var opt = this.options[this.selectedIndex];
        var saveBtn = document.querySelector('.btn-save');
        var fields = document.querySelectorAll('#RoomNumber, #Floor, #Status, #Notes');

        if (!this.value) {
            info.style.display = 'none';
            fields.forEach(function (f) { f.disabled = false; f.style.opacity = '1'; });
            saveBtn.disabled = false; saveBtn.style.opacity = '1'; saveBtn.style.pointerEvents = 'auto';
            return;
        }

        var max = parseInt(opt.getAttribute('data-max')) || 0;
        var created = parseInt(opt.getAttribute('data-created')) || 0;
        var remaining = max - created;
        var limitReached = max > 0 && remaining <= 0;

        // Disable/enable fields and save button
        fields.forEach(function (f) { f.disabled = limitReached; f.style.opacity = limitReached ? '0.5' : '1'; });
        saveBtn.disabled = limitReached;
        saveBtn.style.opacity = limitReached ? '0.5' : '1';
        saveBtn.style.pointerEvents = limitReached ? 'none' : 'auto';

        if (limitReached) {
            info.style.display = 'block';
            info.style.background = '#fee2e2';
            info.style.color = '#b91c1c';
            info.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Limit reached! Max: ' + max + ' | Created: ' + created + '. Cannot create more rooms of this type.';
        } else if (max > 0) {
            info.style.display = 'block';
            info.style.background = '#ecfdf5';
            info.style.color = '#065f46';
            info.innerHTML = '<i class="fas fa-check-circle"></i> Available: ' + remaining + ' of ' + max + ' | Created: ' + created;
        } else {
            info.style.display = 'block';
            info.style.background = '#eff6ff';
            info.style.color = '#1e40af';
            info.innerHTML = '<i class="fas fa-info-circle"></i> No max limit set | Created: ' + created;
        }
    });
</script>
