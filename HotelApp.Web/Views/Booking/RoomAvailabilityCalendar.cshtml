@{
    ViewData["Title"] = "Room Availability Calendar";
}

@section Styles {
    <style>
        body { background:#f0f4f8; font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif; }

        /* ── Container ── */
        .calendar-container { padding:16px; max-width:100%; margin:0; position:relative; }

        /* ── Hero Header ── */
        .calendar-header {
            background: linear-gradient(135deg,#1a2a6c 0%,#1565c0 50%,#0d9488 100%);
            border-radius:16px 16px 0 0;
            padding:24px 28px 20px;
            color:#fff;
            box-shadow:0 4px 20px rgba(26,42,108,.28);
            position:relative; overflow:hidden;
        }
        .calendar-header::before { content:''; position:absolute; right:-60px; top:-60px; width:220px; height:220px; background:rgba(255,255,255,.06); border-radius:50%; }
        .calendar-header::after  { content:''; position:absolute; left:5%; bottom:-70px; width:260px; height:260px; background:rgba(255,255,255,.04); border-radius:50%; }

        .calendar-header h1 { margin:0 0 16px; font-size:1.6rem; font-weight:800; display:flex; align-items:center; gap:12px; position:relative; z-index:1; letter-spacing:-.3px; }
        .calendar-header h1 i { font-size:1.4rem; opacity:.9; }

        .calendar-controls { display:flex; align-items:center; gap:14px; flex-wrap:wrap; position:relative; z-index:1; }
        .control-group { display:flex; align-items:center; gap:8px; }
        .control-group label { font-size:.8rem; font-weight:600; opacity:.9; white-space:nowrap; }
        .control-group input[type="date"],
        .control-group select {
            padding:9px 12px; border:1.5px solid rgba(255,255,255,.3); border-radius:9px;
            font-size:.82rem; background:rgba(255,255,255,.95); color:#1e293b;
            transition:border-color .2s; min-width:140px;
        }
        .control-group input:focus,
        .control-group select:focus { outline:none; border-color:#fff; box-shadow:0 0 0 3px rgba(255,255,255,.25); }

        .btn-load-calendar {
            padding:9px 22px; background:#fff; color:#1a2a6c; border:none; border-radius:9px;
            cursor:pointer; font-size:.82rem; font-weight:700; display:flex; align-items:center; gap:8px;
            transition:all .2s; box-shadow:0 2px 8px rgba(0,0,0,.15);
        }
        .btn-load-calendar:hover { transform:translateY(-2px); box-shadow:0 4px 14px rgba(0,0,0,.2); background:#e8f0fe; }

        /* ── Legend ── */
        .calendar-legend { display:flex; gap:16px; margin-top:14px; padding-top:14px; border-top:1px solid rgba(255,255,255,.18); flex-wrap:wrap; position:relative; z-index:1; }
        .legend-item { display:flex; align-items:center; gap:7px; font-size:.75rem; font-weight:600; }
        .legend-color { width:20px; height:20px; border-radius:5px; border:2px solid rgba(255,255,255,.4); flex-shrink:0; }
        .legend-color.high    { background:linear-gradient(140deg,#2e7d32,#66bb6a); }
        .legend-color.medium  { background:linear-gradient(140deg,#e65100,#ffa726); }
        .legend-color.low     { background:linear-gradient(140deg,#c62828,#ef5350); }
        .legend-color.full    { background:linear-gradient(140deg,#37474f,#78909c); }

        /* ── Calendar wrapper ── */
        .calendar-wrapper {
            background:#fff; border-radius:0 0 16px 16px;
            box-shadow:0 8px 32px rgba(0,0,0,.10); position:relative; overflow:auto; max-height:620px;
        }
        .calendar-flex-container { display:flex; width:100%; position:relative; }

        /* ── Fixed room type column ── */
        .calendar-fixed-column { flex-shrink:0; width:200px; background:#fff; border-right:2px solid #e2e8f0; z-index:10; box-shadow:3px 0 10px rgba(0,0,0,.06); }
        .calendar-fixed-header {
            padding:0 16px; text-align:left; font-weight:700; font-size:.82rem;
            background:linear-gradient(135deg,#1a2a6c,#1565c0); color:#fff;
            border-bottom:2px solid rgba(255,255,255,.15);
            height:64px; display:flex; align-items:center; gap:8px;
        }
        .calendar-fixed-body { background:#fff; overflow:hidden; pointer-events:none; }
        .fixed-room-row {
            padding:14px 16px; border-bottom:1px solid #f1f5f9; background:#fff;
            height:110px; display:flex; flex-direction:column; justify-content:center;
            box-sizing:border-box; position:relative; min-height:110px; max-height:110px;
        }
        .fixed-room-row::before {
            content:''; position:absolute; left:0; top:0; bottom:0; width:3px;
            background:linear-gradient(180deg,#1565c0,#0d9488); opacity:0; transition:opacity .2s;
        }
        .fixed-room-row:hover { background:#f8fafc; }
        .fixed-room-row:hover::before { opacity:1; }

        /* ── Calendar scroll area ── */
        .calendar-scroll { flex-grow:1; overflow-x:auto; overflow-y:visible; position:relative; }
        .calendar-table {
            table-layout:auto; width:max-content; min-width:100%;
            border-collapse:separate; border-spacing:0; position:relative;
        }
        .calendar-table thead { position:sticky; top:0; z-index:20; }

        /* ── Date header cells ── */
        .calendar-table th {
            padding:0 10px; text-align:center; font-weight:700; font-size:.75rem; color:#475569;
            background:#f8fafc; border-bottom:2px solid #e2e8f0; white-space:nowrap;
            height:64px; box-sizing:border-box;
        }
        .calendar-table th.room-type-header {
            text-align:left; position:sticky; left:0!important; z-index:21;
            min-width:160px; max-width:160px; width:160px;
            background:linear-gradient(135deg,#f1f5f9,#e2e8f0)!important;
            font-size:.82rem; color:#1e293b; box-shadow:3px 0 10px rgba(0,0,0,.12);
        }
        .calendar-table th.date-header { min-width:110px; padding:10px 12px; }

        .date-header-day  { display:block; font-size:.95rem; font-weight:800; color:#1e293b; margin-bottom:2px; }
        .date-header-date { display:block; font-size:.68rem; color:#64748b; font-weight:500; }

        .date-header.weekend { background:linear-gradient(135deg,#fdf4ff,#f3e8ff); }
        .date-header.weekend .date-header-day  { color:#6b21a8; }
        .date-header.weekend .date-header-date { color:#9333ea; }

        .date-header.today { background:linear-gradient(135deg,#1a2a6c,#1e40af); }
        .date-header.today .date-header-day  { color:#fff; }
        .date-header.today .date-header-date { color:rgba(255,255,255,.8); }

        /* ── Table rows ── */
        .calendar-table tbody tr { height:110px; min-height:110px; max-height:110px; }
        .calendar-table tbody tr:hover { background:#f8fafc; }
        .calendar-table td {
            padding:0; border-bottom:1px solid #e2e8f0; border-right:1px solid #f1f5f9;
            position:relative; height:110px; min-height:110px; max-height:110px;
            box-sizing:border-box; vertical-align:top;
        }
        .room-type-cell {
            position:sticky; left:0!important; z-index:10; background:#fff!important; padding:12px 14px;
            font-weight:600; color:#1e293b; border-right:2px solid #e2e8f0;
            min-width:160px; max-width:160px; width:160px;
            box-shadow:3px 0 10px rgba(0,0,0,.08);
            will-change:transform; transform:translateZ(0);
        }
        .calendar-table tbody tr:hover .room-type-cell { background:#f8fafc!important; }

        .room-type-name {
            font-size:.8rem; margin-bottom:4px; font-weight:700; color:#1e293b;
            display:flex; align-items:center; gap:6px; line-height:1.3;
        }
        .room-type-name i { color:#1565c0; font-size:.75rem; }
        .room-type-info {
            font-size:.7rem; color:#64748b; font-weight:500;
            display:flex; align-items:center; gap:5px; line-height:1.4;
        }
        .room-type-info i { color:#0d9488; font-size:.65rem; }

        /* ── Availability cells ── */
        .availability-cell {
            padding:9px 7px; text-align:center; cursor:pointer;
            transition:transform .15s, box-shadow .15s;
            height:calc(110px - 8px); min-height:102px; max-height:102px;
            display:flex; flex-direction:column; align-items:center; justify-content:center; gap:2px;
            border-radius:10px; position:relative; overflow:hidden;
            margin:4px; box-sizing:border-box;
        }
        .availability-cell::before {
            content:''; position:absolute; right:-12px; top:-12px; width:55px; height:55px;
            border-radius:50%; background:rgba(255,255,255,.12); pointer-events:none;
        }
        .availability-cell:hover { transform:translateY(-3px); box-shadow:0 8px 20px rgba(0,0,0,.2); z-index:5; }

        /* ── Availability colour variants (matching md-kpi exactly) ── */
        .availability-high { background:linear-gradient(140deg,#2e7d32,#66bb6a); color:#fff; }
        .availability-high .available-count { color:#fff; }
        .availability-high .available-label { color:rgba(255,255,255,.9); }

        .availability-medium { background:linear-gradient(140deg,#e65100,#ffa726); color:#fff; }
        .availability-medium .available-count { color:#fff; }
        .availability-medium .available-label { color:rgba(255,255,255,.9); }

        .availability-low { background:linear-gradient(140deg,#c62828,#ef5350); color:#fff; }
        .availability-low .available-count { color:#fff; }
        .availability-low .available-label { color:rgba(255,255,255,.9); }

        .availability-none { background:linear-gradient(140deg,#37474f,#78909c); color:#fff; }
        .availability-none .available-count { color:#fff; }
        .availability-none .available-label { color:rgba(255,255,255,.8); }

        .available-count { font-size:1.5rem; font-weight:800; line-height:1; margin-bottom:1px; position:relative; z-index:1; }
        .available-label { font-size:.62rem; font-weight:700; text-transform:uppercase; letter-spacing:.5px; position:relative; z-index:1; }
        .booked-count {
            font-size:.65rem; font-weight:700; padding:2px 7px; border-radius:5px;
            background:rgba(0,0,0,.15); color:#fff; margin-top:2px; position:relative; z-index:1;
        }

        /* ── Price badge ── */
        .cell-price {
            font-size:.62rem; font-weight:700; padding:3px 7px;
            background:rgba(255,255,255,.22); border-radius:8px; margin-top:3px;
            border:1px solid rgba(255,255,255,.3); display:flex; flex-direction:column; align-items:center; gap:1px;
            position:relative; z-index:1;
        }
        .rate-badge {
            font-size:.6rem; font-weight:700; padding:1px 5px; border-radius:5px;
            text-transform:uppercase; letter-spacing:.3px; display:inline-block;
        }
        .rate-special { background:rgba(255,255,255,.9); color:#92400e; }
        .rate-weekend { background:rgba(255,255,255,.9); color:#1e3a8a; }
        .rate-standard { background:rgba(255,255,255,.9); color:#065f46; }
        .rate-amount   { font-size:.68rem; font-weight:800; color:#fff; }

        /* ── Loading overlay ── */
        .loading-overlay {
            position:fixed; inset:0; background:rgba(255,255,255,.93);
            display:none; align-items:center; justify-content:center; z-index:9999;
        }
        .loading-overlay.active { display:flex; }
        .loading-content { text-align:center; }
        .loading-spinner {
            width:52px; height:52px; border:4px solid #e2e8f0; border-top-color:#1565c0;
            border-radius:50%; animation:spin 1s linear infinite; margin:0 auto 14px;
        }
        @@keyframes spin { to { transform:rotate(360deg); } }
        .loading-text { color:#475569; font-weight:600; font-size:.85rem; }

        /* ── Empty states ── */
        .empty-state { text-align:center; padding:60px 20px; color:#64748b; }
        .empty-state i { font-size:52px; color:#cbd5e1; margin-bottom:16px; display:block; }
        .empty-state h3 { font-size:1.1rem; margin-bottom:6px; color:#475569; }
        .empty-state p  { font-size:.82rem; }
        .empty-state-fixed { text-align:center; padding:30px 16px; color:#64748b; }
        .empty-state-fixed i { font-size:28px; color:#cbd5e1; margin-bottom:8px; display:block; }
        .empty-state-fixed p { font-size:.72rem; }

        /* ── Swal enhancements ── */
        .cal-popup-table { width:100%; border-collapse:collapse; font-size:.82rem; }
        .cal-popup-table td { padding:6px 8px; border-bottom:1px solid #f1f5f9; }
        .cal-popup-table td:first-child { font-weight:600; color:#475569; white-space:nowrap; width:45%; }
        .cal-popup-table td:last-child  { font-weight:700; color:#1e293b; }
        .cal-popup-section { margin:8px 0 4px; font-size:.72rem; font-weight:800; text-transform:uppercase; letter-spacing:.06em; color:#1565c0; }
        .cal-popup-divider { border:none; border-top:1px solid #e2e8f0; margin:8px 0; }
    </style>
}

<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-content">
        <div class="loading-spinner"></div>
        <div class="loading-text">Loading availability data...</div>
    </div>
</div>

<div class="calendar-container">
    <div class="calendar-header">
        <h1>
            <i class="fas fa-calendar-alt"></i>
            Room Availability Calendar
        </h1>
        <div class="calendar-controls">
            <div class="control-group">
                <label><i class="fas fa-calendar"></i> Start Date:</label>
                <input type="date" id="startDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="control-group">
                <label><i class="fas fa-calendar"></i> End Date:</label>
                <input type="date" id="endDate" value="@DateTime.Today.AddDays(6).ToString("yyyy-MM-dd")" />
            </div>
            <div class="control-group">
                <label><i class="fas fa-bed"></i> Room Type:</label>
                <select id="roomTypeFilter" onchange="onRoomTypeFilterChanged()">
                    <option value="all" selected>All</option>
                </select>
            </div>
            <button class="btn-load-calendar" onclick="loadCalendar()">
                <i class="fas fa-sync-alt"></i>
                Load Calendar
            </button>
        </div>
        <div class="calendar-legend">
            <div class="legend-item">
                <div class="legend-color high"></div>
                <span>High Availability (70%+)</span>
            </div>
            <div class="legend-item">
                <div class="legend-color medium"></div>
                <span>Medium (30-69%)</span>
            </div>
            <div class="legend-item">
                <div class="legend-color low"></div>
                <span>Low (1-29%)</span>
            </div>
            <div class="legend-item">
                <div class="legend-color full"></div>
                <span>Fully Booked</span>
            </div>
        </div>
    </div>
    
    <div class="calendar-wrapper">
        <div class="calendar-flex-container">
            <div class="calendar-fixed-column">
                <div class="calendar-fixed-header"><i class="fas fa-hotel" style="font-size:.85rem;opacity:.8"></i> Room Type</div>
                <div id="fixedColumnBody" class="calendar-fixed-body">
                    <div class="empty-state-fixed">
                        <i class="fas fa-calendar-check"></i>
                        <p>Loading...</p>
                    </div>
                </div>
            </div>
            <div class="calendar-scroll">
                <table class="calendar-table" id="calendarTable">
                    <thead>
                        <tr id="calendarHeaderRow">
                        </tr>
                    </thead>
                    <tbody id="calendarBody">
                        <tr>
                            <td colspan="100">
                                <div class="empty-state">
                                    <i class="fas fa-calendar-check"></i>
                                    <h3>Select Date Range</h3>
                                    <p>Choose your start and end dates, then click "Load Calendar" to view availability.</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let calendarData = {};
        let lastRenderedDates = [];
        
        document.addEventListener('DOMContentLoaded', function () {
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('startDate').min = today;
            document.getElementById('endDate').min = today;
            // Auto-load calendar on page load
            loadCalendar();
        });

        function loadCalendar() {
            const startDate = document.getElementById('startDate').value;
            const endDate = document.getElementById('endDate').value;
            
            if (!startDate || !endDate) {
                Swal.fire({ icon: 'warning', title: 'Missing Dates', text: 'Please select both start and end dates' });
                return;
            }
            
            const start = new Date(startDate);
            const end = new Date(endDate);
            
            if (end < start) {
                Swal.fire({ icon: 'error', title: 'Invalid Date Range', text: 'End date must be after start date' });
                return;
            }
            
            const daysDiff = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
            if (daysDiff > 31) {
                Swal.fire({ icon: 'warning', title: 'Date Range Too Long', text: 'Please select a date range of 31 days or less for optimal viewing' });
                return;
            }
            
            showLoading(true);
            
            // Fetch availability data for each date in range
            fetchCalendarData(startDate, endDate);
        }

        function onRoomTypeFilterChanged() {
            if (lastRenderedDates.length > 0 && Object.keys(calendarData).length > 0) {
                renderCalendar(lastRenderedDates);
            }
        }

        function updateRoomTypeFilterOptions(roomTypes) {
            const select = document.getElementById('roomTypeFilter');
            if (!select) return;

            const current = select.value || 'all';
            const options = ['<option value="all">All</option>'];

            roomTypes.forEach(rt => {
                options.push(`<option value="${rt.id}">${rt.name}</option>`);
            });

            select.innerHTML = options.join('');

            const stillExists = current === 'all' || roomTypes.some(rt => String(rt.id) === String(current));
            select.value = stillExists ? current : 'all';
        }
        
        function fetchCalendarData(startDate, endDate) {
            const promises = [];
            const dates = [];
            
            let currentDate = new Date(startDate);
            const endDateObj = new Date(endDate);
            
            while (currentDate <= endDateObj) {
                const dateStr = currentDate.toISOString().split('T')[0];
                dates.push(dateStr);
                promises.push(
                    fetch(`@Url.Action("GetAvailabilityByDateRange", "Rooms")?startDate=${dateStr}&endDate=${dateStr}`)
                        .then(response => response.json())
                );
                currentDate.setDate(currentDate.getDate() + 1);
            }
            
            Promise.all(promises)
                .then(results => {
                    calendarData = {};
                    results.forEach((result, index) => {
                        if (result.success && result.data) {
                            calendarData[dates[index]] = result.data;
                        }
                    });
                    renderCalendar(dates);
                    showLoading(false);
                })
                .catch(error => {
                    console.error('Error fetching calendar data:', error);
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to load availability data' });
                    showLoading(false);
                });
        }
        
        function renderCalendar(dates) {
            lastRenderedDates = Array.isArray(dates) ? dates.slice() : [];
            if (dates.length === 0 || Object.keys(calendarData).length === 0) {
                document.getElementById('calendarBody').innerHTML = `
                    <tr><td colspan="100"><div class="empty-state">
                        <i class="fas fa-exclamation-circle"></i>
                        <h3>No Data Available</h3>
                        <p>No availability data found for the selected date range.</p>
                    </div></td></tr>
                `;
                document.getElementById('fixedColumnBody').innerHTML = `
                    <div class="empty-state-fixed">
                        <i class="fas fa-exclamation-circle"></i>
                        <p>No Data</p>
                    </div>
                `;
                return;
            }
            
            // Build header row with dates
            const headerRow = document.getElementById('calendarHeaderRow');
            let headerHtml = '';
            
            dates.forEach(dateStr => {
                const date = new Date(dateStr + 'T00:00:00');
                const dayName = date.toLocaleDateString('en-US', { weekday: 'short' });
                const dayNum = date.getDate();
                const monthName = date.toLocaleDateString('en-US', { month: 'short' });
                const isWeekend = date.getDay() === 0 || date.getDay() === 6;
                const isToday = dateStr === new Date().toISOString().split('T')[0];
                
                const classNames = ['date-header'];
                if (isWeekend) classNames.push('weekend');
                if (isToday) classNames.push('today');
                
                headerHtml += `
                    <th class="${classNames.join(' ')}">
                        <span class="date-header-day">${dayName}</span>
                        <span class="date-header-date">${dayNum} ${monthName}</span>
                    </th>
                `;
            });
            
            headerRow.innerHTML = headerHtml;
            
            // Get all unique room types
            const roomTypes = new Map();
            Object.values(calendarData).forEach(dayData => {
                dayData.forEach(room => {
                    if (!roomTypes.has(room.roomTypeId)) {
                        roomTypes.set(room.roomTypeId, {
                            id: room.roomTypeId,
                            name: room.roomTypeName,
                            totalRooms: room.totalRooms
                        });
                    }
                });
            });

            // Populate filter dropdown from available room types
            const roomTypeList = Array.from(roomTypes.values()).sort((a, b) => (a.name || '').localeCompare(b.name || ''));
            updateRoomTypeFilterOptions(roomTypeList);

            const selectedRoomType = document.getElementById('roomTypeFilter')?.value || 'all';
            const filteredRoomTypes = selectedRoomType === 'all'
                ? roomTypeList
                : roomTypeList.filter(rt => String(rt.id) === String(selectedRoomType));
            
            // Build fixed column with room types
            const fixedColumnBody = document.getElementById('fixedColumnBody');
            let fixedHtml = '';
            
            filteredRoomTypes.forEach(roomType => {
                fixedHtml += `
                    <div class="fixed-room-row">
                        <div class="room-type-name"><i class="fas fa-bed"></i>${roomType.name}</div>
                        <div class="room-type-info"><i class="fas fa-layer-group"></i>Total: ${roomType.totalRooms} rooms</div>
                    </div>
                `;
            });
            
            fixedColumnBody.innerHTML = fixedHtml;
            
            // Build body rows - one row per room type
            const tbody = document.getElementById('calendarBody');
            let bodyHtml = '';
            
            filteredRoomTypes.forEach(roomType => {
                bodyHtml += '<tr>';
                
                dates.forEach(dateStr => {
                    const dayData = calendarData[dateStr] || [];
                    const roomData = dayData.find(r => r.roomTypeId === roomType.id);
                    
                    if (roomData) {
                        const available = roomData.availableRooms;
                        const total = roomData.totalRooms;
                        const percentage = total > 0 ? (available * 100 / total) : 0;
                        
                        let availabilityClass = 'availability-none';
                        if (available === 0) {
                            availabilityClass = 'availability-none';
                        } else if (percentage >= 70) {
                            availabilityClass = 'availability-high';
                        } else if (percentage >= 30) {
                            availabilityClass = 'availability-medium';
                        } else {
                            availabilityClass = 'availability-low';
                        }
                        
                        const booked = total - available;
                        const originalRate = Number(roomData.originalRate || roomData.baseRate || 0);
                        const discountedRate = Number(roomData.baseRate || 0);
                        const discountPercent = Number(roomData.discountPercent || 0);
                        const discountAmount = discountPercent > 0
                            ? Math.round((originalRate - discountedRate) * 100) / 100
                            : 0;
                        const rateType = roomData.rateType || 'Standard';
                        const eventName = roomData.eventName || '';
                        const taxPercentage = Number(roomData.taxPercentage || 0);

                        const b2bRate = roomData.b2bRate;
                        const b2bOriginalRate = roomData.b2bOriginalRate;
                        const b2bDiscountPercent = Number(roomData.b2bDiscountPercent || 0);
                        const b2bDiscountAmount = b2bDiscountPercent > 0
                            ? Math.round((Number(b2bOriginalRate || b2bRate || 0) - Number(b2bRate || 0)) * 100) / 100
                            : 0;
                        const hasB2B = b2bRate !== null && b2bRate !== undefined && Number(b2bRate) > 0;
                        const b2bTaxPercentage = Number(roomData.b2bTaxPercentage || 0);
                        
                        // Rate type indicator
                        let rateBadge = 'Standard';
                        let rateBadgeClass = 'rate-standard';
                        
                        if (rateType === 'Special Day') {
                            rateBadge = eventName || 'Special';
                            rateBadgeClass = 'rate-special';
                        } else if (rateType === 'Weekend') {
                            rateBadge = 'Weekend';
                            rateBadgeClass = 'rate-weekend';
                        }
                        
                        bodyHtml += `
                            <td>
                                <div class="availability-cell ${availabilityClass}" 
                                     onclick="cellClicked('${roomType.name}', '${dateStr}', ${available}, ${total}, ${booked}, ${originalRate}, ${discountedRate}, ${discountPercent}, ${discountAmount}, '${rateType}', '${eventName}', ${taxPercentage}, ${hasB2B ? Number(b2bRate) : 0}, ${hasB2B ? Number(b2bOriginalRate || b2bRate) : 0}, ${hasB2B ? Number(b2bDiscountPercent) : 0}, ${hasB2B ? Number(b2bDiscountAmount) : 0}, ${hasB2B ? Number(b2bTaxPercentage) : 0})"
                                     title="${roomType.name} — ${dateStr}&#10;${available} avail / ${booked} booked / ${total} total">
                                    <div class="available-count">${available}</div>
                                    <div class="available-label">${available === 0 ? '<i class=&quot;fas fa-lock&quot;></i> FULL' : '<i class=&quot;fas fa-check-circle&quot;></i> AVAILABLE'}</div>
                                    <div class="booked-count"><i class="fas fa-bookmark"></i> ${booked} Booked</div>
                                    <div class="cell-price">
                                        <span class="rate-badge ${rateBadgeClass}">${rateBadge}</span>
                                        ${discountPercent > 0 ? `<span class="rate-amount" style="text-decoration:line-through;opacity:.6;font-size:.55rem">₹${originalRate.toLocaleString()}</span>` : ''}
                                        <span class="rate-amount">₹${discountedRate.toLocaleString()}</span>
                                    </div>
                                </div>
                            </td>
                        `;
                    } else {
                        bodyHtml += `
                            <td>
                                <div class="availability-cell availability-none">
                                    <div class="available-count">-</div>
                                    <div class="available-label">N/A</div>
                                </div>
                            </td>
                        `;
                    }
                });
                
                bodyHtml += '</tr>';
            });
            
            tbody.innerHTML = bodyHtml;
        }
        
        function cellClicked(roomTypeName, date, available, total, booked, originalRate, discountedRate, discountPercent, discountAmount, rateType, eventName, taxPercentage, b2bRate, b2bOriginalRate, b2bDiscountPercent, b2bDiscountAmount, b2bTaxPercentage) {
            const dateObj = new Date(date + 'T00:00:00');
            const formattedDate = dateObj.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
            
            let rateTypeLabel = 'Standard Rate';
            if (rateType === 'Special Day') {
                rateTypeLabel = eventName ? `Special Day (${eventName})` : 'Special Day Rate';
            } else if (rateType === 'Weekend') {
                rateTypeLabel = 'Weekend Rate';
            }
            
            const b2cTaxPct = Number(taxPercentage || 0);
            const b2cGstAmount = Math.round((Number(discountedRate || 0) * (b2cTaxPct / 100)) * 100) / 100;
            const b2cNetAmount = Math.round((Number(discountedRate || 0) + b2cGstAmount) * 100) / 100;
            const occupancy = total > 0 ? ((total - available) * 100 / total).toFixed(0) : 0;

            let rows = `
                <div class="cal-popup-section">Room Details</div>
                <table class="cal-popup-table">
                    <tr><td>Date</td><td>${formattedDate}</td></tr>
                    <tr><td>Total Rooms</td><td>${total}</td></tr>
                    <tr><td>Available</td><td style="color:#2e7d32;font-weight:800">${available}</td></tr>
                    <tr><td>Booked</td><td style="color:#c62828;font-weight:800">${booked}</td></tr>
                    <tr><td>Occupancy</td><td>${occupancy}%</td></tr>
                </table>
                <hr class="cal-popup-divider">
                <div class="cal-popup-section">B2C Pricing — ${rateTypeLabel}</div>
                <table class="cal-popup-table">`;

            if (discountPercent > 0) {
                rows += `
                    <tr><td>Original Rate</td><td style="text-decoration:line-through;color:#9ca3af">₹${originalRate.toLocaleString()}/night</td></tr>
                    <tr><td>Discount</td><td style="color:#c62828;font-weight:700">${discountPercent}% OFF (Save ₹${discountAmount.toLocaleString()})</td></tr>
                    <tr><td>Rate</td><td style="color:#1565c0;font-size:1.05rem;font-weight:800">₹${discountedRate.toLocaleString()}/night</td></tr>`;
            } else {
                rows += `<tr><td>Rate</td><td style="font-weight:800">₹${discountedRate.toLocaleString()}/night</td></tr>`;
            }
            rows += `
                    <tr><td>GST (${b2cTaxPct}%)</td><td>₹${b2cGstAmount.toLocaleString()}</td></tr>
                    <tr><td>Net Amount</td><td style="color:#2e7d32;font-weight:800">₹${b2cNetAmount.toLocaleString()}/night</td></tr>
                </table>`;

            const hasB2B = b2bRate !== null && b2bRate !== undefined && Number(b2bRate) > 0;
            if (hasB2B) {
                const b2bTaxPct = Number(b2bTaxPercentage || 0);
                const b2bGstAmount = Math.round((Number(b2bRate || 0) * (b2bTaxPct / 100)) * 100) / 100;
                const b2bNetAmount = Math.round((Number(b2bRate || 0) + b2bGstAmount) * 100) / 100;
                rows += `<hr class="cal-popup-divider"><div class="cal-popup-section">B2B Pricing</div><table class="cal-popup-table">`;
                if (Number(b2bDiscountPercent) > 0) {
                    rows += `
                        <tr><td>Original Rate</td><td style="text-decoration:line-through;color:#9ca3af">₹${Number(b2bOriginalRate || b2bRate).toLocaleString()}/night</td></tr>
                        <tr><td>Discount</td><td style="color:#c62828;font-weight:700">${Number(b2bDiscountPercent)}% OFF (Save ₹${Number(b2bDiscountAmount || 0).toLocaleString()})</td></tr>
                        <tr><td>Rate</td><td style="color:#1565c0;font-size:1.05rem;font-weight:800">₹${Number(b2bRate).toLocaleString()}/night</td></tr>`;
                } else {
                    rows += `<tr><td>Rate</td><td style="font-weight:800">₹${Number(b2bRate).toLocaleString()}/night</td></tr>`;
                }
                rows += `
                    <tr><td>GST (${b2bTaxPct}%)</td><td>₹${b2bGstAmount.toLocaleString()}</td></tr>
                    <tr><td>Net Amount</td><td style="color:#2e7d32;font-weight:800">₹${b2bNetAmount.toLocaleString()}/night</td></tr>
                </table>`;
            }

            Swal.fire({
                title: roomTypeName,
                html: `<div style="text-align:left">${rows}</div>`,
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: '<i class="fas fa-plus"></i> Create Booking',
                cancelButtonText: 'Close',
                confirmButtonColor: '#1565c0'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `@Url.Action("Create", "Booking")?checkIn=${date}`;
                }
            });
        }
        
        function showLoading(show) {
            const overlay = document.getElementById('loadingOverlay');
            if (show) {
                overlay.classList.add('active');
            } else {
                overlay.classList.remove('active');
            }
        }
        
        // Synchronize scroll between wrapper and fixed column
        document.addEventListener('DOMContentLoaded', function() {
            const wrapper = document.querySelector('.calendar-wrapper');
            const fixedBody = document.getElementById('fixedColumnBody');
            
            if (wrapper && fixedBody) {
                wrapper.addEventListener('scroll', function() {
                    fixedBody.style.transform = `translateY(-${wrapper.scrollTop}px)`;
                });
            }
        });
    </script>
}